@using Uni_Selector.ViewModels.Home
@model AboutViewModel
@{
    ViewData["Title"] = "About Us";
}

<!-- Banner Section -->
<section>
    <div class="bg-lightGrey10 dark:bg-lightGrey10-dark relative z-0 overflow-y-visible py-50px md:py-20 lg:py-100px 2xl:pb-150px 2xl:pt-40.5">
        <!-- Animated Icons -->
        <div>
            <img class="absolute left-0 bottom-0 md:left-[14px] lg:left-[50px] lg:bottom-[21px] 2xl:left-[165px] 2xl:bottom-[60px] animate-move-var z-10" src="~/assets/images/herobanner/herobanner__1.png" alt="">
            <img class="absolute left-0 top-0 lg:left-[50px] lg:top-[100px] animate-spin-slow" src="~/assets/images/herobanner/herobanner__2.png" alt="">
            <img class="absolute right-[30px] top-0 md:right-10 lg:right-[575px] 2xl:top-20 animate-move-var2 opacity-50 hidden md:block" src="~/assets/images/herobanner/herobanner__3.png" alt="">
            <img class="absolute right-[30px] top-[212px] md:right-10 md:top-[157px] lg:right-[45px] lg:top-[100px] animate-move-hor" src="~/assets/images/herobanner/herobanner__5.png" alt="">
        </div>

        <div class="container">
            <div class="text-center">
                <h1 class="text-3xl md:text-size-40 2xl:text-size-55 font-bold text-blackColor dark:text-blackColor-dark mb-7 md:mb-6 pt-3">
                    About @Model.PlatformName
                </h1>
                <ul class="flex gap-1 justify-center">
                    <li>
                        <a asp-controller="Home" asp-action="Index" class="text-lg text-blackColor2 dark:text-blackColor2-dark">
                            Home <i class="icofont-simple-right"></i>
                        </a>
                    </li>
                    <li>
                        <span class="text-lg text-blackColor2 dark:text-blackColor2-dark">About Us</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- Main About Section -->
<section>
    <div class="container py-50px md:py-70px lg:py-20 2xl:py-100px">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-30px items-center">
            <!-- About Image -->
            <div data-aos="fade-up">
                <div class="relative overflow-hidden rounded-lg">
                    <img class="w-full rounded-lg shadow-brand" src="~/assets/images/about/about_14.png" alt="About Uni Selector">
                </div>
            </div>

            <!-- About Content -->
            <div data-aos="fade-up" class="2xl:ml-65px">
                <span class="text-sm font-semibold text-primaryColor bg-whitegrey3 px-6 py-5px mb-5 rounded-full inline-block">
                    About Us
                </span>
                <h3 class="text-3xl md:text-size-45 leading-10 md:leading-2xl font-bold text-blackColor dark:text-blackColor-dark pb-25px">
                    @Model.Title
                </h3>
                <p class="text-sm md:text-base leading-7 text-contentColor dark:text-contentColor-dark mb-25px">
                    @Model.Description
                </p>

                <div class="mt-30px">
                    <a asp-action="Universities" class="text-sm md:text-size-15 text-whiteColor bg-primaryColor border border-primaryColor px-25px py-15px hover:text-primaryColor hover:bg-whiteColor rounded inline-block dark:hover:bg-whiteColor-dark dark:hover:text-whiteColor">
                        Browse Universities <i class="icofont-long-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Statistics Section -->
<section class="bg-lightGrey10 dark:bg-lightGrey10-dark">
    <div class="container py-50px md:py-70px lg:py-100px">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-30px">
            @foreach (var stat in Model.Statistics)
            {
                <div class="text-center group" data-aos="fade-up">
                    <div class="p-30px bg-whiteColor dark:bg-whiteColor-dark shadow-brand dark:shadow-brand-dark rounded-lg transition-all duration-300 hover:shadow-brand-hover">
                        <div class="mb-20px">
                            <i class="@stat.Icon text-6xl text-@stat.Color"></i>
                        </div>
                        <h3 class="text-4xl font-bold text-blackColor dark:text-blackColor-dark mb-10px">
                            @stat.Number
                        </h3>
                        <p class="text-contentColor dark:text-contentColor-dark">
                            @stat.Label
                        </p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Features Section -->
<section>
    <div class="container py-50px md:py-70px lg:py-100px">
        <!-- Section Header -->
        <div class="text-center mb-50px" data-aos="fade-up">
            <span class="text-sm font-semibold text-primaryColor bg-whitegrey3 px-6 py-5px mb-5 rounded-full inline-block">
                Our Features
            </span>
            <h3 class="text-3xl md:text-[35px] lg:text-size-42 leading-[45px] font-bold text-blackColor dark:text-blackColor-dark">
                What Makes Us Different
            </h3>
        </div>

        <!-- Features Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-30px">
            @foreach (var feature in Model.Features)
            {
                <div class="group" data-aos="fade-up">
                    <div class="p-30px bg-whiteColor dark:bg-whiteColor-dark shadow-brand dark:shadow-brand-dark rounded-lg transition-all duration-300 hover:shadow-brand-hover hover:-translate-y-2">
                        <div class="mb-20px">
                            <div class="w-70px h-70px leading-70px text-center rounded-full bg-primaryColor bg-opacity-10 text-primaryColor text-3xl group-hover:bg-primaryColor group-hover:text-whiteColor transition-all duration-300">
                                <i class="@feature.Icon"></i>
                            </div>
                        </div>
                        <h4 class="text-xl font-bold text-blackColor dark:text-blackColor-dark mb-15px">
                            @feature.Title
                        </h4>
                        <p class="text-contentColor dark:text-contentColor-dark">
                            @feature.Description
                        </p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Mission Section -->
<section class="bg-lightGrey10 dark:bg-lightGrey10-dark">
    <div class="container py-50px md:py-70px lg:py-100px">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-30px items-center">
            <!-- Mission Image -->
            <div class="lg:col-span-5" data-aos="fade-up">
                <div class="relative overflow-hidden rounded-lg">
                    <img class="w-full rounded-lg shadow-brand" src="~/assets/images/about/about_8.png" alt="Our Mission">
                </div>
            </div>

            <!-- Mission Content -->
            <div class="lg:col-span-7" data-aos="fade-up">
                <span class="text-sm font-semibold text-primaryColor bg-whiteColor dark:bg-whiteColor-dark px-6 py-5px mb-5 rounded-full inline-block">
                    Our Mission
                </span>
                <h3 class="text-3xl md:text-size-45 leading-10 md:leading-2xl font-bold text-blackColor dark:text-blackColor-dark pb-25px">
                    @Model.Team.Title
                </h3>
                <p class="text-sm md:text-base leading-7 text-contentColor dark:text-contentColor-dark mb-25px">
                    @Model.Team.Description
                </p>

                <ul class="space-y-15px">
                    @foreach (var point in Model.Team.Points)
                    {
                        <li class="flex items-start gap-3">
                            <div class="flex-shrink-0 mt-1">
                                <i class="icofont-check-circled text-primaryColor text-xl"></i>
                            </div>
                            <p class="text-contentColor dark:text-contentColor-dark">
                                @point
                            </p>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- Call to Action -->
<section>
    <div class="container py-50px md:py-70px lg:py-100px">
        <div class="bg-primaryColor rounded-lg p-50px md:p-70px text-center" data-aos="fade-up">
            <h3 class="text-3xl md:text-size-45 font-bold text-whiteColor mb-20px">
                Ready to Find Your Perfect University?
            </h3>
            <p class="text-whiteColor text-lg mb-30px opacity-90 max-w-3xl mx-auto">
                Join thousands of students who have found their ideal academic path through Uni Selector. Start your journey today!
            </p>
            <div class="flex flex-wrap gap-4 justify-center">
                @if (User.Identity.IsAuthenticated)
                {
                    <a asp-action="Universities" class="inline-block bg-whiteColor text-primaryColor px-30px py-15px rounded font-semibold hover:bg-secondaryColor hover:text-whiteColor transition-all duration-300">
                        Browse Universities
                    </a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" asp-route-tab="register" class="inline-block bg-whiteColor text-primaryColor px-30px py-15px rounded font-semibold hover:bg-secondaryColor hover:text-whiteColor transition-all duration-300">
                        Get Started Free
                    </a>
                    <a asp-controller="Account" asp-action="Login" asp-route-tab="login" class="inline-block bg-transparent text-whiteColor border-2 border-whiteColor px-30px py-15px rounded font-semibold hover:bg-whiteColor hover:text-primaryColor transition-all duration-300">
                        Sign In
                    </a>
                }
            </div>
        </div>
    </div>
</section>
