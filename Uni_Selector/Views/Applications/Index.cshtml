@using Uni_Selector.Models.Enums
@using Uni_Selector.ViewModels.Applications
@model ApplicationsListViewModel
@{
    ViewData["Title"] = "My Applications";
}

<!-- Breadcrumb -->
<section class="py-50px bg-lightGrey10 dark:bg-lightGrey10-dark relative z-0">
    <div class="container">
        <div class="text-center">
            <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-blackColor dark:text-blackColor-dark mb-15px">
                My Applications
            </h1>
            <ul class="flex gap-1 justify-center">
                <li>
                    <a asp-controller="Dashboard" asp-action="Index" class="text-lg text-blackColor2 dark:text-blackColor2-dark hover:text-primaryColor dark:hover:text-primaryColor">
                        <i class="icofont-home"></i> Home
                    </a>
                </li>
                <li><i class="icofont-simple-right text-blackColor2 dark:text-blackColor2-dark"></i></li>
                <li><span class="text-lg text-blackColor2 dark:text-blackColor2-dark">Applications</span></li>
            </ul>
        </div>
    </div>
</section>

<!-- Applications Section -->
<section class="py-50px md:py-70px lg:py-20 2xl:py-100px">
    <div class="container">
        
        <!-- Statistics Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-30px mb-50px">
            <!-- Total Applications -->
            <div class="p-25px bg-whiteColor dark:bg-whiteColor-dark shadow-brand rounded-lg2">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-contentColor dark:text-contentColor-dark mb-5px">Total Applications</p>
                        <h3 class="text-3xl font-bold text-blackColor dark:text-blackColor-dark">@ViewBag.TotalApplications</h3>
                    </div>
                    <div class="w-60px h-60px flex items-center justify-center bg-primaryColor rounded-full">
                        <i class="icofont-file-document text-2xl text-whiteColor"></i>
                    </div>
                </div>
            </div>

            <!-- Pending -->
            <div class="p-25px bg-whiteColor dark:bg-whiteColor-dark shadow-brand rounded-lg2">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-contentColor dark:text-contentColor-dark mb-5px">Pending</p>
                        <h3 class="text-3xl font-bold text-blackColor dark:text-blackColor-dark">@ViewBag.PendingCount</h3>
                    </div>
                    <div class="w-60px h-60px flex items-center justify-center bg-yellow rounded-full">
                        <i class="icofont-clock-time text-2xl text-whiteColor"></i>
                    </div>
                </div>
            </div>

            <!-- Approved -->
            <div class="p-25px bg-whiteColor dark:bg-whiteColor-dark shadow-brand rounded-lg2">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-contentColor dark:text-contentColor-dark mb-5px">Approved</p>
                        <h3 class="text-3xl font-bold text-blackColor dark:text-blackColor-dark">@ViewBag.ApprovedCount</h3>
                    </div>
                    <div class="w-60px h-60px flex items-center justify-center bg-greencolor2 rounded-full">
                        <i class="icofont-check-circled text-2xl text-whiteColor"></i>
                    </div>
                </div>
            </div>

            <!-- Rejected -->
            <div class="p-25px bg-whiteColor dark:bg-whiteColor-dark shadow-brand rounded-lg2">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-contentColor dark:text-contentColor-dark mb-5px">Rejected</p>
                        <h3 class="text-3xl font-bold text-blackColor dark:text-blackColor-dark">@ViewBag.RejectedCount</h3>
                    </div>
                    <div class="w-60px h-60px flex items-center justify-center bg-red rounded-full">
                        <i class="icofont-close-circled text-2xl text-whiteColor"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filters & Search -->
        <div class="mb-30px">
            <form method="get" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-15px">
                <!-- Search -->
                <div class="lg:col-span-2">
                    <input type="text" name="searchTerm" value="@Model.SearchTerm" placeholder="Search by program, university, or application number..." 
                           class="w-full px-15px py-10px border border-borderColor dark:border-borderColor-dark rounded-md focus:outline-none focus:border-primaryColor dark:bg-whiteColor-dark dark:text-blackColor-dark" />
                </div>

                <!-- Status Filter -->
                <div>
                    <select name="status" class="w-full px-15px py-10px border border-borderColor dark:border-borderColor-dark rounded-md focus:outline-none focus:border-primaryColor dark:bg-whiteColor-dark dark:text-blackColor-dark">
                        <option value="">All Status</option>
                        <option value="Pending" selected="@(Model.StatusFilter == "Pending")">Pending</option>
                        <option value="UnderReview" selected="@(Model.StatusFilter == "UnderReview")">Under Review</option>
                        <option value="Approved" selected="@(Model.StatusFilter == "Approved")">Approved</option>
                        <option value="Rejected" selected="@(Model.StatusFilter == "Rejected")">Rejected</option>
                        <option value="Enrolled" selected="@(Model.StatusFilter == "Enrolled")">Enrolled</option>
                        <option value="Cancelled" selected="@(Model.StatusFilter == "Cancelled")">Cancelled</option>
                    </select>
                </div>

                <!-- Sort -->
                <div>
                    <select name="sortBy" class="w-full px-15px py-10px border border-borderColor dark:border-borderColor-dark rounded-md focus:outline-none focus:border-primaryColor dark:bg-whiteColor-dark dark:text-blackColor-dark">
                        <option value="newest" selected="@(Model.SortBy == "newest")">Newest First</option>
                        <option value="oldest" selected="@(Model.SortBy == "oldest")">Oldest First</option>
                        <option value="status" selected="@(Model.SortBy == "status")">By Status</option>
                        <option value="university" selected="@(Model.SortBy == "university")">By University</option>
                    </select>
                </div>

                <!-- Submit -->
                <div>
                    <button type="submit" class="w-full px-15px py-10px bg-primaryColor text-whiteColor rounded-md hover:bg-primaryColor-dark transition-all duration-300">
                        <i class="icofont-search"></i> Filter
                    </button>
                </div>
            </form>
        </div>

        @if (Model.Applications.Any())
        {
            <!-- Applications Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-30px mb-50px">
                @foreach (var app in Model.Applications)
                {
                    <!-- Application Card -->
                    <div class="group" data-aos="fade-up">
                        <div class="p-15px bg-whiteColor shadow-brand dark:bg-darkdeep3-dark dark:shadow-brand-dark rounded-lg2">
                            
                            <!-- Card Image -->
                            <div class="relative mb-4 overflow-hidden rounded-md">
                                <a asp-action="Details" asp-route-id="@app.Id" class="w-full">
                                    @if (!string.IsNullOrEmpty(app.UniversityImage))
                                    {
                                        <img src="@app.UniversityImage" alt="@app.UniversityName" class="w-full h-48 object-cover transition-all duration-300 group-hover:scale-110" />
                                    }
                                    else
                                    {
                                        <div class="w-full h-48 bg-gradient-to-br from-primaryColor to-secondaryColor flex items-center justify-center">
                                            <i class="icofont-graduate text-6xl text-whiteColor opacity-50"></i>
                                        </div>
                                    }
                                </a>
                                
                                <!-- Status Badge -->
                                <div class="absolute left-0 top-1 flex justify-between w-full items-center px-2">
                                    <div>
                                        <p class="text-xs text-whiteColor px-4 py-[3px] @GetStatusBadgeClass(app.Status) rounded font-semibold">
                                            @app.Status
                                        </p>
                                    </div>
                                    @if (app.IsBtec)
                                    {
                                        <span class="text-xs text-whiteColor px-3 py-[3px] bg-purple rounded font-semibold">
                                            BTEC
                                        </span>
                                    }
                                </div>
                            </div>

                            <!-- Card Content -->
                            <div>
                                <!-- Application Number -->
                                <div class="flex items-center gap-2 mb-10px">
                                    <i class="icofont-id text-primaryColor"></i>
                                    <span class="text-xs text-contentColor dark:text-contentColor-dark font-medium">
                                        @app.ApplicationNumber
                                    </span>
                                    @if (!string.IsNullOrEmpty(app.AdmissionNumber))
                                    {
                                        <span class="text-xs text-greencolor2 font-bold ml-auto">
                                            <i class="icofont-check-circled"></i> @app.AdmissionNumber
                                        </span>
                                    }
                                </div>

                                <!-- Program Name -->
                                <a asp-action="Details" asp-route-id="@app.Id" class="text-lg font-semibold text-blackColor mb-10px font-hind dark:text-blackColor-dark hover:text-primaryColor dark:hover:text-primaryColor line-clamp-2">
                                    @app.ProgramName
                                </a>

                                <!-- University -->
                                <div class="flex items-center gap-2 mb-15px">
                                    @if (!string.IsNullOrEmpty(app.UniversityLogo))
                                    {
                                        <img src="@app.UniversityLogo" alt="@app.UniversityName" class="w-8 h-8 rounded-full object-cover" />
                                    }
                                    <span class="text-sm text-contentColor dark:text-contentColor-dark">
                                        @app.UniversityName
                                    </span>
                                </div>

                                <!-- Application Date -->
                                <div class="flex items-center gap-2 mb-4">
                                    <i class="icofont-calendar text-primaryColor"></i>
                                    <span class="text-sm text-black dark:text-blackColor-dark">
                                        @app.ApplicationDate.ToString("MMM dd, yyyy")
                                    </span>
                                </div>

                                <!-- Actions -->
                                <div class="flex gap-2 pt-15px border-t border-borderColor dark:border-borderColor-dark">
                                    <a asp-action="Details" asp-route-id="@app.Id" class="flex-1 px-15px py-10px bg-primaryColor text-whiteColor text-center rounded-md hover:bg-primaryColor-dark transition-all duration-300 text-sm">
                                        <i class="icofont-eye"></i> View Details
                                    </a>
                                    @if (app.CanCancel)
                                    {
                                        <button type="button" onclick="cancelApplication(@app.Id)" class="px-15px py-10px bg-red text-whiteColor rounded-md hover:bg-red-dark transition-all duration-300 text-sm">
                                            <i class="icofont-ban"></i>
                                        </button>
                                    }
                                </div>

                                <!-- Discount Badge -->
                                @if (app.HasDiscount)
                                {
                                    <div class="mt-3 text-center">
                                        <span class="text-xs px-3 py-1 bg-greencolor2 text-whiteColor rounded-full">
                                            <i class="icofont-gift"></i> Discount: @app.DiscountCode
                                        </span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <div class="flex justify-center items-center gap-3">
                    @if (Model.PageNumber > 1)
                    {
                        <a asp-action="Index" asp-route-pageNumber="@(Model.PageNumber - 1)" asp-route-status="@Model.StatusFilter" asp-route-searchTerm="@Model.SearchTerm" asp-route-sortBy="@Model.SortBy" 
                           class="px-15px py-10px bg-whiteColor dark:bg-whiteColor-dark text-blackColor dark:text-blackColor-dark border border-borderColor dark:border-borderColor-dark rounded-md hover:bg-primaryColor hover:text-whiteColor hover:border-primaryColor transition-all duration-300">
                            <i class="icofont-rounded-left"></i> Previous
                        </a>
                    }

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        if (i == Model.PageNumber)
                        {
                            <span class="px-15px py-10px bg-primaryColor text-whiteColor rounded-md">@i</span>
                        }
                        else if (i == 1 || i == Model.TotalPages || (i >= Model.PageNumber - 2 && i <= Model.PageNumber + 2))
                        {
                            <a asp-action="Index" asp-route-pageNumber="@i" asp-route-status="@Model.StatusFilter" asp-route-searchTerm="@Model.SearchTerm" asp-route-sortBy="@Model.SortBy"
                               class="px-15px py-10px bg-whiteColor dark:bg-whiteColor-dark text-blackColor dark:text-blackColor-dark border border-borderColor dark:border-borderColor-dark rounded-md hover:bg-primaryColor hover:text-whiteColor hover:border-primaryColor transition-all duration-300">
                                @i
                            </a>
                        }
                        else if (i == Model.PageNumber - 3 || i == Model.PageNumber + 3)
                        {
                            <span class="px-15px py-10px">...</span>
                        }
                    }

                    @if (Model.PageNumber < Model.TotalPages)
                    {
                        <a asp-action="Index" asp-route-pageNumber="@(Model.PageNumber + 1)" asp-route-status="@Model.StatusFilter" asp-route-searchTerm="@Model.SearchTerm" asp-route-sortBy="@Model.SortBy"
                           class="px-15px py-10px bg-whiteColor dark:bg-whiteColor-dark text-blackColor dark:text-blackColor-dark border border-borderColor dark:border-borderColor-dark rounded-md hover:bg-primaryColor hover:text-whiteColor hover:border-primaryColor transition-all duration-300">
                            Next <i class="icofont-rounded-right"></i>
                        </a>
                    }
                </div>
            }
        }
        else
        {
            <!-- Empty State -->
            <div class="text-center py-100px">
                <i class="icofont-file-document text-9xl text-lightGrey6 dark:text-lightGrey6-dark mb-25px"></i>
                <h3 class="text-2xl font-bold text-blackColor dark:text-blackColor-dark mb-15px">No Applications Found</h3>
                <p class="text-contentColor dark:text-contentColor-dark mb-25px">
                    @if (!string.IsNullOrEmpty(Model.SearchTerm) || !string.IsNullOrEmpty(Model.StatusFilter))
                    {
                        <text>No applications match your filters. Try adjusting your search criteria.</text>
                    }
                    else
                    {
                        <text>You haven't submitted any applications yet. Start by exploring our recommendations!</text>
                    }
                </p>
                <a asp-controller="Recommendations" asp-action="Index" class="px-30px py-15px bg-primaryColor text-whiteColor rounded-md hover:bg-primaryColor-dark transition-all duration-300">
                    <i class="icofont-search-document"></i> View Recommendations
                </a>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function cancelApplication(id) {
            Swal.fire({
                title: 'Cancel Application?',
                text: 'Are you sure you want to cancel this application? This action cannot be undone.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, cancel it!',
                cancelButtonText: 'No, keep it'
            }).then((result) => {
                if (result.isConfirmed) {
                    // AJAX request to cancel
                    fetch('/Applications/' + id + '/Cancel', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        }
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Cancelled!',
                                text: data.message,
                                confirmButtonColor: '#3b82f6'
                            }).then(() => {
                                window.location.reload();
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error!',
                                text: data.message,
                                confirmButtonColor: '#3b82f6'
                            });
                        }
                    });
                }
            });
        }

        // Show success/error messages
        @if (TempData["Success"] != null)
        {
            <text>
            Swal.fire({
                icon: 'success',
                title: 'Success!',
                text: '@TempData["Success"]',
                confirmButtonColor: '#3b82f6'
            });
            </text>
        }

        @if (TempData["Error"] != null)
        {
            <text>
            Swal.fire({
                icon: 'error',
                title: 'Error!',
                text: '@TempData["Error"]',
                confirmButtonColor: '#3b82f6'
            });
            </text>
        }
    </script>
}

@functions {
    string GetStatusBadgeClass(ApplicationStatus status)
    {
        return status switch
        {
            ApplicationStatus.Pending => "bg-yellow",
            ApplicationStatus.UnderReview => "bg-blue",
            ApplicationStatus.Approved => "bg-greencolor2",
            ApplicationStatus.Rejected => "bg-red",
            ApplicationStatus.Enrolled => "bg-purple",
            ApplicationStatus.Cancelled => "bg-gray-500",
            _ => "bg-gray-400"
        };
    }
}

<form method="post" style="display:none;">
    @Html.AntiForgeryToken()
</form>
