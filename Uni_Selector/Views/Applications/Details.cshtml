@using Uni_Selector.Models.Enums
@using Uni_Selector.ViewModels.Applications
@model ApplicationDetailsViewModel
@{
    ViewData["Title"] = "Application Details";
}

<!-- Breadcrumb -->
<section class="py-50px bg-lightGrey10 dark:bg-lightGrey10-dark relative z-0">
    <div class="container">
        <div class="text-center">
            <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-blackColor dark:text-blackColor-dark mb-15px">
                Application Details
            </h1>
            <ul class="flex gap-1 justify-center">
                <li>
                    <a asp-controller="Dashboard" asp-action="Index" class="text-lg text-blackColor2 dark:text-blackColor2-dark hover:text-primaryColor dark:hover:text-primaryColor">
                        <i class="icofont-home"></i> Home
                    </a>
                </li>
                <li><i class="icofont-simple-right text-blackColor2 dark:text-blackColor2-dark"></i></li>
                <li>
                    <a asp-action="Index" class="text-lg text-blackColor2 dark:text-blackColor2-dark hover:text-primaryColor dark:hover:text-primaryColor">
                        Applications
                    </a>
                </li>
                <li><i class="icofont-simple-right text-blackColor2 dark:text-blackColor2-dark"></i></li>
                <li><span class="text-lg text-blackColor2 dark:text-blackColor2-dark">@Model.ApplicationNumber</span></li>
            </ul>
        </div>
    </div>
</section>

<!-- Application Details Section -->
<section class="py-50px md:py-70px lg:py-20 2xl:py-100px">
    <div class="container">
        
        <!-- Status Banner -->
        <div class="mb-40px p-30px bg-whiteColor dark:bg-whiteColor-dark shadow-brand rounded-lg2">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-20px items-center">
                <!-- Application Number -->
                <div>
                    <p class="text-xs text-contentColor dark:text-contentColor-dark mb-5px">Application Number</p>
                    <p class="text-xl font-bold text-blackColor dark:text-blackColor-dark flex items-center">
                        <i class="icofont-id text-primaryColor mr-10px"></i>
                        @Model.ApplicationNumber
                    </p>
                </div>

                <!-- Status -->
                <div>
                    <p class="text-xs text-contentColor dark:text-contentColor-dark mb-5px">Status</p>
                    <span class="inline-block px-4 py-2 @Model.StatusBadgeClass rounded-lg font-semibold text-sm">
                        <i class="@Model.StatusIcon mr-5px"></i>
                        @Model.Status
                    </span>
                </div>

                <!-- Application Date -->
                <div>
                    <p class="text-xs text-contentColor dark:text-contentColor-dark mb-5px">Submitted On</p>
                    <p class="text-base font-semibold text-blackColor dark:text-blackColor-dark">
                        <i class="icofont-calendar text-primaryColor mr-5px"></i>
                        @Model.ApplicationDate.ToString("MMM dd, yyyy")
                    </p>
                </div>

                <!-- Actions -->
                <div class="text-left md:text-right">
                    @if (Model.CanCancel)
                    {
                        <button type="button" onclick="cancelApplication(@Model.Id)" 
                                class="px-20px py-10px bg-red text-whiteColor rounded-md hover:bg-red-dark transition-all duration-300">
                            <i class="icofont-ban"></i> Cancel Application
                        </button>
                    }
                    else if (Model.Status == ApplicationStatus.Approved && !string.IsNullOrEmpty(Model.AdmissionNumber))
                    {
                        <div class="inline-block px-20px py-10px bg-greencolor2 text-whiteColor rounded-md">
                            <i class="icofont-graduate"></i> Admission #@Model.AdmissionNumber
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-30px">
            
            <!-- Main Content Column -->
            <div class="lg:col-span-2">
                
                <!-- Status-Specific Messages -->
                @if (Model.Status == ApplicationStatus.Approved)
                {
                    <div class="mb-30px p-25px bg-greencolor2 bg-opacity-10 border-l-4 border-greencolor2 rounded-lg">
                        <h4 class="text-lg font-semibold text-greencolor2 mb-10px flex items-center">
                            <i class="icofont-check-circled mr-10px text-2xl"></i>
                            Congratulations! Your Application Has Been Approved
                        </h4>
                        <p class="text-sm text-contentColor dark:text-contentColor-dark mb-10px">
                            Your application has been approved by @Model.UniversityName. 
                            @if (!string.IsNullOrEmpty(Model.AdmissionNumber))
                            {
                                <text>Your admission number is <strong>@Model.AdmissionNumber</strong>.</text>
                            }
                        </p>
                        @if (Model.HasDiscount)
                        {
                            <p class="text-sm text-greencolor2 font-semibold">
                                <i class="icofont-gift"></i> Your discount code: <strong>@Model.DiscountCode</strong>
                            </p>
                        }
                    </div>
                }
                else if (Model.Status == ApplicationStatus.Rejected)
                {
                    <div class="mb-30px p-25px bg-red bg-opacity-10 border-l-4 border-red rounded-lg">
                        <h4 class="text-lg font-semibold text-red mb-10px flex items-center">
                            <i class="icofont-close-circled mr-10px text-2xl"></i>
                            Application Not Approved
                        </h4>
                        <p class="text-sm text-contentColor dark:text-contentColor-dark mb-10px">
                            Unfortunately, your application was not approved at this time.
                        </p>
                        @if (!string.IsNullOrEmpty(Model.RejectionReason))
                        {
                            <p class="text-sm text-blackColor dark:text-blackColor-dark">
                                <strong>Reason:</strong> @Model.RejectionReason
                            </p>
                        }
                    </div>
                }
                else if (Model.Status == ApplicationStatus.Pending)
                {
                    <div class="mb-30px p-25px bg-yellow bg-opacity-10 border-l-4 border-yellow rounded-lg">
                        <h4 class="text-lg font-semibold text-yellow mb-10px flex items-center">
                            <i class="icofont-clock-time mr-10px text-2xl"></i>
                            Application Pending Review
                        </h4>
                        <p class="text-sm text-contentColor dark:text-contentColor-dark">
                            Your application has been submitted and is awaiting review by the university. You will be notified once there's an update.
                        </p>
                    </div>
                }
                else if (Model.Status == ApplicationStatus.UnderReview)
                {
                    <div class="mb-30px p-25px bg-blue bg-opacity-10 border-l-4 border-blue rounded-lg">
                        <h4 class="text-lg font-semibold text-blue mb-10px flex items-center">
                            <i class="icofont-eye mr-10px text-2xl"></i>
                            Application Under Review
                        </h4>
                        <p class="text-sm text-contentColor dark:text-contentColor-dark">
                            The university is currently reviewing your application. This usually takes 3-5 business days.
                        </p>
                    </div>
                }

                <!-- Tabs -->
                <div class="bg-whiteColor dark:bg-whiteColor-dark shadow-brand rounded-lg2">
                    
                    <!-- Tab Headers -->
                    <div class="border-b border-borderColor dark:border-borderColor-dark">
                        <ul class="flex flex-wrap -mb-px text-sm font-medium text-center" role="tablist">
                            <li class="mr-2" role="presentation">
                                <button class="inline-block p-4 border-b-2 border-primaryColor text-primaryColor rounded-t-lg active" 
                                        id="overview-tab" data-tabs-target="#overview" type="button" role="tab" aria-controls="overview" aria-selected="true">
                                    <i class="icofont-info-circle mr-5px"></i> Overview
                                </button>
                            </li>
                            <li class="mr-2" role="presentation">
                                <button class="inline-block p-4 border-b-2 border-transparent rounded-t-lg hover:text-primaryColor hover:border-primaryColor" 
                                        id="program-tab" data-tabs-target="#program" type="button" role="tab" aria-controls="program" aria-selected="false">
                                    <i class="icofont-graduate mr-5px"></i> Program Details
                                </button>
                            </li>
                            <li class="mr-2" role="presentation">
                                <button class="inline-block p-4 border-b-2 border-transparent rounded-t-lg hover:text-primaryColor hover:border-primaryColor" 
                                        id="university-tab" data-tabs-target="#university" type="button" role="tab" aria-controls="university" aria-selected="false">
                                    <i class="icofont-building-alt mr-5px"></i> University Info
                                </button>
                            </li>
                        </ul>
                    </div>

                    <!-- Tab Content -->
                    <div class="p-30px">
                        
                        <!-- Overview Tab -->
                        <div id="overview" role="tabpanel" aria-labelledby="overview-tab">
                            
                            <!-- Student Information -->
                            <div class="mb-30px">
                                <h5 class="text-lg font-semibold text-blackColor dark:text-blackColor-dark mb-15px flex items-center">
                                    <i class="icofont-user text-primaryColor mr-10px"></i>
                                    Student Information
                                </h5>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-15px">
                                    <div class="p-15px bg-lightGrey10 dark:bg-lightGrey10-dark rounded-lg">
                                        <p class="text-xs text-contentColor dark:text-contentColor-dark mb-5px">Full Name</p>
                                        <p class="text-base font-semibold text-blackColor dark:text-blackColor-dark">@Model.StudentFullName</p>
                                    </div>
                                    <div class="p-15px bg-lightGrey10 dark:bg-lightGrey10-dark rounded-lg">
                                        <p class="text-xs text-contentColor dark:text-contentColor-dark mb-5px">Email</p>
                                        <p class="text-base font-semibold text-blackColor dark:text-blackColor-dark">@Model.StudentEmail</p>
                                    </div>
                                    @if (!string.IsNullOrEmpty(Model.StudentPhone))
                                    {
                                        <div class="p-15px bg-lightGrey10 dark:bg-lightGrey10-dark rounded-lg">
                                            <p class="text-xs text-contentColor dark:text-contentColor-dark mb-5px">Phone</p>
                                            <p class="text-base font-semibold text-blackColor dark:text-blackColor-dark">@Model.StudentPhone</p>
                                        </div>
                                    }
                                    <div class="p-15px bg-lightGrey10 dark:bg-lightGrey10-dark rounded-lg">
                                        <p class="text-xs text-contentColor dark:text-contentColor-dark mb-5px">GPA</p>
                                        <p class="text-base font-semibold text-blackColor dark:text-blackColor-dark">
                                            <span class="px-3 py-1 bg-greencolor2 text-whiteColor rounded-full text-sm">
                                                @Model.StudentGPA
                                            </span>
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <!-- Application Information -->
                            <div class="mb-30px">
                                <h5 class="text-lg font-semibold text-blackColor dark:text-blackColor-dark mb-15px flex items-center">
                                    <i class="icofont-file-document text-primaryColor mr-10px"></i>
                                    Application Information
                                </h5>
                                <div class="space-y-15px">
                                    @if (Model.PlannedFirstSemesterHours.HasValue)
                                    {
                                        <div class="flex items-center justify-between p-15px bg-lightGrey10 dark:bg-lightGrey10-dark rounded-lg">
                                            <span class="text-sm text-contentColor dark:text-contentColor-dark">Planned First Semester Hours</span>
                                            <span class="text-base font-semibold text-blackColor dark:text-blackColor-dark">
                                                @Model.PlannedFirstSemesterHours Credits
                                            </span>
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(Model.Notes))
                                    {
                                        <div class="p-15px bg-lightGrey10 dark:bg-lightGrey10-dark rounded-lg">
                                            <p class="text-xs text-contentColor dark:text-contentColor-dark mb-5px">Additional Notes</p>
                                            <p class="text-sm text-blackColor dark:text-blackColor-dark">@Model.Notes</p>
                                        </div>
                                    }
                                    @if (Model.HourDiscountPercent.HasValue)
                                    {
                                        <div class="flex items-center justify-between p-15px bg-greencolor2 bg-opacity-10 rounded-lg border border-greencolor2 border-opacity-30">
                                            <span class="text-sm text-contentColor dark:text-contentColor-dark">
                                                <i class="icofont-sale-discount text-greencolor2"></i> Hour Discount
                                            </span>
                                            <span class="text-base font-bold text-greencolor2">
                                                @Model.HourDiscountPercent%
                                            </span>
                                        </div>
                                    }
                                </div>
                            </div>

                            <!-- Timeline -->
                            <div>
                                <h5 class="text-lg font-semibold text-blackColor dark:text-blackColor-dark mb-15px flex items-center">
                                    <i class="icofont-history text-primaryColor mr-10px"></i>
                                    Application Timeline
                                </h5>
                                <div class="relative border-l-2 border-primaryColor pl-25px space-y-20px">
                                    <!-- Submitted -->
                                    <div class="relative">
                                        <div class="absolute -left-[29px] w-3 h-3 bg-primaryColor rounded-full border-2 border-whiteColor dark:border-whiteColor-dark"></div>
                                        <p class="text-sm font-semibold text-blackColor dark:text-blackColor-dark">Application Submitted</p>
                                        <p class="text-xs text-contentColor dark:text-contentColor-dark">
                                            @Model.ApplicationDate.ToString("MMM dd, yyyy 'at' hh:mm tt")
                                        </p>
                                    </div>

                                    @if (Model.Status != ApplicationStatus.Pending && Model.UpdatedAt.HasValue)
                                    {
                                        <div class="relative">
                                            <div class="absolute -left-[29px] w-3 h-3 bg-primaryColor rounded-full border-2 border-whiteColor dark:border-whiteColor-dark"></div>
                                            <p class="text-sm font-semibold text-blackColor dark:text-blackColor-dark">Status Updated to @Model.Status</p>
                                            <p class="text-xs text-contentColor dark:text-contentColor-dark">
                                                @Model.UpdatedAt.Value.ToString("MMM dd, yyyy 'at' hh:mm tt")
                                            </p>
                                        </div>
                                    }

                                    @if (Model.ApprovalDate.HasValue)
                                    {
                                        <div class="relative">
                                            <div class="absolute -left-[29px] w-3 h-3 bg-greencolor2 rounded-full border-2 border-whiteColor dark:border-whiteColor-dark"></div>
                                            <p class="text-sm font-semibold text-greencolor2">Application Approved</p>
                                            <p class="text-xs text-contentColor dark:text-contentColor-dark">
                                                @Model.ApprovalDate.Value.ToString("MMM dd, yyyy 'at' hh:mm tt")
                                            </p>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Program Details Tab -->
                        <div class="hidden" id="program" role="tabpanel" aria-labelledby="program-tab">
                            <div class="space-y-20px">
                                <div>
                                    <h5 class="text-2xl font-bold text-blackColor dark:text-blackColor-dark mb-10px">
                                        @Model.ProgramName
                                    </h5>
                                    @if (!string.IsNullOrEmpty(Model.ProgramNameArabic))
                                    {
                                        <p class="text-lg text-contentColor dark:text-contentColor-dark mb-10px">@Model.ProgramNameArabic</p>
                                    }
                                    @if (Model.IsBtec)
                                    {
                                        <span class="inline-block px-4 py-2 bg-purple text-whiteColor rounded-lg text-sm font-semibold">
                                            BTEC @Model.BtecLevel
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-block px-4 py-2 bg-primaryColor text-whiteColor rounded-lg text-sm font-semibold">
                                            @Model.Degree
                                        </span>
                                    }
                                </div>

                                @if (!string.IsNullOrEmpty(Model.ProgramDescription))
                                {
                                    <div class="p-20px bg-lightGrey10 dark:bg-lightGrey10-dark rounded-lg">
                                        <h6 class="text-sm font-semibold text-blackColor dark:text-blackColor-dark mb-10px">Description</h6>
                                        <p class="text-sm text-contentColor dark:text-contentColor-dark">@Model.ProgramDescription</p>
                                    </div>
                                }

                                <div class="grid grid-cols-2 gap-15px">
                                    @if (Model.TotalCreditHours.HasValue)
                                    {
                                        <div class="p-15px bg-lightGrey10 dark:bg-lightGrey10-dark rounded-lg text-center">
                                            <i class="icofont-book-alt text-3xl text-primaryColor mb-10px"></i>
                                            <p class="text-xs text-contentColor dark:text-contentColor-dark mb-5px">Total Credit Hours</p>
                                            <p class="text-xl font-bold text-blackColor dark:text-blackColor-dark">@Model.TotalCreditHours</p>
                                        </div>
                                    }
                                    @if (Model.DurationYears.HasValue)
                                    {
                                        <div class="p-15px bg-lightGrey10 dark:bg-lightGrey10-dark rounded-lg text-center">
                                            <i class="icofont-clock-time text-3xl text-primaryColor mb-10px"></i>
                                            <p class="text-xs text-contentColor dark:text-contentColor-dark mb-5px">Duration</p>
                                            <p class="text-xl font-bold text-blackColor dark:text-blackColor-dark">@Model.DurationYears Years</p>
                                        </div>
                                    }
                                    @if (Model.SemesterStartDate.HasValue)
                                    {
                                        <div class="p-15px bg-lightGrey10 dark:bg-lightGrey10-dark rounded-lg text-center">
                                            <i class="icofont-calendar text-3xl text-primaryColor mb-10px"></i>
                                            <p class="text-xs text-contentColor dark:text-contentColor-dark mb-5px">Semester Starts</p>
                                            <p class="text-base font-bold text-blackColor dark:text-blackColor-dark">@Model.SemesterStartDate.Value.ToString("MMM yyyy")</p>
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(Model.TechnicalField))
                                    {
                                        <div class="p-15px bg-lightGrey10 dark:bg-lightGrey10-dark rounded-lg text-center">
                                            <i class="icofont-tools text-3xl text-primaryColor mb-10px"></i>
                                            <p class="text-xs text-contentColor dark:text-contentColor-dark mb-5px">Technical Field</p>
                                            <p class="text-base font-bold text-blackColor dark:text-blackColor-dark">@Model.TechnicalField</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- University Info Tab -->
                        <div class="hidden" id="university" role="tabpanel" aria-labelledby="university-tab">
                            <div class="space-y-20px">
                                <!-- University Header -->
                                <div class="text-center pb-20px border-b border-borderColor dark:border-borderColor-dark">
                                    @if (!string.IsNullOrEmpty(Model.UniversityLogo))
                                    {
                                        <img src="@Model.UniversityLogo" alt="@Model.UniversityName" class="h-24 mx-auto mb-15px object-contain" />
                                    }
                                    <h5 class="text-2xl font-bold text-blackColor dark:text-blackColor-dark mb-10px">
                                        @Model.UniversityName
                                    </h5>
                                    @if (!string.IsNullOrEmpty(Model.UniversityAddress))
                                    {
                                        <p class="text-sm text-contentColor dark:text-contentColor-dark flex items-center justify-center">
                                            <i class="icofont-location-pin text-primaryColor mr-5px"></i>
                                            @Model.UniversityAddress
                                        </p>
                                    }
                                </div>

                                <!-- Contact Information -->
                                <div>
                                    <h6 class="text-lg font-semibold text-blackColor dark:text-blackColor-dark mb-15px">Contact Information</h6>
                                    <div class="space-y-10px">
                                        @if (!string.IsNullOrEmpty(Model.UniversityPhone))
                                        {
                                            <div class="flex items-center p-15px bg-lightGrey10 dark:bg-lightGrey10-dark rounded-lg">
                                                <i class="icofont-phone text-primaryColor text-xl mr-15px"></i>
                                                <div>
                                                    <p class="text-xs text-contentColor dark:text-contentColor-dark">Phone</p>
                                                    <p class="text-base font-semibold text-blackColor dark:text-blackColor-dark">@Model.UniversityPhone</p>
                                                </div>
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(Model.UniversityEmail))
                                        {
                                            <div class="flex items-center p-15px bg-lightGrey10 dark:bg-lightGrey10-dark rounded-lg">
                                                <i class="icofont-email text-primaryColor text-xl mr-15px"></i>
                                                <div>
                                                    <p class="text-xs text-contentColor dark:text-contentColor-dark">Email</p>
                                                    <p class="text-base font-semibold text-blackColor dark:text-blackColor-dark">@Model.UniversityEmail</p>
                                                </div>
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(Model.UniversityWebsite))
                                        {
                                            <div class="flex items-center p-15px bg-lightGrey10 dark:bg-lightGrey10-dark rounded-lg">
                                                <i class="icofont-link text-primaryColor text-xl mr-15px"></i>
                                                <div>
                                                    <p class="text-xs text-contentColor dark:text-contentColor-dark">Website</p>
                                                    <a href="@Model.UniversityWebsite" target="_blank" class="text-base font-semibold text-primaryColor hover:underline">
                                                        Visit Website <i class="icofont-external-link text-sm"></i>
                                                    </a>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sidebar Column -->
            <div class="lg:col-span-1">
                
                <!-- Pricing Card -->
                @if (Model.HourPriceBase.HasValue && Model.RegistrationFeeFirstSemester.HasValue)
                {
                    <div class="p-25px bg-whiteColor dark:bg-whiteColor-dark shadow-brand rounded-lg2 mb-30px sticky top-100px">
                        <h4 class="text-lg font-semibold text-blackColor dark:text-blackColor-dark mb-20px flex items-center">
                            <i class="icofont-price text-primaryColor mr-10px"></i>
                            Cost Breakdown
                        </h4>

                        <div class="space-y-15px mb-20px">
                            <div class="flex items-center justify-between">
                                <span class="text-sm text-contentColor dark:text-contentColor-dark">Registration Fee</span>
                                <span class="text-base font-semibold text-blackColor dark:text-blackColor-dark">
                                    @Model.RegistrationFeeFirstSemester.Value.ToString("N2") JOD
                                </span>
                            </div>
                            @if (Model.PlannedFirstSemesterHours.HasValue)
                            {
                                <div class="flex items-center justify-between">
                                    <span class="text-sm text-contentColor dark:text-contentColor-dark">
                                        Tuition (@Model.PlannedFirstSemesterHours hrs × @Model.HourPriceBase.Value.ToString("N2"))
                                    </span>
                                    <span class="text-base font-semibold text-blackColor dark:text-blackColor-dark">
                                        @((Model.PlannedFirstSemesterHours.Value * Model.HourPriceBase.Value).ToString("N2")) JOD
                                    </span>
                                </div>
                            }
                            @if (Model.HasDiscount && Model.DiscountPercentage.HasValue)
                            {
                                <div class="flex items-center justify-between text-greencolor2">
                                    <span class="text-sm">Platform Discount (@Model.DiscountPercentage%)</span>
                                    <span class="text-base font-semibold">
                                        -@Model.DiscountAmount.Value.ToString("N2") JOD
                                    </span>
                                </div>
                            }
                        </div>

                        <div class="pt-15px border-t border-borderColor dark:border-borderColor-dark">
                            <div class="flex items-center justify-between">
                                <span class="text-base font-semibold text-blackColor dark:text-blackColor-dark">Estimated Total</span>
                                <span class="text-2xl font-bold text-primaryColor">
                                    @{
                                        var total = Model.RegistrationFeeFirstSemester.Value;
                                        if (Model.PlannedFirstSemesterHours.HasValue)
                                        {
                                            total += Model.PlannedFirstSemesterHours.Value * Model.HourPriceBase.Value;
                                        }
                                        if (Model.HasDiscount && Model.DiscountAmount.HasValue)
                                        {
                                            total -= Model.DiscountAmount.Value;
                                        }
                                    }
                                    @total.ToString("N2") <span class="text-sm">JOD</span>
                                </span>
                            </div>
                        </div>
                    </div>
                }

                <!-- Discount Code Card -->
                @if (Model.HasDiscount)
                {
                    <div class="p-25px bg-greencolor2 bg-opacity-10 border-2 border-greencolor2 border-dashed rounded-lg2 mb-30px">
                        <h5 class="text-base font-semibold text-greencolor2 mb-15px flex items-center">
                            <i class="icofont-gift mr-10px text-xl"></i>
                            Your Discount Code
                        </h5>
                        <div class="p-15px bg-whiteColor dark:bg-whiteColor-dark rounded-lg text-center mb-15px">
                            <p class="text-2xl font-bold text-greencolor2 tracking-wider">@Model.DiscountCode</p>
                        </div>
                        <p class="text-xs text-contentColor dark:text-contentColor-dark text-center mb-10px">
                            Status: <span class="font-semibold text-greencolor2">@Model.DiscountStatus</span>
                        </p>
                        <p class="text-xs text-contentColor dark:text-contentColor-dark text-center">
                            Present this code at the university during registration to receive your @Model.DiscountPercentage% discount.
                        </p>
                    </div>
                }

                <!-- Quick Actions -->
                <div class="p-25px bg-whiteColor dark:bg-whiteColor-dark shadow-brand rounded-lg2">
                    <h5 class="text-base font-semibold text-blackColor dark:text-blackColor-dark mb-15px">
                        Quick Actions
                    </h5>
                    <div class="space-y-10px">
                        <a asp-action="Index" class="w-full px-20px py-12px bg-primaryColor text-whiteColor rounded-md hover:bg-primaryColor-dark transition-all duration-300 inline-block text-center text-sm">
                            <i class="icofont-listing-box"></i> View All Applications
                        </a>
                        @if (!string.IsNullOrEmpty(Model.UniversityEmail))
                        {
                            <a href="mailto:@Model.UniversityEmail" class="w-full px-20px py-12px bg-gray-200 dark:bg-gray-700 text-blackColor dark:text-whiteColor rounded-md hover:bg-gray-300 dark:hover:bg-gray-600 transition-all duration-300 inline-block text-center text-sm">
                                <i class="icofont-email"></i> Email University
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Tabs functionality
        const tabButtons = document.querySelectorAll('[role="tab"]');
        const tabPanels = document.querySelectorAll('[role="tabpanel"]');

        tabButtons.forEach(button => {
            button.addEventListener('click', () => {
                // Remove active states
                tabButtons.forEach(btn => {
                    btn.classList.remove('border-primaryColor', 'text-primaryColor', 'active');
                    btn.classList.add('border-transparent');
                    btn.setAttribute('aria-selected', 'false');
                });
                tabPanels.forEach(panel => panel.classList.add('hidden'));

                // Add active state to clicked tab
                button.classList.add('border-primaryColor', 'text-primaryColor', 'active');
                button.classList.remove('border-transparent');
                button.setAttribute('aria-selected', 'true');

                // Show corresponding panel
                const targetId = button.getAttribute('data-tabs-target');
                document.querySelector(targetId).classList.remove('hidden');
            });
        });

        // Cancel application function
        function cancelApplication(id) {
            Swal.fire({
                title: 'Cancel Application?',
                text: 'Are you sure you want to cancel this application? This action cannot be undone.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, cancel it!',
                cancelButtonText: 'No, keep it'
            }).then((result) => {
                if (result.isConfirmed) {
                    // AJAX request to cancel
                    fetch('/Applications/' + id + '/Cancel', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        }
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Cancelled!',
                                text: data.message,
                                confirmButtonColor: '#3b82f6'
                            }).then(() => {
                                window.location.reload();
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error!',
                                text: data.message,
                                confirmButtonColor: '#3b82f6'
                            });
                        }
                    });
                }
            });
        }

        // Show success message if present
        @if (TempData["Success"] != null)
        {
            <text>
            Swal.fire({
                icon: 'success',
                title: 'Success!',
                text: '@TempData["Success"]',
                confirmButtonColor: '#3b82f6'
            });
            </text>
        }
    </script>
}

<form method="post" style="display:none;">
    @Html.AntiForgeryToken()
</form>
