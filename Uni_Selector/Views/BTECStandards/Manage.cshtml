@model Uni_Selector.ViewModels.BTECAuthority.ManageBTECStandardsViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage BTEC Standards";
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">⚙️ Manage BTEC Standards</h4>
        <p class="text-muted mb-0">Update BTEC standards and notify universities</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <iconify-icon icon="solar:arrow-left-outline" width="20"></iconify-icon>
            Back to Standards
        </a>
    </div>
</div>

<form asp-action="Update" method="post" id="updateStandardsForm">
    @Html.AntiForgeryToken()

    <!-- Update Information -->
    <div class="card mb-4">
        <div class="card-header bg-primary-focus">
            <h5 class="card-title mb-0 text-primary-main">
                <iconify-icon icon="solar:info-circle-outline" width="24"></iconify-icon>
                Update Information (Required)
            </h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="UpdateDescription" class="form-label">Update Description *</label>
                    <textarea asp-for="UpdateDescription" class="form-control" rows="4" placeholder="Describe the changes being made to BTEC standards..." required></textarea>
                    <span asp-validation-for="UpdateDescription" class="text-danger"></span>
                    <small class="text-muted">This description will be sent to all universities</small>
                </div>

                <div class="col-md-6">
                    <label asp-for="EffectiveDate" class="form-label">Effective Date *</label>
                    <input asp-for="EffectiveDate" type="date" class="form-control" required />
                    <span asp-validation-for="EffectiveDate" class="text-danger"></span>
                    <small class="text-muted">Date when changes take effect</small>

                    <div class="mt-3">
                        <label asp-for="NotificationMessage" class="form-label">Custom Notification Message (Optional)</label>
                        <textarea asp-for="NotificationMessage" class="form-control" rows="3" placeholder="Additional message for universities..."></textarea>
                        <span asp-validation-for="NotificationMessage" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Level Standards -->
    <div class="card mb-4">
        <div class="card-header bg-info-focus">
            <h5 class="card-title mb-0 text-info-main">
                <iconify-icon icon="solar:diploma-outline" width="24"></iconify-icon>
                Level Standards (Optional Updates)
            </h5>
        </div>
        <div class="card-body">
            <div class="accordion" id="levelStandardsAccordion">
                @for (int i = 0; i < Model.LevelStandards.Count; i++)
                {
                    var level = Model.LevelStandards[i];
                    var levelNumber = (int)level.Level;

                    <div class="accordion-item">
                        <h2 class="accordion-header" id="heading@(levelNumber)">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse@(levelNumber)">
                                <strong>@level.Level</strong>
                                <span class="ms-3 text-muted small">
                                    GPA: @level.MinimumGPA% | Credits: @level.MinimumCreditHours | Duration: @level.RecommendedDuration months
                                </span>
                            </button>
                        </h2>
                        <div id="collapse@(levelNumber)" class="accordion-collapse collapse" data-bs-parent="#levelStandardsAccordion">
                            <div class="accordion-body">
                                <input type="hidden" asp-for="LevelStandards[i].Level" />

                                <div class="row g-3">
                                    <div class="col-md-3">
                                        <label asp-for="LevelStandards[i].MinimumGPA" class="form-label">Minimum GPA (%)</label>
                                        <input asp-for="LevelStandards[i].MinimumGPA" type="number" step="0.01" class="form-control" />
                                        <span asp-validation-for="LevelStandards[i].MinimumGPA" class="text-danger"></span>
                                    </div>

                                    <div class="col-md-3">
                                        <label asp-for="LevelStandards[i].MinimumCreditHours" class="form-label">Credit Hours</label>
                                        <input asp-for="LevelStandards[i].MinimumCreditHours" type="number" class="form-control" />
                                        <span asp-validation-for="LevelStandards[i].MinimumCreditHours" class="text-danger"></span>
                                    </div>

                                    <div class="col-md-3">
                                        <label asp-for="LevelStandards[i].RecommendedDuration" class="form-label">Duration (months)</label>
                                        <input asp-for="LevelStandards[i].RecommendedDuration" type="number" class="form-control" />
                                        <span asp-validation-for="LevelStandards[i].RecommendedDuration" class="text-danger"></span>
                                    </div>

                                    <div class="col-md-3">
                                        <label class="form-label">Previous Level Required</label>
                                        <div class="form-check form-switch">
                                            <input asp-for="LevelStandards[i].RequiresPreviousLevel" type="checkbox" class="form-check-input" role="switch" />
                                            <label asp-for="LevelStandards[i].RequiresPreviousLevel" class="form-check-label">Yes</label>
                                        </div>
                                    </div>

                                    <div class="col-12">
                                        <label asp-for="LevelStandards[i].Description" class="form-label">Description</label>
                                        <textarea asp-for="LevelStandards[i].Description" class="form-control" rows="2"></textarea>
                                        <span asp-validation-for="LevelStandards[i].Description" class="text-danger"></span>
                                    </div>

                                    <div class="col-12">
                                        <label asp-for="LevelStandards[i].KeyLearningOutcomes" class="form-label">Key Learning Outcomes</label>
                                        <textarea asp-for="LevelStandards[i].KeyLearningOutcomes" class="form-control" rows="3" placeholder="List key learning outcomes for this level..."></textarea>
                                        <span asp-validation-for="LevelStandards[i].KeyLearningOutcomes" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- General Requirements -->
    <div class="card mb-4">
        <div class="card-header bg-success-focus">
            <h5 class="card-title mb-0 text-success-main">
                <iconify-icon icon="solar:document-text-outline" width="24"></iconify-icon>
                General Requirements (Optional Updates)
            </h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label asp-for="MinimumGPA" class="form-label">Minimum GPA (%)</label>
                    <input asp-for="MinimumGPA" type="number" step="0.01" class="form-control" placeholder="Current: 60" />
                    <span asp-validation-for="MinimumGPA" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="MinimumCreditHours" class="form-label">Minimum Credit Hours</label>
                    <input asp-for="MinimumCreditHours" type="number" class="form-control" placeholder="Current: 60" />
                    <span asp-validation-for="MinimumCreditHours" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="MaximumDuration" class="form-label">Maximum Duration (years)</label>
                    <input asp-for="MaximumDuration" type="number" class="form-control" placeholder="Current: 5" />
                    <span asp-validation-for="MaximumDuration" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <div class="mt-4">
                        <div class="form-check">
                            <input asp-for="RequireEnglishProficiency" type="checkbox" class="form-check-input" />
                            <label asp-for="RequireEnglishProficiency" class="form-check-label">Require English Proficiency</label>
                        </div>
                        <div class="form-check mt-2">
                            <input asp-for="RequireTechnicalBackground" type="checkbox" class="form-check-input" />
                            <label asp-for="RequireTechnicalBackground" class="form-check-label">Require Technical Background</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quality Standards -->
    <div class="card mb-4">
        <div class="card-header bg-warning-focus">
            <h5 class="card-title mb-0 text-warning-main">
                <iconify-icon icon="solar:shield-check-outline" width="24"></iconify-icon>
                Quality Standards (Optional Updates)
            </h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="form-check form-switch mb-3">
                        <input asp-for="RequireQualifiedInstructors" type="checkbox" class="form-check-input" role="switch" />
                        <label asp-for="RequireQualifiedInstructors" class="form-check-label">
                            <strong>Require Qualified Instructors</strong>
                            <br /><small class="text-muted">All instructors must have relevant qualifications and experience</small>
                        </label>
                    </div>

                    <div class="form-check form-switch mb-3">
                        <input asp-for="RequireModernFacilities" type="checkbox" class="form-check-input" role="switch" />
                        <label asp-for="RequireModernFacilities" class="form-check-label">
                            <strong>Require Modern Facilities</strong>
                            <br /><small class="text-muted">Programs must have access to modern equipment and facilities</small>
                        </label>
                    </div>

                    <div class="form-check form-switch">
                        <input asp-for="RequireIndustryPartnership" type="checkbox" class="form-check-input" role="switch" />
                        <label asp-for="RequireIndustryPartnership" class="form-check-label">
                            <strong>Require Industry Partnership</strong>
                            <br /><small class="text-muted">Programs must have partnerships with industry</small>
                        </label>
                    </div>
                </div>

                <div class="col-md-6">
                    <label asp-for="MinimumPassRate" class="form-label">Minimum Pass Rate (%)</label>
                    <input asp-for="MinimumPassRate" type="number" step="0.01" class="form-control" placeholder="Current: 75" />
                    <span asp-validation-for="MinimumPassRate" class="text-danger"></span>
                    <small class="text-muted d-block mt-1">Percentage of students that must pass each year</small>

                    <div class="form-check form-switch mt-4">
                        <input asp-for="RequireAnnualReview" type="checkbox" class="form-check-input" role="switch" />
                        <label asp-for="RequireAnnualReview" class="form-check-label">
                            <strong>Require Annual Review</strong>
                            <br /><small class="text-muted">Programs must conduct annual quality reviews</small>
                        </label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Accreditation Criteria -->
    <div class="card mb-4">
        <div class="card-header bg-danger-focus">
            <h5 class="card-title mb-0 text-danger-main">
                <iconify-icon icon="solar:star-outline" width="24"></iconify-icon>
                Accreditation Criteria (Optional Updates)
            </h5>
        </div>
        <div class="card-body">
            <p class="text-muted mb-3">Update the weights for accreditation criteria. Total must equal 100%.</p>

            @for (int i = 0; i < Model.AccreditationCriteria.Count; i++)
            {
                <input type="hidden" asp-for="AccreditationCriteria[i].Name" />
                <input type="hidden" asp-for="AccreditationCriteria[i].Description" />

                <div class="row align-items-center mb-3">
                    <div class="col-md-4">
                        <strong>@Model.AccreditationCriteria[i].Name</strong>
                        <br /><small class="text-muted">@Model.AccreditationCriteria[i].Description</small>
                    </div>
                    <div class="col-md-8">
                        <div class="input-group">
                            <input asp-for="AccreditationCriteria[i].Weight" type="number" step="0.01" class="form-control" />
                            <span class="input-group-text">%</span>
                        </div>
                        <span asp-validation-for="AccreditationCriteria[i].Weight" class="text-danger"></span>
                    </div>
                </div>
            }

            <div class="alert alert-warning mt-3 mb-0">
                <iconify-icon icon="solar:info-circle-outline" width="20"></iconify-icon>
                <strong>Note:</strong> Total weight of all criteria must equal 100%
            </div>
        </div>
    </div>

    <!-- Notification Settings -->
    <div class="card mb-4 border-primary">
        <div class="card-header bg-primary">
            <h5 class="card-title mb-0 text-white">
                <iconify-icon icon="solar:bell-outline" width="24"></iconify-icon>
                Notification Settings
            </h5>
        </div>
        <div class="card-body">
            <div class="form-check form-switch mb-3">
                <input asp-for="NotifyUniversities" type="checkbox" class="form-check-input" role="switch" checked />
                <label asp-for="NotifyUniversities" class="form-check-label">
                    <strong>Send Notifications to All Universities</strong>
                    <br /><small class="text-muted">All University Representatives will receive in-app notifications and emails about this update</small>
                </label>
            </div>

            <div class="alert alert-info mb-0">
                <iconify-icon icon="solar:info-circle-outline" width="20"></iconify-icon>
                <strong>What happens when you submit:</strong>
                <ul class="mb-0 mt-2">
                    <li>Standards will be updated immediately</li>
                    <li>
                        If notifications are enabled, all University Representatives will receive:
                        <ul>
                            <li>In-app notification through the system</li>
                            <li>Email notification with update details</li>
                        </ul>
                    </li>
                    <li>Update will be logged in the system</li>
                    <li>Changes take effect on the specified effective date</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Submit Buttons -->
    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <iconify-icon icon="solar:close-circle-outline" width="20"></iconify-icon>
                    Cancel
                </a>
                <button type="submit" class="btn btn-primary" id="submitBtn">
                    <iconify-icon icon="solar:check-circle-outline" width="20"></iconify-icon>
                    Update Standards & Notify Universities
                </button>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.getElementById('updateStandardsForm').addEventListener('submit', function(e) {
            e.preventDefault();

            const notifyUniversities = document.querySelector('input[name="NotifyUniversities"]').checked;

            Swal.fire({
                title: 'Update BTEC Standards?',
                html: notifyUniversities
                    ? '<p>This will update BTEC standards and send notifications to <strong>all University Representatives</strong>.</p><p class="text-muted">They will receive both in-app notifications and email alerts.</p>'
                    : '<p>This will update BTEC standards.</p><p class="text-warning">No notifications will be sent to universities.</p>',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, Update Standards',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    // Show loading
                    Swal.fire({
                        title: 'Updating Standards...',
                        html: notifyUniversities
                            ? 'Updating standards and sending notifications to universities...'
                            : 'Updating standards...',
                        allowOutsideClick: false,
                        allowEscapeKey: false,
                        didOpen: () => {
                            Swal.showLoading();
                        }
                    });

                    // Submit the form
                    e.target.submit();
                }
            });
        });

        // Validate total weight for accreditation criteria
        function validateTotalWeight() {
            const weights = document.querySelectorAll('input[name^="AccreditationCriteria"][name$="Weight"]');
            let total = 0;
            weights.forEach(input => {
                total += parseFloat(input.value) || 0;
            });

            if (Math.abs(total - 100) > 0.01 && total > 0) {
                return false;
            }
            return true;
        }

        // Add validation on form submit
        document.getElementById('updateStandardsForm').addEventListener('submit', function(e) {
            const weights = document.querySelectorAll('input[name^="AccreditationCriteria"][name$="Weight"]');
            let hasValues = false;
            let total = 0;

            weights.forEach(input => {
                if (input.value) {
                    hasValues = true;
                    total += parseFloat(input.value) || 0;
                }
            });

            if (hasValues && Math.abs(total - 100) > 0.01) {
                e.preventDefault();
                Swal.fire({
                    title: 'Invalid Accreditation Weights',
                    text: `Total weight must equal 100%. Current total: ${total.toFixed(2)}%`,
                    icon: 'error',
                    confirmButtonText: 'OK'
                });
            }
        }, true);
    </script>
}
