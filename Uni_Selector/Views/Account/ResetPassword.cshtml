@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<section>
    <div class="bg-lightGrey10 dark:bg-lightGrey10-dark relative z-0 overflow-y-visible py-50px md:py-20 lg:py-100px 2xl:pb-150px 2xl:pt-40.5">
        <div class="container">
            <div class="text-center">
                <h1 class="text-3xl md:text-size-40 2xl:text-size-55 font-bold text-blackColor dark:text-blackColor-dark mb-7 md:mb-6 pt-3">
                    Reset Password
                </h1>
                <ul class="flex gap-1 justify-center">
                    <li>
                        <a asp-controller="Home" asp-action="Index" class="text-lg text-blackColor2 dark:text-blackColor2-dark">
                            Home <i class="icofont-simple-right"></i>
                        </a>
                    </li>
                    <li>
                        <span class="text-lg text-blackColor2 dark:text-blackColor2-dark">Reset Password</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</section>

<section class="relative">
    <div class="container py-100px">
        <div class="md:w-1/2 mx-auto">
            <!-- Success/Error Messages -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="mb-6 bg-green-50 dark:bg-green-900 dark:bg-opacity-20 border-l-4 border-green-500 p-4 rounded-lg shadow-lg" role="alert" data-aos="fade-down">
                    <div class="flex items-center">
                        <div class="flex-shrink-0">
                            <i class="icofont-check-circled text-3xl text-green-500"></i>
                        </div>
                        <div class="ml-3">
                            <h3 class="text-sm font-bold text-green-800 dark:text-green-200 mb-1">Success!</h3>
                            <p class="text-sm text-green-700 dark:text-green-300">
                                @TempData["SuccessMessage"]
                            </p>
                        </div>
                        <div class="ml-auto pl-3">
                            <button type="button" class="inline-flex text-green-400 hover:text-green-600" onclick="this.parentElement.parentElement.parentElement.remove()">
                                <i class="icofont-close text-xl"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="mb-6 bg-red-50 dark:bg-red-900 dark:bg-opacity-20 border-l-4 border-red-500 p-4 rounded-lg shadow-lg" role="alert" data-aos="fade-down">
                    <div class="flex items-center">
                        <div class="flex-shrink-0">
                            <i class="icofont-warning text-3xl text-red-500"></i>
                        </div>
                        <div class="ml-3">
                            <h3 class="text-sm font-bold text-red-800 dark:text-red-200 mb-1">Error!</h3>
                            <p class="text-sm text-red-700 dark:text-red-300">
                                @TempData["ErrorMessage"]
                            </p>
                        </div>
                        <div class="ml-auto pl-3">
                            <button type="button" class="inline-flex text-red-400 hover:text-red-600" onclick="this.parentElement.parentElement.parentElement.remove()">
                                <i class="icofont-close text-xl"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }

            @if (TempData["WarningMessage"] != null)
            {
                <div class="mb-6 bg-yellow-50 dark:bg-yellow-900 dark:bg-opacity-20 border-l-4 border-yellow-500 p-4 rounded-lg shadow-lg" role="alert" data-aos="fade-down">
                    <div class="flex items-center">
                        <div class="flex-shrink-0">
                            <i class="icofont-warning-alt text-3xl text-yellow-500"></i>
                        </div>
                        <div class="ml-3">
                            <h3 class="text-sm font-bold text-yellow-800 dark:text-yellow-200 mb-1">Warning!</h3>
                            <p class="text-sm text-yellow-700 dark:text-yellow-300">
                                @TempData["WarningMessage"]
                            </p>
                        </div>
                        <div class="ml-auto pl-3">
                            <button type="button" class="inline-flex text-yellow-400 hover:text-yellow-600" onclick="this.parentElement.parentElement.parentElement.remove()">
                                <i class="icofont-close text-xl"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }

            <div class="shadow-container bg-whiteColor dark:bg-whiteColor-dark p-10 md:p-50px rounded-5px" data-aos="fade-up">
                <div class="text-center mb-8">
                    <div class="w-20 h-20 bg-green-500 rounded-full flex items-center justify-center mx-auto mb-4 shadow-lg animate-pulse">
                        <i class="icofont-check text-4xl text-white"></i>
                    </div>
                    <h3 class="text-size-32 font-bold text-blackColor dark:text-blackColor-dark mb-2">
                        Create New Password
                    </h3>
                    <p class="text-contentColor dark:text-contentColor-dark">
                        Your new password must be different from previously used passwords.
                    </p>
                </div>

                <form asp-action="ResetPassword" method="post">
                    <input asp-for="Token" type="hidden" />
                    <input asp-for="Email" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="text-red-600 mb-4 p-4 bg-red-50 dark:bg-red-900 dark:bg-opacity-20 rounded-lg"></div>

                    <div class="mb-6">
                        <label asp-for="NewPassword" class="text-contentColor dark:text-contentColor-dark mb-10px block font-medium">
                            <i class="icofont-lock mr-2 text-primaryColor"></i> New Password
                        </label>
                        <input asp-for="NewPassword" type="password" placeholder="••••••••" class="w-full h-52px leading-52px pl-5 bg-transparent text-sm focus:outline-none text-contentColor dark:text-contentColor-dark border border-borderColor dark:border-borderColor-dark placeholder:text-placeholder placeholder:opacity-80 font-medium rounded focus:border-primaryColor transition-all duration-300">
                        <span asp-validation-for="NewPassword" class="text-red-600 text-sm mt-1 block"></span>
                        <div class="mt-2 bg-blue-50 dark:bg-blue-900 dark:bg-opacity-20 p-3 rounded-lg">
                            <p class="text-xs text-blue-700 dark:text-blue-300 flex items-center">
                                <i class="icofont-info-circle mr-2"></i>
                                Min 8 characters with uppercase, lowercase & number
                            </p>
                        </div>
                    </div>

                    <div class="mb-6">
                        <label asp-for="ConfirmPassword" class="text-contentColor dark:text-contentColor-dark mb-10px block font-medium">
                            <i class="icofont-lock mr-2 text-primaryColor"></i> Confirm Password
                        </label>
                        <input asp-for="ConfirmPassword" type="password" placeholder="••••••••" class="w-full h-52px leading-52px pl-5 bg-transparent text-sm focus:outline-none text-contentColor dark:text-contentColor-dark border border-borderColor dark:border-borderColor-dark placeholder:text-placeholder placeholder:opacity-80 font-medium rounded focus:border-primaryColor transition-all duration-300">
                        <span asp-validation-for="ConfirmPassword" class="text-red-600 text-sm mt-1 block"></span>
                    </div>

                    <button type="submit" class="text-size-15 text-whiteColor bg-primaryColor px-25px py-10px w-full border border-primaryColor hover:text-primaryColor hover:bg-whiteColor inline-block rounded group dark:hover:text-whiteColor dark:hover:bg-whiteColor-dark transition-all duration-300 shadow-lg hover:shadow-xl">
                        <i class="icofont-key mr-2"></i> Reset Password
                    </button>

                    <div class="mt-6 text-center">
                        <p class="text-sm text-contentColor dark:text-contentColor-dark">
                            Remember your password?
                            <a asp-action="Login" class="text-primaryColor hover:underline font-semibold">
                                Sign in here
                            </a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Animated Icons -->
    <div>
        <img loading="lazy" class="absolute right-[14%] top-[30%] animate-move-var" src="~/assets/images/education/hero_shape2.png" alt="Shape">
        <img loading="lazy" class="absolute left-[5%] top-1/2 animate-move-hor" src="~/assets/images/education/hero_shape3.png" alt="Shape">
        <img loading="lazy" class="absolute left-1/2 bottom-[60px] animate-spin-slow" src="~/assets/images/education/hero_shape4.png" alt="Shape">
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Auto-hide alerts after 5 seconds
        setTimeout(function() {
            const alerts = document.querySelectorAll('[role="alert"]');
            alerts.forEach(alert => {
                alert.style.transition = 'opacity 0.5s ease-out';
                alert.style.opacity = '0';
                setTimeout(() => alert.remove(), 500);
            });
        }, 5000);

        // Password strength indicator
        const passwordInput = document.querySelector('input[name="NewPassword"]');
        if (passwordInput) {
            passwordInput.addEventListener('input', function() {
                const value = this.value;
                const hasUpper = /[A-Z]/.test(value);
                const hasLower = /[a-z]/.test(value);
                const hasNumber = /[0-9]/.test(value);
                const isLongEnough = value.length >= 8;

                // You can add visual feedback here
            });
        }
    </script>
}