@model LoginViewModel
@{
    ViewData["Title"] = ViewData["ActiveTab"]?.ToString() ?? "login"; 
    var activeTab = ViewData["ActiveTab"]?.ToString() ?? "login";
}

<!-- Banner Section -->
<section>
    <div class="bg-lightGrey10 dark:bg-lightGrey10-dark relative z-0 overflow-y-visible py-50px md:py-20 lg:py-100px 2xl:pb-150px 2xl:pt-40.5">
        <!-- Animated Icons -->
        <div>
            <img class="absolute left-0 bottom-0 md:left-[14px] lg:left-[50px] lg:bottom-[21px] 2xl:left-[165px] 2xl:bottom-[60px] animate-move-var z-10" src="~/assets/images/herobanner/herobanner__1.png" alt="">
            <img class="absolute left-0 top-0 lg:left-[50px] lg:top-[100px] animate-spin-slow" src="~/assets/images/herobanner/herobanner__2.png" alt="">
            <img class="absolute right-[30px] top-0 md:right-10 lg:right-[575px] 2xl:top-20 animate-move-var2 opacity-50 hidden md:block" src="~/assets/images/herobanner/herobanner__3.png" alt="">
            <img class="absolute right-[30px] top-[212px] md:right-10 md:top-[157px] lg:right-[45px] lg:top-[100px] animate-move-hor" src="~/assets/images/herobanner/herobanner__5.png" alt="">
        </div>

        <div class="container">
            <div class="text-center">
                <h1 class="text-3xl md:text-size-40 2xl:text-size-55 font-bold text-blackColor dark:text-blackColor-dark mb-7 md:mb-6 pt-3">
                    Welcome to Uni Selector
                </h1>
                <ul class="flex gap-1 justify-center">
                    <li>
                        <a asp-controller="Home" asp-action="Index" class="text-lg text-blackColor2 dark:text-blackColor2-dark">
                            Home <i class="icofont-simple-right"></i>
                        </a>
                    </li>
                    <li>
                        <span class="text-lg text-blackColor2 dark:text-blackColor2-dark">@(activeTab == "register" ? "Sign Up" : "Login")</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- Form Section -->
<section class="relative">
    <div class="container py-100px">
        <div class="tab md:w-2/3 mx-auto">
            <!-- Success/Error Messages -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="mb-6 bg-green-50 dark:bg-green-900 dark:bg-opacity-20 border-l-4 border-green-500 p-4 rounded-lg shadow-lg animate-fade-in" role="alert" data-aos="fade-down">
                    <div class="flex items-center">
                        <div class="flex-shrink-0">
                            <i class="icofont-check-circled text-3xl text-green-500"></i>
                        </div>
                        <div class="ml-3">
                            <p class="text-sm font-medium text-green-800 dark:text-green-200">
                                @TempData["SuccessMessage"]
                            </p>
                        </div>
                        <div class="ml-auto pl-3">
                            <button type="button" class="inline-flex text-green-400 hover:text-green-600 dark:hover:text-green-300" onclick="this.parentElement.parentElement.parentElement.remove()">
                                <i class="icofont-close text-xl"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="mb-6 bg-red-50 dark:bg-red-900 dark:bg-opacity-20 border-l-4 border-red-500 p-4 rounded-lg shadow-lg animate-fade-in" role="alert" data-aos="fade-down">
                    <div class="flex items-center">
                        <div class="flex-shrink-0">
                            <i class="icofont-warning text-3xl text-red-500"></i>
                        </div>
                        <div class="ml-3">
                            <p class="text-sm font-medium text-red-800 dark:text-red-200">
                                @TempData["ErrorMessage"]
                            </p>
                        </div>
                        <div class="ml-auto pl-3">
                            <button type="button" class="inline-flex text-red-400 hover:text-red-600 dark:hover:text-red-300" onclick="this.parentElement.parentElement.parentElement.remove()">
                                <i class="icofont-close text-xl"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }

            <!-- Tab Controller -->
            <div class="tab-links grid grid-cols-2 gap-11px text-blackColor text-lg lg:text-size-22 font-semibold font-hind mb-43px mt-30px md:mt-0">
                <button data-tab="login" class="tab-button py-9px lg:py-6 hover:text-primaryColor dark:text-whiteColor dark:hover:text-primaryColor bg-white dark:bg-whiteColor-dark dark:hover:bg-whiteColor-dark hover:bg-white relative group/btn shadow-bottom hover:shadow-bottom dark:shadow-standard-dark rounded-standard transition-all duration-300 @(activeTab == "login" ? "active" : "")">
                    <span class="tab-indicator absolute h-1 bg-primaryColor top-0 left-0 transition-all duration-300 @(activeTab == "login" ? "w-full" : "w-0")"></span>
                    Login
                </button>
                <button data-tab="register" class="tab-button py-9px lg:py-6 hover:text-primaryColor dark:hover:text-primaryColor dark:text-whiteColor bg-lightGrey7 dark:bg-lightGrey7-dark hover:bg-white dark:hover:bg-whiteColor-dark relative group/btn hover:shadow-bottom dark:shadow-standard-dark rounded-standard transition-all duration-300 @(activeTab == "register" ? "active" : "")">
                    <span class="tab-indicator absolute h-1 bg-primaryColor top-0 left-0 transition-all duration-300 @(activeTab == "register" ? "w-full" : "w-0")"></span>
                    Sign Up
                </button>
            </div>

            <!-- Tab Contents -->
            <div class="shadow-container bg-whiteColor dark:bg-whiteColor-dark pt-10px px-5 pb-10 md:p-50px md:pt-30px rounded-5px">
                <div class="tab-contents">
                    <!-- Login Form -->
                    <div id="login-form" class="tab-content @(activeTab == "login" ? "block opacity-100" : "hidden opacity-0") transition-opacity duration-300 ease-linear">
                        <!-- Heading -->
                        <div class="text-center">
                            <h3 class="text-size-32 font-bold text-blackColor dark:text-blackColor-dark mb-2 leading-normal">
                                Login
                            </h3>
                            <p class="text-contentColor dark:text-contentColor-dark mb-15px">
                                Don't have an account yet?
                                <a href="javascript:void(0)" data-switch-tab="register" class="hover:text-primaryColor relative after:absolute after:left-0 after:bottom-0.5 after:w-0 after:h-0.5 after:bg-primaryColor after:transition-all after:duration-300 hover:after:w-full">
                                    Sign up for free
                                </a>
                            </p>
                        </div>

                        <form asp-action="Login" method="post" class="pt-25px" data-aos="fade-up">
                            <div asp-validation-summary="ModelOnly" class="text-red-600 mb-4 p-4 bg-red-50 dark:bg-red-900 dark:bg-opacity-20 rounded-lg"></div>

                            <div class="mb-25px">
                                <label asp-for="Email" class="text-contentColor dark:text-contentColor-dark mb-10px block">Email Address</label>
                                <input asp-for="Email" type="email" placeholder="your@email.com" class="w-full h-52px leading-52px pl-5 bg-transparent text-sm focus:outline-none text-contentColor dark:text-contentColor-dark border border-borderColor dark:border-borderColor-dark placeholder:text-placeholder placeholder:opacity-80 font-medium rounded focus:border-primaryColor">
                                <span asp-validation-for="Email" class="text-red-600 text-sm mt-1 block"></span>
                            </div>

                            <div class="mb-25px">
                                <label asp-for="Password" class="text-contentColor dark:text-contentColor-dark mb-10px block">Password</label>
                                <input asp-for="Password" type="password" placeholder="••••••••" class="w-full h-52px leading-52px pl-5 bg-transparent text-sm focus:outline-none text-contentColor dark:text-contentColor-dark border border-borderColor dark:border-borderColor-dark placeholder:text-placeholder placeholder:opacity-80 font-medium rounded focus:border-primaryColor">
                                <span asp-validation-for="Password" class="text-red-600 text-sm mt-1 block"></span>
                            </div>

                            <div class="text-contentColor dark:text-contentColor-dark flex items-center justify-between mb-25px">
                                <div class="flex items-center">
                                    <input asp-for="RememberMe" type="checkbox" id="remember" class="w-18px h-18px mr-2 block box-content accent-primaryColor">
                                    <label for="remember">Remember me</label>
                                </div>
                                <div>
                                    <a asp-action="ForgotPassword" class="hover:text-primaryColor relative after:absolute after:left-0 after:bottom-0.5 after:w-0 after:h-0.5 after:bg-primaryColor after:transition-all after:duration-300 hover:after:w-full">
                                        Forgot password?
                                    </a>
                                </div>
                            </div>

                            <div class="text-center">
                                <button type="submit" class="text-size-15 text-whiteColor bg-primaryColor px-25px py-10px w-full border border-primaryColor hover:text-primaryColor hover:bg-whiteColor inline-block rounded group dark:hover:text-whiteColor dark:hover:bg-whiteColor-dark transition-all duration-300">
                                    <i class="icofont-login mr-2"></i> Log In
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- Register Form -->
                    <div id="register-form" class="tab-content @(activeTab == "register" ? "block opacity-100" : "hidden opacity-0") transition-opacity duration-300 ease-linear">
                        <!-- Heading -->
                        <div class="text-center">
                            <h3 class="text-size-32 font-bold text-blackColor dark:text-blackColor-dark mb-2 leading-normal">
                                Sign Up
                            </h3>
                            <p class="text-contentColor dark:text-contentColor-dark mb-15px">
                                Already have an account?
                                <a href="javascript:void(0)" data-switch-tab="login" class="hover:text-primaryColor relative after:absolute after:left-0 after:bottom-0.5 after:w-0 after:h-0.5 after:bg-primaryColor after:transition-all after:duration-300 hover:after:w-full">
                                    Log In
                                </a>
                            </p>
                        </div>

                        <form asp-action="Register" method="post" class="pt-25px" data-aos="fade-up">
                            <div asp-validation-summary="ModelOnly" class="text-red-600 mb-4 p-4 bg-red-50 dark:bg-red-900 dark:bg-opacity-20 rounded-lg"></div>

                            <div class="mb-25px">
                                <label class="text-contentColor dark:text-contentColor-dark mb-10px block">Full Name</label>
                                <input type="text" name="FullName" placeholder="John Doe" class="w-full h-52px leading-52px pl-5 bg-transparent text-sm focus:outline-none text-contentColor dark:text-contentColor-dark border border-borderColor dark:border-borderColor-dark placeholder:text-placeholder placeholder:opacity-80 font-medium rounded focus:border-primaryColor" required>
                            </div>

                            <div class="grid grid-cols-1 lg:grid-cols-2 lg:gap-x-30px gap-y-25px mb-25px">
                                <div>
                                    <label class="text-contentColor dark:text-contentColor-dark mb-10px block">Email</label>
                                    <input type="email" name="Email" placeholder="your@email.com" class="w-full h-52px leading-52px pl-5 bg-transparent text-sm focus:outline-none text-contentColor dark:text-contentColor-dark border border-borderColor dark:border-borderColor-dark placeholder:text-placeholder placeholder:opacity-80 font-medium rounded focus:border-primaryColor" required>
                                </div>
                                <div>
                                    <label class="text-contentColor dark:text-contentColor-dark mb-10px block">Phone Number</label>
                                    <input type="tel" name="PhoneNumber" placeholder="+962 7X XXX XXXX" class="w-full h-52px leading-52px pl-5 bg-transparent text-sm focus:outline-none text-contentColor dark:text-contentColor-dark border border-borderColor dark:border-borderColor-dark placeholder:text-placeholder placeholder:opacity-80 font-medium rounded focus:border-primaryColor" required>
                                </div>
                            </div>

                            <div class="grid grid-cols-1 lg:grid-cols-2 lg:gap-x-30px gap-y-25px mb-25px">
                                <div>
                                    <label class="text-contentColor dark:text-contentColor-dark mb-10px block">Password</label>
                                    <input type="password" name="Password" placeholder="••••••••" class="w-full h-52px leading-52px pl-5 bg-transparent text-sm focus:outline-none text-contentColor dark:text-contentColor-dark border border-borderColor dark:border-borderColor-dark placeholder:text-placeholder placeholder:opacity-80 font-medium rounded focus:border-primaryColor" required>
                                    <small class="text-xs text-gray-500 dark:text-gray-400">Min 8 characters, uppercase, lowercase & number</small>
                                </div>
                                <div>
                                    <label class="text-contentColor dark:text-contentColor-dark mb-10px block">Confirm Password</label>
                                    <input type="password" name="ConfirmPassword" placeholder="••••••••" class="w-full h-52px leading-52px pl-5 bg-transparent text-sm focus:outline-none text-contentColor dark:text-contentColor-dark border border-borderColor dark:border-borderColor-dark placeholder:text-placeholder placeholder:opacity-80 font-medium rounded focus:border-primaryColor" required>
                                </div>
                            </div>

                            <div class="text-contentColor dark:text-contentColor-dark flex items-center mb-4">
                                <input type="checkbox" id="accept-pp" class="w-18px h-18px mr-2 block box-content accent-primaryColor" required>
                                <label for="accept-pp">I accept the <a href="#" class="text-primaryColor hover:underline">Terms and Privacy Policy</a></label>
                            </div>

                            <div class="text-center">
                                <button type="submit" class="text-size-15 text-whiteColor bg-primaryColor px-25px py-10px w-full border border-primaryColor hover:text-primaryColor hover:bg-whiteColor inline-block rounded group dark:hover:text-whiteColor dark:hover:bg-whiteColor-dark transition-all duration-300">
                                    <i class="icofont-user-alt-3 mr-2"></i> Create Account
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Animated Icons -->
    <div>
        <img loading="lazy" class="absolute right-[14%] top-[30%] animate-move-var" src="~/assets/images/education/hero_shape2.png" alt="Shape">
        <img loading="lazy" class="absolute left-[5%] top-1/2 animate-move-hor" src="~/assets/images/education/hero_shape3.png" alt="Shape">
        <img loading="lazy" class="absolute left-1/2 bottom-[60px] animate-spin-slow" src="~/assets/images/education/hero_shape4.png" alt="Shape">
        <img loading="lazy" class="absolute left-1/2 top-10 animate-spin-slow" src="~/assets/images/education/hero_shape5.png" alt="Shape">
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Tab switching functionality
        document.addEventListener('DOMContentLoaded', function() {
            const tabButtons = document.querySelectorAll('.tab-button');
            const tabContents = document.querySelectorAll('.tab-content');
            const switchTabLinks = document.querySelectorAll('[data-switch-tab]');

            function switchTab(targetTab) {
                // Update buttons
                tabButtons.forEach(btn => {
                    const isActive = btn.dataset.tab === targetTab;
                    const indicator = btn.querySelector('.tab-indicator');

                    if (isActive) {
                        btn.classList.add('active', 'bg-white', 'shadow-bottom');
                        btn.classList.remove('bg-lightGrey7', 'dark:bg-lightGrey7-dark');
                        indicator.classList.add('w-full');
                        indicator.classList.remove('w-0');
                    } else {
                        btn.classList.remove('active', 'bg-white', 'shadow-bottom');
                        btn.classList.add('bg-lightGrey7', 'dark:bg-lightGrey7-dark');
                        indicator.classList.remove('w-full');
                        indicator.classList.add('w-0');
                    }
                });

                // Update content
                tabContents.forEach(content => {
                    if (content.id === `${targetTab}-form`) {
                        content.classList.remove('hidden', 'opacity-0');
                        content.classList.add('block', 'opacity-100');
                    } else {
                        content.classList.add('hidden', 'opacity-0');
                        content.classList.remove('block', 'opacity-100');
                    }
                });

                // Update URL without page reload
                const url = new URL(window.location);
                url.searchParams.set('tab', targetTab);
                window.history.pushState({}, '', url);
            }

            // Tab button clicks
            tabButtons.forEach(button => {
                button.addEventListener('click', function(e) {
                    e.preventDefault();
                    switchTab(this.dataset.tab);
                });
            });

            // In-page "switch to" links
            switchTabLinks.forEach(link => {
                link.addEventListener('click', function(e) {
                    e.preventDefault();
                    switchTab(this.dataset.switchTab);
                });
            });
        });

        // Auto-hide alerts after 5 seconds
        setTimeout(function() {
            const alerts = document.querySelectorAll('[role="alert"]');
            alerts.forEach(alert => {
                alert.style.transition = 'opacity 0.5s ease-out';
                alert.style.opacity = '0';
                setTimeout(() => alert.remove(), 500);
            });
        }, 5000);
    </script>
}