@using Uni_Selector.Models.Enums
@model Uni_Selector.ViewModels.ProgramManagement.CreateProgramViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Add New Program";
    var programs = ViewBag.AvailablePrograms as List<Uni_Selector.Models.ProgramEntity>;
}

<div class="dashboard-main-body">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-24">
        <h6 class="fw-semibold mb-0">Add New Program</h6>
        <ul class="d-flex align-items-center gap-2">
            <li class="fw-medium">
                <a asp-controller="UniversityRep" asp-action="Index" class="d-flex align-items-center gap-1 hover-text-primary">
                    <iconify-icon icon="solar:home-smile-angle-outline" class="icon text-lg"></iconify-icon>
                    Dashboard
                </a>
            </li>
            <li>-</li>
            <li class="fw-medium">
                <a asp-action="Index">Programs</a>
            </li>
            <li>-</li>
            <li class="fw-medium">Add New</li>
        </ul>
    </div>

    <div class="card h-100 p-0 radius-12">
        <div class="card-body p-24">
            <div class="row justify-content-center">
                <div class="col-xxl-8 col-xl-10 col-lg-10">
                    <div class="card border">
                        <div class="card-body">
                            <form asp-action="Create" method="post" id="createProgramForm">
                                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                                <div class="mb-20">
                                    <label asp-for="ProgramId" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                        Select Program <span class="text-danger-600">*</span>
                                    </label>
                                    <select asp-for="ProgramId" class="form-control radius-8 form-select" id="programSelect">
                                        <option value="">-- Select Program --</option>
                                        @if (programs != null)
                                        {
                                            @foreach (var prog in programs)
                                            {
                                                <option value="@prog.Id">
                                                    @prog.NameEnglish (@prog.NameArabic) - @prog.Degree - @prog.TotalCreditHours Hours
                                                </option>
                                            }
                                        }
                                    </select>
                                    <span asp-validation-for="ProgramId" class="text-danger"></span>
                                </div>

                                <div class="mb-20">
                                    <label asp-for="StudySystem" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                        Study System <span class="text-danger-600">*</span>
                                    </label>
                                    <select asp-for="StudySystem" class="form-control radius-8 form-select" asp-items="Html.GetEnumSelectList<StudySystem>()">
                                        <option value="">-- Select Study System --</option>
                                    </select>
                                    <span asp-validation-for="StudySystem" class="text-danger"></span>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-20">
                                        <label asp-for="DurationInYears" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                            Duration (Years) <span class="text-danger-600">*</span>
                                        </label>
                                        <input asp-for="DurationInYears" type="number" class="form-control radius-8" min="1" max="10" placeholder="e.g., 4">
                                        <span asp-validation-for="DurationInYears" class="text-danger"></span>
                                    </div>

                                    <div class="col-md-6 mb-20">
                                        <label asp-for="SemesterStartDate" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                            Semester Start Date <span class="text-danger-600">*</span>
                                        </label>
                                        <input asp-for="SemesterStartDate" type="date" class="form-control radius-8">
                                        <span asp-validation-for="SemesterStartDate" class="text-danger"></span>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-4 mb-20">
                                        <label asp-for="HourPriceBase" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                            Hour Price (JOD) <span class="text-danger-600">*</span>
                                        </label>
                                        <input asp-for="HourPriceBase" type="number" step="0.01" class="form-control radius-8" placeholder="e.g., 65.00">
                                        <span asp-validation-for="HourPriceBase" class="text-danger"></span>
                                    </div>

                                    <div class="col-md-4 mb-20">
                                        <label asp-for="RegistrationFeeFirstSemester" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                            First Semester Fee (JOD) <span class="text-danger-600">*</span>
                                        </label>
                                        <input asp-for="RegistrationFeeFirstSemester" type="number" step="0.01" class="form-control radius-8" placeholder="e.g., 450.00">
                                        <span asp-validation-for="RegistrationFeeFirstSemester" class="text-danger"></span>
                                    </div>

                                    <div class="col-md-4 mb-20">
                                        <label asp-for="RegistrationFeeRegularSemester" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                            Regular Semester Fee (JOD) <span class="text-danger-600">*</span>
                                        </label>
                                        <input asp-for="RegistrationFeeRegularSemester" type="number" step="0.01" class="form-control radius-8" placeholder="e.g., 450.00">
                                        <span asp-validation-for="RegistrationFeeRegularSemester" class="text-danger"></span>
                                    </div>
                                </div>

                                <div class="mb-20">
                                    <label asp-for="Capacity" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                        Student Capacity <span class="text-danger-600">*</span>
                                    </label>
                                    <input asp-for="Capacity" type="number" class="form-control radius-8" min="0" max="10000" placeholder="e.g., 50">
                                    <span asp-validation-for="Capacity" class="text-danger"></span>
                                </div>

                                <div class="d-flex align-items-center justify-content-center gap-3 mt-24">
                                    <a asp-action="Index" class="border border-danger-600 bg-hover-danger-200 text-danger-600 text-md px-56 py-11 radius-8 text-decoration-none">
                                        Cancel
                                    </a>
                                    <button type="button" id="submitBtn" class="btn btn-primary border border-primary-600 text-md px-56 py-12 radius-8">
                                        Save Program
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function() {
            $('#submitBtn').on('click', function(e) {
                e.preventDefault();
                var form = document.getElementById('createProgramForm');

                if (!form.checkValidity()) {
                    form.reportValidity();
                    return;
                }

                Swal.fire({
                    title: 'Create Program?',
                    text: "Are you sure you want to add this program?",
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'Yes, create it!'
                }).then((result) => {
                    if (result.isConfirmed) {
                        Swal.fire({
                            title: 'Creating...',
                            text: 'Please wait',
                            allowOutsideClick: false,
                            showConfirmButton: false,
                            willOpen: () => {
                                Swal.showLoading();
                            }
                        });
                        setTimeout(() => form.submit(), 300);
                    }
                });
            });
        });
    </script>
}
