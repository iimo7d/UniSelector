                                <h3 class="text-2xl font-bold text-blackColor dark:text-whiteColor">Special Circumstances</h3>
                                <p class="text-sm text-contentColor dark:text-contentColor-dark mt-1">Any additional information</p>
                            </div>
                            <span class="step-badge bg-gradient-to-r from-greencolor/10 to-blue/10 text-greencolor">
                                <i class="icofont-check-circled"></i>
                                <span>Final Step</span>
                            </span>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <!-- Has Disability -->
                            <label class="circumstance-card" id="disabilityCard">
                                <div class="flex items-center gap-3">
                                    <input asp-for="HasDisability" type="checkbox" id="hasDisabilityCheck" class="custom-checkbox" />
                                    <div class="flex-1">
                                        <div class="font-semibold text-blackColor dark:text-whiteColor flex items-center gap-2">
                                            <i class="icofont-wheelchair text-primaryColor"></i>
                                            <span>I have a disability</span>
                                        </div>
                                        <p class="text-xs text-contentColor dark:text-contentColor-dark mt-1">Select if applicable</p>
                                    </div>
                                </div>
                            </label>

                            <!-- Disability Type (Conditional) -->
                            <div id="disabilityTypeDiv" class="input-group hidden">
                                <label class="input-label">
                                    <i class="icofont-info-circle text-primaryColor"></i>
                                    <span>Disability Type</span>
                                    <span class="required-star">*</span>
                                </label>
                                <input asp-for="DisabilityType" id="DisabilityType"
                                       class="form-input w-full h-14 px-5 text-sm rounded-xl border-2 border-borderColor dark:border-borderColor-dark bg-transparent text-blackColor dark:text-whiteColor placeholder:text-placeholder focus:outline-none"
                                       placeholder="Specify disability type" />
                                <span asp-validation-for="DisabilityType" class="validation-error"></span>
                            </div>

                            <!-- Is Orphan -->
                            <label class="circumstance-card" id="orphanCard">
                                <div class="flex items-center gap-3">
                                    <input asp-for="IsOrphan" type="checkbox" class="custom-checkbox" />
                                    <div class="flex-1">
                                        <div class="font-semibold text-blackColor dark:text-whiteColor flex items-center gap-2">
                                            <i class="icofont-heart-alt text-primaryColor"></i>
                                            <span>I am an orphan</span>
                                        </div>
                                        <p class="text-xs text-contentColor dark:text-contentColor-dark mt-1">Select if applicable</p>
                                    </div>
                                </div>
                            </label>

                            <!-- Is Employee Child -->
                            <label class="circumstance-card" id="employeeCard">
                                <div class="flex items-center gap-3">
                                    <input asp-for="IsEmployeeChild" type="checkbox" class="custom-checkbox" />
                                    <div class="flex-1">
                                        <div class="font-semibold text-blackColor dark:text-whiteColor flex items-center gap-2">
                                            <i class="icofont-briefcase text-primaryColor"></i>
                                            <span>University employee's child</span>
                                        </div>
                                        <p class="text-xs text-contentColor dark:text-contentColor-dark mt-1">Parent works at university</p>
                                    </div>
                                </div>
                            </label>

                            <!-- Has Family Connection -->
                            <label class="circumstance-card" id="familyCard">
                                <div class="flex items-center gap-3">
                                    <input asp-for="HasFamilyConnection" type="checkbox" id="hasFamilyConnectionCheck" class="custom-checkbox" />
                                    <div class="flex-1">
                                        <div class="font-semibold text-blackColor dark:text-whiteColor flex items-center gap-2">
                                            <i class="icofont-users text-primaryColor"></i>
                                            <span>Family connection to university</span>
                                        </div>
                                        <p class="text-xs text-contentColor dark:text-contentColor-dark mt-1">Family member attended/works</p>
                                    </div>
                                </div>
                            </label>

                            <!-- Family University (Conditional) -->
                            <div id="familyUniversityDiv" class="input-group hidden">
                                <label class="input-label">
                                    <i class="icofont-graduate text-primaryColor"></i>
                                    <span>Select University</span>
                                    <span class="required-star">*</span>
                                </label>
                                <select asp-for="FamilyConnectionUniversityId" id="FamilyConnectionUniversityId"
                                        class="form-input w-full h-14 px-5 text-sm rounded-xl border-2 border-borderColor dark:border-borderColor-dark bg-transparent text-blackColor dark:text-whiteColor focus:outline-none">
                                    <option value="">-- Select University --</option>
                                    @foreach (var u in ViewBag.Universities as List<SelectListItem>)
                                    {
                                        <option value="@u.Value">@u.Text</option>
                                    }
                                </select>
                                <span asp-validation-for="FamilyConnectionUniversityId" class="validation-error"></span>
                            </div>
                        </div>

                        <!-- Final Note -->
                        <div class="mt-8 p-6 rounded-2xl bg-gradient-to-br from-blue/5 to-primaryColor/5 dark:from-blue/10 dark:to-primaryColor/10 border-2 border-blue/20">
                            <div class="flex items-start gap-4">
                                <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue to-primaryColor flex-shrink-0 flex items-center justify-center">
                                    <i class="icofont-info-circle text-2xl text-white"></i>
                                </div>
                                <div class="flex-1">
                                    <h4 class="font-bold text-blackColor dark:text-whiteColor mb-2">Ready to Update!</h4>
                                    <p class="text-sm text-contentColor dark:text-contentColor-dark">
                                        Please review all changes before submitting. Updated information will be used to refine your personalized university recommendations.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Navigation -->
                        <div class="flex justify-between gap-4 mt-10 pt-6 border-t-2 border-borderColor dark:border-borderColor-dark">
                            <button type="button" class="wizard-btn btn-prev px-8 py-4 rounded-xl font-bold text-sm flex items-center gap-2 shadow-lg">
                                <i class="icofont-rounded-left text-xl"></i>
                                <span>Previous</span>
                            </button>
                            <button type="submit" class="wizard-btn btn-submit px-10 py-4 rounded-xl font-bold text-sm flex items-center gap-3 shadow-xl">
                                <i class="icofont-check-circled text-2xl"></i>
                                <span>Update Profile</span>
                            </button>
                        </div>
                    </div>
                </form>

            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // Configuration
            let currentStep = 1;
            const totalSteps = 5;
            const form = document.getElementById("wizardForm");
            const panels = document.querySelectorAll(".step-panel");
            const stepItems = document.querySelectorAll(".step-item");
            const progressFill = document.getElementById("progressFill");

            // Elements
            const pathSelect = document.getElementById("pathSelect");
            const academicTrackDiv = document.getElementById("academicTrackDiv");
            const vocationalBranchDiv = document.getElementById("vocationalBranchDiv");
            const btecDiv = document.getElementById("btecDiv");
            const academicTrackSelect = document.getElementById("AcademicTrack");
            const vocationalBranchSelect = document.getElementById("VocationalBranch");

            const hasDisabilityCheck = document.getElementById("hasDisabilityCheck");
            const disabilityTypeDiv = document.getElementById("disabilityTypeDiv");
            const disabilityTypeInput = document.getElementById("DisabilityType");
            const disabilityCard = document.getElementById("disabilityCard");

            const hasFamilyConnectionCheck = document.getElementById("hasFamilyConnectionCheck");
            const familyUniversityDiv = document.getElementById("familyUniversityDiv");
            const familyUniversitySelect = document.getElementById("FamilyConnectionUniversityId");
            const familyCard = document.getElementById("familyCard");

            // File upload
            const btecFileInput = document.getElementById("btecFileInput");
            const fileUploadWrapper = document.getElementById("fileUploadWrapper");
            const fileUploadPlaceholder = document.getElementById("fileUploadPlaceholder");
            const fileUploadSuccess = document.getElementById("fileUploadSuccess");
            const fileNameDisplay = document.getElementById("fileName");
            const removeFileBtn = document.getElementById("removeFile");

            // Step Navigation Functions
            function updateStepDots(step) {
                stepItems.forEach((item, index) => {
                    const stepNum = index + 1;
                    const dot = item.querySelector('[data-role="dot"]');
                    const icon = item.querySelector('[data-role="icon"]');
                    const number = item.querySelector('[data-role="number"]');
                    const connector = item.querySelector('.step-connector');

                    dot.classList.remove('todo', 'active', 'completed');

                    if (stepNum < step) {
                        dot.classList.add('completed');
                        if (icon) icon.classList.add('hidden');
                        if (number) number.classList.remove('hidden');
                        if (connector) connector.classList.add('completed');
                    } else if (stepNum === step) {
                        dot.classList.add('active');
                        if (icon) icon.classList.remove('hidden');
                        if (number) number.classList.add('hidden');
                    } else {
                        dot.classList.add('todo');
                        if (icon) icon.classList.remove('hidden');
                        if (number) number.classList.add('hidden');
                        if (connector) connector.classList.remove('completed');
                    }
                });
            }

            function updateProgressBar(step) {
                const progress = ((step - 1) / (totalSteps - 1)) * 100;
                progressFill.style.width = progress + '%';
            }

            function showStep(step) {
                panels.forEach(panel => panel.classList.remove('active'));
                const currentPanel = document.querySelector(`.step-panel[data-step="${step}"]`);
                if (currentPanel) currentPanel.classList.add('active');
                updateStepDots(step);
                updateProgressBar(step);
                currentStep = step;
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }

            function validateStep(step) {
                const panel = document.querySelector(`.step-panel[data-step="${step}"]`);
                if (!panel) return true;

                const inputs = panel.querySelectorAll('input:not([type="hidden"]):not([type="checkbox"]):not([type="file"]), select, textarea');
                let isValid = true;
                let firstInvalidField = null;

                inputs.forEach(input => {
                    if (input.offsetParent === null || input.disabled) return;
                    let parent = input.closest('.input-group');
                    if (parent && parent.classList.contains('hidden')) return;

                    if (!input.checkValidity()) {
                        isValid = false;
                        if (!firstInvalidField) firstInvalidField = input;
                        input.classList.add('border-secondaryColor');
                    } else {
                        input.classList.remove('border-secondaryColor');
                    }
                });

                if (!isValid && firstInvalidField) {
                    firstInvalidField.focus();
                    firstInvalidField.reportValidity();
                }

                return isValid;
            }

            // Path-based Conditional Logic
            function updatePathUI() {
                if (!pathSelect) return;
                const value = pathSelect.value;

                if (academicTrackDiv) {
                    academicTrackDiv.classList.add('hidden');
                    if (academicTrackSelect) academicTrackSelect.required = false;
                }
                if (vocationalBranchDiv) {
                    vocationalBranchDiv.classList.add('hidden');
                    if (vocationalBranchSelect) vocationalBranchSelect.required = false;
                }
                if (btecDiv) btecDiv.classList.add('hidden');

                if (value === "1") {
                    if (academicTrackDiv) {
                        academicTrackDiv.classList.remove('hidden');
                        if (academicTrackSelect) academicTrackSelect.required = true;
                    }
                } else if (value === "2") {
                    if (vocationalBranchDiv) {
                        vocationalBranchDiv.classList.remove('hidden');
                        if (vocationalBranchSelect) vocationalBranchSelect.required = true;
                    }
                } else if (value === "3") {
                    if (btecDiv) btecDiv.classList.remove('hidden');
                }
            }

            // Special Circumstances Logic
            function updateDisabilityUI() {
                if (!hasDisabilityCheck || !disabilityTypeDiv) return;
                const isChecked = hasDisabilityCheck.checked;

                if (isChecked) {
                    disabilityTypeDiv.classList.remove('hidden');
                    if (disabilityTypeInput) disabilityTypeInput.required = true;
                    if (disabilityCard) disabilityCard.classList.add('active');
                } else {
                    disabilityTypeDiv.classList.add('hidden');
                    if (disabilityTypeInput) {
                        disabilityTypeInput.required = false;
                        disabilityTypeInput.value = '';
                    }
                    if (disabilityCard) disabilityCard.classList.remove('active');
                }
            }

            function updateFamilyUI() {
                if (!hasFamilyConnectionCheck || !familyUniversityDiv) return;
                const isChecked = hasFamilyConnectionCheck.checked;

                if (isChecked) {
                    familyUniversityDiv.classList.remove('hidden');
                    if (familyUniversitySelect) familyUniversitySelect.required = true;
                    if (familyCard) familyCard.classList.add('active');
                } else {
                    familyUniversityDiv.classList.add('hidden');
                    if (familyUniversitySelect) {
                        familyUniversitySelect.required = false;
                        familyUniversitySelect.value = '';
                    }
                    if (familyCard) familyCard.classList.remove('active');
                }
            }

            // File Upload Logic
            function handleFileSelect(file) {
                if (!file) return;

                if (file.size > 5 * 1024 * 1024) {
                    Swal.fire({
                        icon: 'error',
                        title: 'File Too Large',
                        text: 'Please select a file smaller than 5MB',
                        confirmButtonColor: '#5f2ded',
                        confirmButtonText: 'OK'
                    });
                    btecFileInput.value = '';
                    return;
                }

                const validTypes = ['application/pdf', 'image/jpeg', 'image/jpg', 'image/png'];
                if (!validTypes.includes(file.type)) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Invalid File Type',
                        text: 'Please select a PDF, JPG, or PNG file',
                        confirmButtonColor: '#5f2ded',
                        confirmButtonText: 'OK'
                    });
                    btecFileInput.value = '';
                    return;
                }

                fileUploadPlaceholder.classList.add('hidden');
                fileUploadSuccess.classList.remove('hidden');
                fileUploadWrapper.classList.add('has-file');
                fileNameDisplay.textContent = file.name;
            }

            if (btecFileInput) {
                btecFileInput.addEventListener('change', function(e) {
                    handleFileSelect(e.target.files[0]);
                });
            }

            if (fileUploadWrapper) {
                fileUploadWrapper.addEventListener('click', function() {
                    btecFileInput.click();
                });

                fileUploadWrapper.addEventListener('dragover', function(e) {
                    e.preventDefault();
                    fileUploadWrapper.style.borderColor = '#5f2ded';
                    fileUploadWrapper.style.background = 'rgba(95, 45, 237, 0.05)';
                });

                fileUploadWrapper.addEventListener('dragleave', function(e) {
                    e.preventDefault();
                    fileUploadWrapper.style.borderColor = '';
                    fileUploadWrapper.style.background = '';
                });

                fileUploadWrapper.addEventListener('drop', function(e) {
                    e.preventDefault();
                    fileUploadWrapper.style.borderColor = '';
                    fileUploadWrapper.style.background = '';

                    const file = e.dataTransfer.files[0];
                    if (file) {
                        btecFileInput.files = e.dataTransfer.files;
                        handleFileSelect(file);
                    }
                });
            }

            if (removeFileBtn) {
                removeFileBtn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    btecFileInput.value = '';
                    fileUploadPlaceholder.classList.remove('hidden');
                    fileUploadSuccess.classList.add('hidden');
                    fileUploadWrapper.classList.remove('has-file');
                });
            }

            // Navigation Button Handlers
            document.querySelectorAll('.btn-next').forEach(btn => {
                btn.addEventListener('click', function() {
                    const fromStep = currentStep;
                    if (!validateStep(fromStep)) return;
                    if (fromStep < totalSteps) {
                        showStep(fromStep + 1);
                    }
                });
            });

            document.querySelectorAll('.btn-prev').forEach(btn => {
                btn.addEventListener('click', function() {
                    if (currentStep > 1) {
                        showStep(currentStep - 1);
                    }
                });
            });

            stepItems.forEach((item, index) => {
                item.addEventListener('click', function() {
                    const targetStep = index + 1;

                    if (targetStep <= currentStep) {
                        showStep(targetStep);
                    } else {
                        let canProceed = true;
                        for (let i = currentStep; i < targetStep; i++) {
                            if (!validateStep(i)) {
                                canProceed = false;
                                break;
                            }
                        }
                        if (canProceed) {
                            showStep(targetStep);
                        }
                    }
                });
            });

            // Form Submission
            form.addEventListener('submit', async function(e) {
                e.preventDefault();

                let allValid = true;
                for (let i = 1; i <= totalSteps; i++) {
                    if (!validateStep(i)) {
                        allValid = false;
                        showStep(i);
                        Swal.fire({
                            icon: 'error',
                            title: 'Validation Error',
                            text: `Please complete all required fields in Step ${i}`,
                            confirmButtonColor: '#5f2ded',
                            confirmButtonText: 'OK'
                        });
                        return;
                    }
                }

                if (!allValid) return;

                   const result = await Swal.fire({
            title: 'Update Profile?',
            html: `
                <div class="text-left space-y-2">
                  <p class="text-contentColor">Please review all changes before submitting.</p>
                  <p class="text-sm text-contentColor">Your updated information will be used to refine your university recommendations.</p>
                </div>
              `,
            icon: 'question',
            showConfirmButton: true,
            showCancelButton: true,
            showDenyButton: false,  // ← ADD THIS LINE
            confirmButtonColor: '#10b981',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'Yes, Update!',
            cancelButtonText: 'Review Again',
            heightAuto: false,
            customClass: {
                confirmButton: 'swal2-confirm',
                cancelButton: 'swal2-cancel'
            }
        });
                if (result.isConfirmed) {
                    form.submit();
                }
            });

            // Event Listeners
            if (pathSelect) {
                pathSelect.addEventListener('change', updatePathUI);
                updatePathUI();
            }

            if (hasDisabilityCheck) {
                hasDisabilityCheck.addEventListener('change', updateDisabilityUI);
                updateDisabilityUI();
            }

            if (hasFamilyConnectionCheck) {
                hasFamilyConnectionCheck.addEventListener('change', updateFamilyUI);
                updateFamilyUI();
            }

            document.querySelectorAll('.circumstance-card input[type="checkbox"]').forEach(checkbox => {
                checkbox.addEventListener('change', function() {
                    const card = this.closest('.circumstance-card');
                    if (this.checked) {
                        card.classList.add('active');
                    } else {
                        card.classList.remove('active');
                    }
                });

                // Initialize card state on load
                if (checkbox.checked) {
                    const card = checkbox.closest('.circumstance-card');
                    if (card) card.classList.add('active');
                }
            });

            // Initialize
            showStep(1);

            // Show TempData messages
            @if (TempData["Success"] != null)
            {
                    <text>
                    Swal.fire({
                        icon: 'success',
                        title: 'Success!',
                        text: '@TempData["Success"]',
                        confirmButtonColor: '#10b981',
                        confirmButtonText: 'OK'
                    });
                    </text>
            }

            @if (TempData["Error"] != null)
            {
                    <text>
                    Swal.fire({
                        icon: 'error',
                        title: 'Error!',
                        text: '@TempData["Error"]',
                        confirmButtonColor: '#5f2ded',
                        confirmButtonText: 'OK'
                    });
                    </text>
            }

            @if (TempData["Info"] != null)
            {
                    <text>
                    Swal.fire({
                        icon: 'info',
                        title: 'Information',
                        text: '@TempData["Info"]',
                        confirmButtonColor: '#5f2ded',
                        confirmButtonText: 'OK'
                    });
                    </text>
            }
        });
    </script>
}
