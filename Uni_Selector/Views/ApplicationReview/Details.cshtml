@using Uni_Selector.Models.Enums
@model Uni_Selector.ViewModels.ApplicationReview.ApplicationDetailsViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Application Details";
}

<div class="dashboard-main-body">
    @Html.AntiForgeryToken()

    <!-- Breadcrumb -->
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-24">
        <h6 class="fw-semibold mb-0">Application Details</h6>
        <ul class="d-flex align-items-center gap-2">
            <li class="fw-medium">
                <a asp-action="Index" class="d-flex align-items-center gap-1 hover-text-primary">
                    <iconify-icon icon="solar:home-smile-angle-outline" class="icon text-lg"></iconify-icon>
                    Applications
                </a>
            </li>
            <li>-</li>
            <li class="fw-medium">@Model.ApplicationNumber</li>
        </ul>
    </div>

    <div class="row gy-4">
        <!-- Left Sidebar - Student Info -->
        <div class="col-lg-4">
            <div class="user-grid-card position-relative border radius-16 overflow-hidden bg-base h-100">
                <div class="bg-primary-600" style="height: 120px;"></div>
                <div class="pb-24 ms-16 mb-24 me-16 mt--100">
                    <div class="text-center border border-top-0 border-start-0 border-end-0 pb-24">
                        <div class="w-200-px h-200-px rounded-circle bg-primary-50 d-inline-flex align-items-center justify-content-center border border-white border-width-2-px">
                            <iconify-icon icon="solar:user-bold-duotone" class="text-primary-600" style="font-size: 80px;"></iconify-icon>
                        </div>
                        <h6 class="mb-0 mt-16">@Model.StudentName</h6>
                        <span class="text-secondary-light mb-16">@Model.StudentEmail</span>
                        <div class="mt-12">
                            @switch (Model.Status)
                            {
                                case ApplicationStatus.Pending:
                                    <span class="bg-warning-focus text-warning-main px-24 py-4 rounded-pill fw-medium text-sm">Pending</span>
                                    break;
                                case ApplicationStatus.UnderReview:
                                    <span class="bg-info-focus text-info-main px-24 py-4 rounded-pill fw-medium text-sm">Under Review</span>
                                    break;
                                case ApplicationStatus.Approved:
                                    <span class="bg-success-focus text-success-main px-24 py-4 rounded-pill fw-medium text-sm">Approved</span>
                                    break;
                                case ApplicationStatus.Rejected:
                                    <span class="bg-danger-focus text-danger-main px-24 py-4 rounded-pill fw-medium text-sm">Rejected</span>
                                    break;
                                case ApplicationStatus.Enrolled:
                                    <span class="bg-primary-600 text-white px-24 py-4 rounded-pill fw-medium text-sm">Enrolled</span>
                                    break;
                                case ApplicationStatus.Cancelled:
                                    <span class="bg-neutral-500 text-white px-24 py-4 rounded-pill fw-medium text-sm">Cancelled</span>
                                    break;
                            }
                        </div>
                    </div>
                    <div class="mt-24">
                        <h6 class="text-xl mb-16">Student Information</h6>
                        <ul>
                            <li class="d-flex align-items-center gap-1 mb-12">
                                <span class="w-40 text-md fw-semibold text-primary-light">National ID</span>
                                <span class="w-60 text-secondary-light fw-medium">: @Model.NationalId</span>
                            </li>
                            <li class="d-flex align-items-center gap-1 mb-12">
                                <span class="w-40 text-md fw-semibold text-primary-light">Seat Number</span>
                                <span class="w-60 text-secondary-light fw-medium">: @Model.SeatNumber</span>
                            </li>
                            <li class="d-flex align-items-center gap-1 mb-12">
                                <span class="w-40 text-md fw-semibold text-primary-light">Phone</span>
                                <span class="w-60 text-secondary-light fw-medium">: @Model.StudentPhone</span>
                            </li>
                            <li class="d-flex align-items-center gap-1 mb-12">
                                <span class="w-40 text-md fw-semibold text-primary-light">Gender</span>
                                <span class="w-60 text-secondary-light fw-medium">: @Model.Gender</span>
                            </li>
                            <li class="d-flex align-items-center gap-1 mb-12">
                                <span class="w-40 text-md fw-semibold text-primary-light">Date of Birth</span>
                                <span class="w-60 text-secondary-light fw-medium">: @Model.DateOfBirth.ToString("MMM dd, yyyy")</span>
                            </li>
                            <li class="d-flex align-items-center gap-1 mb-12">
                                <span class="w-40 text-md fw-semibold text-primary-light">Nationality</span>
                                <span class="w-60 text-secondary-light fw-medium">: @Model.Nationality</span>
                            </li>
                            <li class="d-flex align-items-center gap-1 mb-12">
                                <span class="w-40 text-md fw-semibold text-primary-light">GPA</span>
                                <span class="w-60 text-primary-600 fw-bold">: @Model.GPA.ToString("F1")%</span>
                            </li>
                            <li class="d-flex align-items-center gap-1 mb-12">
                                <span class="w-40 text-md fw-semibold text-primary-light">Path</span>
                                <span class="w-60 text-secondary-light fw-medium">: @Model.Path</span>
                            </li>
                            @if (Model.AcademicTrack.HasValue)
                            {
                                <li class="d-flex align-items-center gap-1 mb-12">
                                    <span class="w-40 text-md fw-semibold text-primary-light">Track</span>
                                    <span class="w-60 text-secondary-light fw-medium">: @Model.AcademicTrack</span>
                                </li>
                            }
                            @if (Model.VocationalBranch.HasValue)
                            {
                                <li class="d-flex align-items-center gap-1 mb-12">
                                    <span class="w-40 text-md fw-semibold text-primary-light">Branch</span>
                                    <span class="w-60 text-secondary-light fw-medium">: @Model.VocationalBranch</span>
                                </li>
                            }
                        </ul>
                    </div>

                    <div class="mt-24">
                        <h6 class="text-xl mb-16">Guardian Information</h6>
                        <ul>
                            <li class="d-flex align-items-center gap-1 mb-12">
                                <span class="w-40 text-md fw-semibold text-primary-light">Name</span>
                                <span class="w-60 text-secondary-light fw-medium">: @Model.GuardianName</span>
                            </li>
                            <li class="d-flex align-items-center gap-1 mb-12">
                                <span class="w-40 text-md fw-semibold text-primary-light">Phone</span>
                                <span class="w-60 text-secondary-light fw-medium">: @Model.GuardianPhone</span>
                            </li>
                            <li class="d-flex align-items-center gap-1 mb-12">
                                <span class="w-40 text-md fw-semibold text-primary-light">Relation</span>
                                <span class="w-60 text-secondary-light fw-medium">: @Model.GuardianRelation</span>
                            </li>
                        </ul>
                    </div>

                    <div class="mt-24">
                        <h6 class="text-xl mb-16">Location</h6>
                        <ul>
                            <li class="d-flex align-items-center gap-1 mb-12">
                                <span class="w-40 text-md fw-semibold text-primary-light">Province</span>
                                <span class="w-60 text-secondary-light fw-medium">: @Model.Province</span>
                            </li>
                            <li class="d-flex align-items-center gap-1 mb-12">
                                <span class="w-40 text-md fw-semibold text-primary-light">City</span>
                                <span class="w-60 text-secondary-light fw-medium">: @Model.City</span>
                            </li>
                            @if (!string.IsNullOrWhiteSpace(Model.Area))
                            {
                                <li class="d-flex align-items-center gap-1 mb-12">
                                    <span class="w-40 text-md fw-semibold text-primary-light">Area</span>
                                    <span class="w-60 text-secondary-light fw-medium">: @Model.Area</span>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Side - Application Details -->
        <div class="col-lg-8">
            <div class="card h-100">
                <div class="card-body p-24">
                    <!-- Application Info Section -->
                    <div class="mb-20">
                        <h6 class="text-xl mb-16 fw-bold">Application Information</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="p-16 border radius-8">
                                    <span class="text-secondary-light text-sm">Application Number</span>
                                    <h6 class="fw-semibold mt-4">@Model.ApplicationNumber</h6>
                                </div>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(Model.AdmissionNumber))
                            {
                                <div class="col-md-6">
                                    <div class="p-16 border radius-8 bg-success-50">
                                        <span class="text-secondary-light text-sm">Admission Number</span>
                                        <h6 class="fw-semibold mt-4 text-success-600">@Model.AdmissionNumber</h6>
                                    </div>
                                </div>
                            }
                            <div class="col-md-6">
                                <div class="p-16 border radius-8">
                                    <span class="text-secondary-light text-sm">Application Date</span>
                                    <h6 class="fw-semibold mt-4">@Model.ApplicationDate.ToString("MMM dd, yyyy")</h6>
                                </div>
                            </div>
                            @if (Model.ApprovalDate.HasValue)
                            {
                                <div class="col-md-6">
                                    <div class="p-16 border radius-8">
                                        <span class="text-secondary-light text-sm">Approval Date</span>
                                        <h6 class="fw-semibold mt-4">@Model.ApprovalDate.Value.ToString("MMM dd, yyyy")</h6>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Program Info Section -->
                    <div class="mb-20">
                        <h6 class="text-xl mb-16 fw-bold">Program Information</h6>
                        <div class="border radius-8 p-20">
                            <div class="d-flex justify-content-between align-items-start mb-16">
                                <div>
                                    <h5 class="fw-bold mb-8">@Model.ProgramNameEnglish</h5>
                                    <p class="text-secondary-light mb-8">@Model.ProgramNameArabic</p>
                                    @if (Model.IsBtecProgram)
                                    {
                                        <span class="badge bg-info-focus text-info-main">BTEC Program</span>
                                        @if (Model.IsProgramApprovedByBtec)
                                        {
                                            <span class="badge bg-success-focus text-success-main ms-2">BTEC Approved</span>
                                        }
                                    }
                                </div>
                            </div>

                            <div class="row g-3 mt-16">
                                <div class="col-md-4">
                                    <span class="text-secondary-light text-sm d-block">University</span>
                                    <span class="fw-semibold">@Model.UniversityNameEnglish</span>
                                </div>
                                <div class="col-md-4">
                                    <span class="text-secondary-light text-sm d-block">
                                        @if (Model.IsBtecProgram)
                                        {
                                            <text>BTEC Level</text>
                                        }
                                        else
                                        {
                                            <text>Degree</text>
                                        }
                                    </span>
                                    <span class="fw-semibold">
                                        @if (Model.IsBtecProgram)
                                        {
                                            @Model.BtecLevel
                                        }
                                        else
                                        {
                                            @Model.Degree
                                        }
                                    </span>
                                </div>
                                <div class="col-md-4">
                                    <span class="text-secondary-light text-sm d-block">Duration</span>
                                    <span class="fw-semibold">@Model.ProgramDuration Years</span>
                                </div>
                                <div class="col-md-4">
                                    <span class="text-secondary-light text-sm d-block">Language</span>
                                    <span class="fw-semibold">@Model.ProgramLanguage</span>
                                </div>
                                <div class="col-md-4">
                                    <span class="text-secondary-light text-sm d-block">Total Credit Hours</span>
                                    <span class="fw-semibold">@Model.TotalCreditHours Hours</span>
                                </div>
                                @if (!Model.IsBtecProgram)
                                {
                                    <div class="col-md-4">
                                        <span class="text-secondary-light text-sm d-block">Study System</span>
                                        <span class="fw-semibold">@Model.StudySystem</span>
                                    </div>
                                }
                                @if (Model.IsBtecProgram && !string.IsNullOrWhiteSpace(Model.TechnicalField))
                                {
                                    <div class="col-md-4">
                                        <span class="text-secondary-light text-sm d-block">Technical Field</span>
                                        <span class="fw-semibold">@Model.TechnicalField</span>
                                    </div>
                                }
                            </div>

                            <!-- Financial Information -->
                            <div class="mt-20 pt-20 border-top">
                                <h6 class="fw-bold mb-16">Financial Information</h6>
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <span class="text-secondary-light text-sm d-block">Hour Price</span>
                                        <span class="fw-semibold text-primary-600">@Model.HourPriceBase.ToString("N2") JOD</span>
                                    </div>
                                    <div class="col-md-4">
                                        <span class="text-secondary-light text-sm d-block">Registration Fee (1st Semester)</span>
                                        <span class="fw-semibold">@Model.RegistrationFeeFirstSemester.ToString("N2") JOD</span>
                                    </div>
                                    <div class="col-md-4">
                                        <span class="text-secondary-light text-sm d-block">Registration Fee (Regular)</span>
                                        <span class="fw-semibold">@Model.RegistrationFeeRegularSemester.ToString("N2") JOD</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Discount & Commission Section -->
                    @if (Model.HasDiscountGrant || Model.HasCommission || Model.HourDiscountPercent.HasValue)
                    {
                        <div class="mb-20">
                            <h6 class="text-xl mb-16 fw-bold">Discount & Commission</h6>
                            <div class="row g-3">
                                @if (Model.HasDiscountGrant)
                                {
                                    <div class="col-md-6">
                                        <div class="border radius-8 p-16 bg-success-50">
                                            <div class="d-flex align-items-center gap-2 mb-8">
                                                <iconify-icon icon="solar:ticket-bold-duotone" class="text-success-600 text-xl"></iconify-icon>
                                                <span class="text-secondary-light text-sm">Platform Discount (5%)</span>
                                            </div>
                                            <h6 class="fw-bold text-success-600 mb-4">@Model.DiscountCode</h6>
                                            <span class="text-sm">Amount: @Model.DiscountAmountEstimated?.ToString("N2") JOD</span>
                                            <div class="mt-8">
                                                @switch (Model.DiscountStatus)
                                                {
                                                    case DiscountStatus.Issued:
                                                        <span class="badge bg-warning-focus text-warning-main">Issued</span>
                                                        break;
                                                    case DiscountStatus.Redeemed:
                                                        <span class="badge bg-success-focus text-success-main">Redeemed</span>
                                                        break;
                                                    case DiscountStatus.Expired:
                                                        <span class="badge bg-danger-focus text-danger-main">Expired</span>
                                                        break;
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                                @if (Model.HourDiscountPercent.HasValue)
                                {
                                    <div class="col-md-6">
                                        <div class="border radius-8 p-16 bg-info-50">
                                            <div class="d-flex align-items-center gap-2 mb-8">
                                                <iconify-icon icon="solar:percent-circle-bold-duotone" class="text-info-600 text-xl"></iconify-icon>
                                                <span class="text-secondary-light text-sm">Hour Discount</span>
                                            </div>
                                            <h6 class="fw-bold text-info-600 mb-4">@Model.HourDiscountPercent%</h6>
                                            <span class="text-sm d-block">Planned Hours: @Model.PlannedFirstSemesterHours</span>
                                            @if (!string.IsNullOrWhiteSpace(Model.HourDiscountSetByUserName))
                                            {
                                                <span class="text-xs text-secondary-light d-block mt-4">Set by: @Model.HourDiscountSetByUserName</span>
                                            }
                                        </div>
                                    </div>
                                }
                                @if (Model.HasCommission)
                                {
                                    <div class="col-md-12">
                                        <div class="border radius-8 p-16 bg-primary-50">
                                            <div class="d-flex align-items-center gap-2 mb-8">
                                                <iconify-icon icon="solar:dollar-bold-duotone" class="text-primary-600 text-xl"></iconify-icon>
                                                <span class="text-secondary-light text-sm">Platform Commission (2%)</span>
                                            </div>
                                            <div class="row">
                                                <div class="col-md-4">
                                                    <span class="text-sm d-block">Mode: @Model.CommissionMode</span>
                                                </div>
                                                <div class="col-md-4">
                                                    <span class="text-sm d-block fw-bold text-primary-600">Amount: @Model.CommissionAmountEstimated?.ToString("N2") JOD</span>
                                                </div>
                                                <div class="col-md-4">
                                                    @if (Model.CommissionSettled == true)
                                                    {
                                                        <span class="badge bg-success-focus text-success-main">Settled</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-warning-focus text-warning-main">Pending</span>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <!-- Notes Section -->
                    @if (!string.IsNullOrWhiteSpace(Model.Notes))
                    {
                        <div class="mb-20">
                            <h6 class="text-xl mb-16 fw-bold">Notes</h6>
                            <div class="border radius-8 p-16 bg-base">
                                <pre class="mb-0" style="white-space: pre-wrap; font-family: inherit;">@Model.Notes</pre>
                            </div>
                        </div>
                    }

                    <!-- Rejection Reason -->
                    @if (!string.IsNullOrWhiteSpace(Model.RejectionReason))
                    {
                        <div class="mb-20">
                            <h6 class="text-xl mb-16 fw-bold text-danger-600">Rejection Reason</h6>
                            <div class="border border-danger-600 radius-8 p-16 bg-danger-50">
                                <p class="mb-0">@Model.RejectionReason</p>
                            </div>
                        </div>
                    }

                    <!-- Action Buttons -->
                    <div class="d-flex gap-3 flex-wrap">
                        @if (Model.CanApprove)
                        {
                            <button type="button" class="btn btn-success px-24 py-12 radius-8" onclick="approveApplication(@Model.ApplicationId)">
                                <iconify-icon icon="solar:check-circle-bold" class="icon text-lg"></iconify-icon>
                                Approve Application
                            </button>
                        }
                        @if (Model.CanReject)
                        {
                            <button type="button" class="btn btn-danger px-24 py-12 radius-8" onclick="rejectApplication(@Model.ApplicationId)">
                                <iconify-icon icon="solar:close-circle-bold" class="icon text-lg"></iconify-icon>
                                Reject Application
                            </button>
                        }
                        @if (Model.CanSetDiscount)
                        {
                            <button type="button" class="btn btn-info px-24 py-12 radius-8" data-bs-toggle="modal" data-bs-target="#setDiscountModal">
                                <iconify-icon icon="solar:percent-circle-bold" class="icon text-lg"></iconify-icon>
                                Set Hour Discount
                            </button>
                        }
                        @if (Model.CanAddNotes)
                        {
                            <button type="button" class="btn btn-outline-primary px-24 py-12 radius-8" data-bs-toggle="modal" data-bs-target="#addNotesModal">
                                <iconify-icon icon="solar:notes-bold" class="icon text-lg"></iconify-icon>
                                Add Notes
                            </button>
                        }
                        <a asp-action="Index" class="btn btn-outline-secondary px-24 py-12 radius-8">
                            <iconify-icon icon="solar:arrow-left-bold" class="icon text-lg"></iconify-icon>
                            Back to List
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Notes Modal -->
<div class="modal fade" id="addNotesModal" tabindex="-1" aria-labelledby="addNotesModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addNotesModalLabel">Add Notes to Application</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="addNotesForm">
                @Html.AntiForgeryToken()

                <div class="modal-body">
                    <div class="mb-20">
                        <label for="notes" class="form-label fw-semibold text-primary-light text-sm mb-8">Notes <span class="text-danger-600">*</span></label>
                        <textarea class="form-control radius-8" id="notes" name="notes" rows="5" placeholder="Enter your notes here..." maxlength="1000" required></textarea>
                        <span class="text-sm text-secondary-light mt-4 d-block">Maximum 1000 characters</span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary px-24 py-12 radius-8" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-24 py-12 radius-8">
                        <iconify-icon icon="solar:notes-bold" class="icon"></iconify-icon>
                        Add Notes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Set Discount Modal -->
<div class="modal fade" id="setDiscountModal" tabindex="-1" aria-labelledby="setDiscountModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="setDiscountModalLabel">Set Hour Discount</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="setDiscountForm">
                @Html.AntiForgeryToken()

                <div class="modal-body">
                    <div class="alert alert-info d-flex align-items-center mb-20" role="alert">
                        <iconify-icon icon="solar:info-circle-bold" class="text-info-main me-8 text-xl"></iconify-icon>
                        <div>
                            <strong>Hour Discount Range:</strong> 30% - 50%
                        </div>
                    </div>

                    <div class="mb-20">
                        <label for="hourDiscountPercent" class="form-label fw-semibold text-primary-light text-sm mb-8">Discount Percentage <span class="text-danger-600">*</span></label>
                        <input type="number" class="form-control radius-8" id="hourDiscountPercent" name="hourDiscountPercent"
                               min="30" max="50" step="0.01" placeholder="Enter discount percentage (30-50)" required>
                    </div>

                    <div class="mb-20">
                        <label for="plannedFirstSemesterHours" class="form-label fw-semibold text-primary-light text-sm mb-8">Planned First Semester Hours <span class="text-danger-600">*</span></label>
                        <input type="number" class="form-control radius-8" id="plannedFirstSemesterHours" name="plannedFirstSemesterHours"
                               min="1" max="60" placeholder="Enter planned hours (1-60)" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary px-24 py-12 radius-8" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-info px-24 py-12 radius-8">
                        <iconify-icon icon="solar:percent-circle-bold" class="icon"></iconify-icon>
                        Set Discount
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const applicationId = @Model.ApplicationId;

        // Add Notes Form Handler
        document.getElementById('addNotesForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const notes = document.getElementById('notes').value;

            try {
                const response = await fetch(`/UniversityRep/Applications/${applicationId}/Notes`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    },
                    body: new URLSearchParams({
                        'applicationId': applicationId,
                        'notes': notes,
                        '__RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    })
                });

                const result = await response.json();

                if (result.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Success!',
                        text: result.message,
                        timer: 2000,
                        showConfirmButton: false
                    }).then(() => {
                        location.reload();
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error!',
                        text: result.message
                    });
                }
            } catch (error) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error!',
                    text: 'An error occurred while adding notes.'
                });
            }
        });

        // Set Discount Form Handler
        document.getElementById('setDiscountForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const discountPercent = parseFloat(document.getElementById('hourDiscountPercent').value);
            const plannedHours = parseInt(document.getElementById('plannedFirstSemesterHours').value);

            // Validation
            if (discountPercent < 30 || discountPercent > 50) {
                Swal.fire({
                    icon: 'error',
                    title: 'Invalid Discount',
                    text: 'Discount must be between 30% and 50%'
                });
                return;
            }

            if (plannedHours < 1 || plannedHours > 60) {
                Swal.fire({
                    icon: 'error',
                    title: 'Invalid Hours',
                    text: 'Planned hours must be between 1 and 60'
                });
                return;
            }

            try {
                const response = await fetch(`/UniversityRep/Applications/${applicationId}/SetDiscount`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    },
                    body: new URLSearchParams({
                        'applicationId': applicationId,
                        'hourDiscountPercent': discountPercent,
                        'plannedFirstSemesterHours': plannedHours,
                        '__RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    })
                });

                const result = await response.json();

                if (result.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Success!',
                        text: result.message,
                        timer: 2000,
                        showConfirmButton: false
                    }).then(() => {
                        location.reload();
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error!',
                        text: result.message
                    });
                }
            } catch (error) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error!',
                    text: 'An error occurred while setting discount.'
                });
            }
        });

        // Approve Application
        async function approveApplication(id) {
            const { value: notes } = await Swal.fire({
                title: 'Approve Application',
                html: `
                    <div class="text-start">
                        <p class="mb-16">This will:</p>
                        <ul class="text-start mb-16">
                            <li>Approve the application</li>
                            <li>Generate 5% platform discount code</li>
                            <li>Create 2% commission record</li>
                            <li>Assign admission number</li>
                        </ul>
                        <label class="form-label fw-semibold text-sm">Approval Notes (Optional)</label>
                        <textarea id="approvalNotes" class="swal2-textarea w-100" placeholder="Enter approval notes..." maxlength="500"></textarea>
                    </div>
                `,
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Approve',
                cancelButtonText: 'Cancel',
                confirmButtonColor: '#28a745',
                preConfirm: () => {
                    return document.getElementById('approvalNotes').value;
                }
            });

            if (notes !== undefined) {
                try {
                    const response = await fetch(`/UniversityRep/Applications/${id}/Approve`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                        },
                        body: new URLSearchParams({
                            'applicationId': id,
                            'approvalNotes': notes,
                            '__RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                        })
                    });

                    const result = await response.json();

                    if (result.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Approved!',
                            text: result.message,
                            timer: 2000,
                            showConfirmButton: false
                        }).then(() => {
                            location.reload();
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error!',
                            text: result.message
                        });
                    }
                } catch (error) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error!',
                        text: 'An error occurred while approving the application.'
                    });
                }
            }
        }

        // Reject Application
        async function rejectApplication(id) {
            const { value: reason } = await Swal.fire({
                title: 'Reject Application',
                html: `
                    <div class="text-start">
                        <p class="text-danger-600 mb-16">This action will reject the application.</p>
                        <label class="form-label fw-semibold text-sm">Rejection Reason <span class="text-danger-600">*</span></label>
                        <textarea id="rejectionReason" class="swal2-textarea w-100" placeholder="Enter reason for rejection..." maxlength="1000" required></textarea>
                    </div>
                `,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Reject',
                cancelButtonText: 'Cancel',
                confirmButtonColor: '#dc3545',
                preConfirm: () => {
                    const reason = document.getElementById('rejectionReason').value;
                    if (!reason) {
                        Swal.showValidationMessage('Rejection reason is required');
                    }
                    return reason;
                }
            });

            if (reason) {
                try {
                    const response = await fetch(`/UniversityRep/Applications/${id}/Reject`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                        },
                        body: new URLSearchParams({
                            'applicationId': id,
                            'rejectionReason': reason,
                            '__RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                        })
                    });

                    const result = await response.json();

                    if (result.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Rejected!',
                            text: result.message,
                            timer: 2000,
                            showConfirmButton: false
                        }).then(() => {
                            location.reload();
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error!',
                            text: result.message
                        });
                    }
                } catch (error) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error!',
                        text: 'An error occurred while rejecting the application.'
                    });
                }
            }
        }

        // Show success/error messages from TempData
        @if (TempData["Success"] != null)
        {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: 'Success!',
                    text: '@TempData["Success"]',
                    timer: 3000,
                    showConfirmButton: false
                });
                </text>
        }

        @if (TempData["Error"] != null)
        {
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Error!',
                    text: '@TempData["Error"]',
                    timer: 3000,
                    showConfirmButton: false
                });
                </text>
        }
    </script>
}
