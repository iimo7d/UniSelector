@using Uni_Selector.ViewModels.AdminCommission
@model CommissionListViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Commissions Management";
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-24">
    <h6 class="fw-semibold mb-0">Commissions Management</h6>
    <ul class="d-flex align-items-center gap-2">
        <li class="fw-medium">
            <a href="@Url.Action("Index", "Admin")" class="d-flex align-items-center gap-1 hover-text-primary">
                <iconify-icon icon="solar:home-smile-angle-outline" class="icon text-lg"></iconify-icon>
                Dashboard
            </a>
        </li>
        <li>-</li>
        <li class="fw-medium">Commissions</li>
    </ul>
</div>

<!-- Summary Cards -->
<div class="row gy-4 mb-24">
    <div class="col-xxl-3 col-sm-6">
        <div class="card p-0 radius-12">
            <div class="card-body p-20">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <span class="text-secondary-light mb-4 fw-medium text-sm d-block">Total Commission</span>
                        <h4 class="mb-0 fw-bold text-primary-600">@Model.TotalCommissionAmount.ToString("N2") JOD</h4>
                    </div>
                    <div class="w-64-px h-64-px rounded-circle bg-primary-600 d-flex align-items-center justify-content-center">
                        <iconify-icon icon="solar:money-bag-bold" class="text-white text-32"></iconify-icon>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xxl-3 col-sm-6">
        <div class="card p-0 radius-12">
            <div class="card-body p-20">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <span class="text-secondary-light mb-4 fw-medium text-sm d-block">Settled (@Model.SettledCount)</span>
                        <h4 class="mb-0 fw-bold text-success-600">@Model.SettledAmount.ToString("N2") JOD</h4>
                    </div>
                    <div class="w-64-px h-64-px rounded-circle bg-success-600 d-flex align-items-center justify-content-center">
                        <iconify-icon icon="solar:check-circle-bold" class="text-white text-32"></iconify-icon>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xxl-3 col-sm-6">
        <div class="card p-0 radius-12">
            <div class="card-body p-20">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <span class="text-secondary-light mb-4 fw-medium text-sm d-block">Pending (@Model.PendingCount)</span>
                        <h4 class="mb-0 fw-bold text-warning-600">@Model.PendingAmount.ToString("N2") JOD</h4>
                    </div>
                    <div class="w-64-px h-64-px rounded-circle bg-warning-600 d-flex align-items-center justify-content-center">
                        <iconify-icon icon="solar:clock-circle-bold" class="text-white text-32"></iconify-icon>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xxl-3 col-sm-6">
        <div class="card p-0 radius-12">
            <div class="card-body p-20">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <span class="text-secondary-light mb-4 fw-medium text-sm d-block">Total Records</span>
                        <h4 class="mb-0 fw-bold">@Model.TotalCommissions</h4>
                    </div>
                    <div class="w-64-px h-64-px rounded-circle bg-info-600 d-flex align-items-center justify-content-center">
                        <iconify-icon icon="solar:document-bold" class="text-white text-32"></iconify-icon>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card h-100 p-0 radius-12">
    <div class="card-header border-bottom bg-base py-16 px-24">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div class="d-flex align-items-center gap-2">
                <a href="@Url.Action("Settlements")" class="btn btn-primary text-sm btn-sm px-12 py-12 radius-8">
                    <iconify-icon icon="solar:checklist-outline" class="icon text-xl me-4"></iconify-icon>
                    View Settlements
                </a>
                <a href="@Url.Action("Calculate")" class="btn btn-outline-success text-sm btn-sm px-12 py-12 radius-8" onclick="return confirm('Calculate commissions for all approved applications without commissions?')">
                    <iconify-icon icon="solar:calculator-outline" class="icon text-xl me-4"></iconify-icon>
                    Calculate Commissions
                </a>
            </div>
        </div>
    </div>

    <div class="card-body p-24">
        <!-- Filters -->
        <form asp-action="Index" method="get" class="mb-24">
            <div class="row g-3 align-items-end">

                <div class="col-12 col-md-2 col-lg-1">
                    <label class="form-label fw-medium text-sm mb-8">Show</label>
                    <select name="pageSize" class="form-select form-select-sm radius-8" onchange="this.form.submit()">
                        <option value="10" selected="@(Model.PageSize == 10)">10</option>
                        <option value="20" selected="@(Model.PageSize == 20)">20</option>
                        <option value="50" selected="@(Model.PageSize == 50)">50</option>
                        <option value="100" selected="@(Model.PageSize == 100)">100</option>
                    </select>
                </div>

                <!-- was col-lg-3 -> make it col-lg-2 -->
                <div class="col-12 col-md-4 col-lg-2">
                    <label class="form-label fw-medium text-sm mb-8">University</label>
                    <select name="universityId" class="form-select form-select-sm radius-8">
                        <option value="">All Universities</option>
                        @foreach (var uni in Model.Universities)
                        {
                            <option value="@uni.Id" selected="@(Model.UniversityId == uni.Id)">@uni.Name</option>
                        }
                    </select>
                </div>

                <div class="col-12 col-md-3 col-lg-2">
                    <label class="form-label fw-medium text-sm mb-8">Status</label>
                    <select name="settled" class="form-select form-select-sm radius-8">
                        <option value="">All</option>
                        <option value="true" selected="@(Model.Settled == true)">Settled</option>
                        <option value="false" selected="@(Model.Settled == false)">Pending</option>
                    </select>
                </div>

                <div class="col-12 col-md-3 col-lg-2">
                    <label class="form-label fw-medium text-sm mb-8">Mode</label>
                    <select name="mode" class="form-select form-select-sm radius-8">
                        <option value="">All Modes</option>
                        @foreach (var mode in Model.AllModes)
                        {
                            <option value="@mode" selected="@(Model.Mode == mode)">@mode</option>
                        }
                    </select>
                </div>

                <!-- was col-lg-2 -> make it col-lg-3 -->
                <div class="col-12 col-md-6 col-lg-3">
                    <label class="form-label fw-medium text-sm mb-8">Date Range</label>
                    <div class="d-flex gap-2">
                        <input type="date" name="startDate"
                               value="@Model.StartDate?.ToString("yyyy-MM-dd")"
                               class="form-control form-control-sm radius-8"
                               style="min-width:0; flex:1 1 0;" />
                        <input type="date" name="endDate"
                               value="@Model.EndDate?.ToString("yyyy-MM-dd")"
                               class="form-control form-control-sm radius-8"
                               style="min-width:0; flex:1 1 0;" />
                    </div>
                </div>

                <!-- keep buttons col-lg-2 -->
                <div class="col-12 col-md-6 col-lg-2 d-flex gap-2 justify-content-start justify-content-lg-end">
                    <button type="submit" class="btn btn-primary btn-sm radius-8 px-20">Filter</button>
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm radius-8 px-16">Clear</a>
                </div>

            </div>
        </form>

        <div class="table-responsive scroll-sm">
            <table class="table bordered-table sm-table mb-0">
                <thead>
                    <tr>
                        <th>Application #</th>
                        <th>Student</th>
                        <th>University</th>
                        <th>Mode</th>
                        <th>Base Amount</th>
                        <th>%</th>
                        <th>Commission</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Commissions.Any())
                    {
                        foreach (var comm in Model.Commissions)
                        {
                            <tr>
                                <td>
                                    <span class="text-sm fw-semibold text-primary-600">@comm.ApplicationNumber</span>
                                </td>
                                <td>
                                    <span class="text-sm">@comm.StudentName</span>
                                </td>
                                <td>
                                    <span class="text-sm">@comm.UniversityName</span>
                                </td>
                                <td>
                                    <span class="badge bg-info-focus text-info-600 px-12 py-4 radius-4 text-xs">@comm.ModeText</span>
                                </td>
                                <td>
                                    <span class="text-sm">@comm.BaseAmount.ToString("N2") JOD</span>
                                </td>
                                <td>
                                    <span class="text-sm fw-semibold">@comm.Percentage%</span>
                                </td>
                                <td>
                                    <span class="text-sm fw-bold text-success-600">@comm.AmountEstimated.ToString("N2") JOD</span>
                                </td>
                                <td>
                                    @if (comm.Settled)
                                    {
                                        <span class="badge bg-success-focus text-success-600 px-16 py-4 radius-4">Settled</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-focus text-warning-600 px-16 py-4 radius-4">Pending</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="text-sm">@comm.CreatedAt.ToString("dd MMM yyyy")</span>
                                        <span class="text-xs text-secondary-light">@comm.CreatedAt.ToString("HH:mm")</span>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <a asp-action="Details" asp-route-id="@comm.Id"
                                       class="bg-info-focus bg-hover-info-200 text-info-600 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle"
                                       title="View Details">
                                        <iconify-icon icon="majesticons:eye-line" class="icon text-xl"></iconify-icon>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="10" class="text-center py-32">
                                <iconify-icon icon="solar:money-bag-outline" class="icon text-64 text-secondary-light mb-12"></iconify-icon>
                                <p class="text-secondary-light mb-0">No commissions found</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mt-24">
                <span class="text-sm fw-medium text-secondary-light">
                    Showing @((Model.CurrentPage - 1) * Model.PageSize + 1) to @Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCommissions) of @Model.TotalCommissions
                </span>
                <ul class="pagination d-flex flex-wrap align-items-center gap-2 justify-content-center">
                    @if (Model.CurrentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link bg-neutral-200 text-secondary-light fw-semibold radius-8 border-0 d-flex align-items-center justify-content-center h-32-px w-32-px"
                               href="@Url.Action("Index", new { page = Model.CurrentPage - 1, pageSize = Model.PageSize, universityId = Model.UniversityId, settled = Model.Settled, mode = Model.Mode, startDate = Model.StartDate?.ToString("yyyy-MM-dd"), endDate = Model.EndDate?.ToString("yyyy-MM-dd") })">
                                <iconify-icon icon="ep:d-arrow-left"></iconify-icon>
                            </a>
                        </li>
                    }
                    @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                    {
                        <li class="page-item">
                            <a class="page-link @(i == Model.CurrentPage ? "bg-primary-600 text-white" : "bg-neutral-200 text-secondary-light") fw-semibold radius-8 border-0 d-flex align-items-center justify-content-center h-32-px w-32-px"
                               href="@Url.Action("Index", new { page = i, pageSize = Model.PageSize, universityId = Model.UniversityId, settled = Model.Settled, mode = Model.Mode, startDate = Model.StartDate?.ToString("yyyy-MM-dd"), endDate = Model.EndDate?.ToString("yyyy-MM-dd") })">
                                @i
                            </a>
                        </li>
                    }
                    @if (Model.CurrentPage < Model.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link bg-neutral-200 text-secondary-light fw-semibold radius-8 border-0 d-flex align-items-center justify-content-center h-32-px w-32-px"
                               href="@Url.Action("Index", new { page = Model.CurrentPage + 1, pageSize = Model.PageSize, universityId = Model.UniversityId, settled = Model.Settled, mode = Model.Mode, startDate = Model.StartDate?.ToString("yyyy-MM-dd"), endDate = Model.EndDate?.ToString("yyyy-MM-dd") })">
                                <iconify-icon icon="ep:d-arrow-right"></iconify-icon>
                            </a>
                        </li>
                    }
                </ul>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        @if (TempData["Success"] != null)
        {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: 'Success!',
                    text: '@TempData["Success"]',
                    confirmButtonColor: '#198754',
                    timer: 3000,
                    timerProgressBar: true
                });
                </text>
        }
        @if (TempData["Error"] != null)
        {
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Error!',
                    text: '@TempData["Error"]',
                    confirmButtonColor: '#dc3545'
                });
                </text>
        }
    </script>
}
