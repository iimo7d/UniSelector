@model ApplicationListViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Applications Management";
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-24">
    <h6 class="fw-semibold mb-0">Applications Management</h6>
    <ul class="d-flex align-items-center gap-2">
        <li class="fw-medium">
            <a href="@Url.Action("Index", "Admin")" class="d-flex align-items-center gap-1 hover-text-primary">
                <iconify-icon icon="solar:home-smile-angle-outline" class="icon text-lg"></iconify-icon>
                Dashboard
            </a>
        </li>
        <li>-</li>
        <li class="fw-medium">Applications</li>
    </ul>
</div>

<div class="card h-100 p-0 radius-12">
    <div class="card-header border-bottom bg-base py-16 px-24">
        <div class="row align-items-center gy-3">
            <div class="col-12">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                    <div class="d-flex align-items-center gap-2">
                        <a href="@Url.Action("Statistics")" class="btn btn-outline-primary text-sm btn-sm px-12 py-12 radius-8 d-flex align-items-center gap-2">
                            <iconify-icon icon="solar:chart-outline" class="icon text-xl line-height-1"></iconify-icon>
                            View Statistics
                        </a>
                        <a href="@Url.Action("Export")" class="btn btn-success text-sm btn-sm px-12 py-12 radius-8 d-flex align-items-center gap-2">
                            <iconify-icon icon="solar:download-outline" class="icon text-xl line-height-1"></iconify-icon>
                            Export to Excel
                        </a>
                    </div>
                    <span class="badge bg-primary-600 text-white px-16 py-8 radius-4 fw-medium text-md">
                        Total: @Model.TotalApplications
                    </span>
                </div>
            </div>
            
            <!-- Filters -->
            <div class="col-12">
                <form asp-action="Index" method="get">
                    <div class="row g-3 align-items-end filters-row">

                        <div class="col-12 col-md-2 col-lg-1">
                            <label class="form-label fw-medium text-sm mb-8">Show</label>
                            <select name="pageSize" class="form-select form-select-sm radius-8" onchange="this.form.submit()">
                                <option value="10" selected="@(Model.PageSize == 10 ? "selected" : null)">10</option>
                                <option value="20" selected="@(Model.PageSize == 20 ? "selected" : null)">20</option>
                                <option value="50" selected="@(Model.PageSize == 50 ? "selected" : null)">50</option>
                                <option value="100" selected="@(Model.PageSize == 100 ? "selected" : null)">100</option>
                            </select>
                        </div>

                        <!-- قللنا Search على lg عشان نوسّع مساحة الأزرار -->
                        <div class="col-12 col-md-4 col-lg-2 col-xl-3">
                            <label class="form-label fw-medium text-sm mb-8">Search</label>
                            <div class="position-relative">
                                <input type="text" name="searchTerm" value="@Model.SearchTerm"
                                       class="form-control form-control-sm radius-8 ps-36"
                                       placeholder="Application #, Student name...">
                                <iconify-icon icon="ion:search-outline"
                                              class="icon text-lg position-absolute top-50 translate-middle-y ms-12"></iconify-icon>
                            </div>
                        </div>

                        <div class="col-12 col-md-3 col-lg-2">
                            <label class="form-label fw-medium text-sm mb-8">Status</label>
                            <select name="status" class="form-select form-select-sm radius-8">
                                <option value="">All Statuses</option>
                                @foreach (var status in Model.AllStatuses)
                                {
                                    <option value="@status" selected="@(Model.Status == status ? "selected" : null)">@status</option>
                                }
                            </select>
                        </div>

                        <div class="col-12 col-md-3 col-lg-2">
                            <label class="form-label fw-medium text-sm mb-8">University</label>
                            <select name="universityId" class="form-select form-select-sm radius-8">
                                <option value="">All Universities</option>
                                @foreach (var university in Model.Universities)
                                {
                                    <option value="@university.Id" selected="@(Model.UniversityId == university.Id ? "selected" : null)">@university.Name</option>
                                }
                            </select>
                        </div>

                        <div class="col-12 col-md-6 col-lg-3">
                            <label class="form-label fw-medium text-sm mb-8">Date Range</label>
                            <div class="d-flex gap-2">
                                <input type="date" name="startDate"
                                       value="@Model.StartDate?.ToString("yyyy-MM-dd")"
                                       class="form-control form-control-sm radius-8"
                                       style="min-width:0; flex:1 1 0;" />

                                <input type="date" name="endDate"
                                       value="@Model.EndDate?.ToString("yyyy-MM-dd")"
                                       class="form-control form-control-sm radius-8"
                                       style="min-width:0; flex:1 1 0;" />
                            </div>
                        </div>

                        <!-- أهم تغيير: من col-lg-1 إلى col-lg-2 + flex-wrap -->
                        <div class="col-12 col-md-6 col-lg-2 d-flex flex-wrap gap-2 justify-content-start justify-content-lg-end">
                            <button type="submit" class="btn btn-primary btn-sm radius-8 px-20 text-nowrap">
                                <iconify-icon icon="ic:baseline-filter-list" class="icon text-lg me-4"></iconify-icon>
                                Filter
                            </button>
                            <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm radius-8 px-16 text-nowrap">
                                Clear
                            </a>
                        </div>

                        <input type="hidden" name="page" value="@Model.CurrentPage" />
                    </div>
                </form>

                <style>
                    /* يمنع أي عناصر داخل الأعمدة تعمل overflow */
                    .filters-row .form-control,
                    .filters-row .form-select {
                        min-width: 0;
                    }
                </style>
            </div>
        </div>
    </div>

    <div class="card-body p-24">
        <div class="table-responsive scroll-sm">
            <table class="table bordered-table sm-table mb-0">
                <thead>
                    <tr>
                        <th scope="col">
                            <div class="d-flex align-items-center gap-10">
                                <div class="form-check style-check d-flex align-items-center">
                                    <input class="form-check-input radius-4 border border-neutral-400" type="checkbox" id="selectAll">
                                </div>
                                Application #
                            </div>
                        </th>
                        <th scope="col">Date</th>
                        <th scope="col">Student</th>
                        <th scope="col">University</th>
                        <th scope="col">Program</th>
                        <th scope="col">Type</th>
                        <th scope="col" class="text-center">Status</th>
                        <th scope="col" class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Applications.Any())
                    {
                        foreach (var app in Model.Applications)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-10">
                                        <div class="form-check style-check d-flex align-items-center">
                                            <input class="form-check-input radius-4 border border-neutral-400" type="checkbox" name="checkbox">
                                        </div>
                                        <span class="text-sm fw-semibold text-primary-600">@app.ApplicationNumber</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="text-sm fw-medium">@app.ApplicationDate.ToString("dd MMM yyyy")</span>
                                        <span class="text-xs text-secondary-light">@app.ApplicationDate.ToString("HH:mm")</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <h6 class="text-md mb-0 fw-medium">@app.StudentName</h6>
                                        <span class="text-sm text-secondary-light">@app.StudentEmail</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="text-sm">@app.UniversityName</span>
                                </td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="text-sm fw-medium">@app.ProgramName</span>
                                        <span class="badge bg-neutral-200 text-neutral-600 px-12 py-2 radius-4 fw-medium text-xs w-fit-content mt-4">@app.Degree</span>
                                    </div>
                                </td>
                                <td>
                                    @if (app.IsBtec)
                                    {
                                        <span class="badge bg-purple-focus text-purple-600 px-16 py-4 radius-4 fw-medium text-sm">BTEC</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info-focus text-info-600 px-16 py-4 radius-4 fw-medium text-sm">Regular</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <span class="@app.StatusBadgeClass px-20 py-6 radius-4 fw-medium text-sm">@app.StatusText</span>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex align-items-center gap-10 justify-content-center">
                                        <a asp-action="Details" asp-route-id="@app.Id"
                                           class="bg-info-focus bg-hover-info-200 text-info-600 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle"
                                           title="View Details">
                                            <iconify-icon icon="majesticons:eye-line" class="icon text-xl"></iconify-icon>
                                        </a>
                                        <a asp-action="Override" asp-route-id="@app.Id"
                                           class="bg-warning-focus text-warning-600 bg-hover-warning-200 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle"
                                           title="Override Status">
                                            <iconify-icon icon="solar:shield-warning-outline" class="icon text-xl"></iconify-icon>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-32">
                                <iconify-icon icon="solar:document-text-outline" class="icon text-64 text-secondary-light mb-12"></iconify-icon>
                                <p class="text-secondary-light mb-0">No applications found</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mt-24">
                <span class="text-sm fw-medium text-secondary-light">
                    Showing @((Model.CurrentPage - 1) * Model.PageSize + 1) to
                    @Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalApplications) of @Model.TotalApplications
                </span>
                <ul class="pagination d-flex flex-wrap align-items-center gap-2 justify-content-center">
                    @if (Model.CurrentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link bg-neutral-200 text-secondary-light fw-semibold radius-8 border-0 d-flex align-items-center justify-content-center h-32-px w-32-px"
                               href="@Url.Action("Index", new { page = Model.CurrentPage - 1, pageSize = Model.PageSize, searchTerm = Model.SearchTerm, status = Model.Status, universityId = Model.UniversityId, startDate = Model.StartDate?.ToString("yyyy-MM-dd"), endDate = Model.EndDate?.ToString("yyyy-MM-dd") })">
                                <iconify-icon icon="ep:d-arrow-left" class=""></iconify-icon>
                            </a>
                        </li>
                    }

                    @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                    {
                        <li class="page-item">
                            <a class="page-link @(i == Model.CurrentPage ? "bg-primary-600 text-white" : "bg-neutral-200 text-secondary-light") fw-semibold radius-8 border-0 d-flex align-items-center justify-content-center h-32-px w-32-px"
                               href="@Url.Action("Index", new { page = i, pageSize = Model.PageSize, searchTerm = Model.SearchTerm, status = Model.Status, universityId = Model.UniversityId, startDate = Model.StartDate?.ToString("yyyy-MM-dd"), endDate = Model.EndDate?.ToString("yyyy-MM-dd") })">
                                @i
                            </a>
                        </li>
                    }

                    @if (Model.CurrentPage < Model.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link bg-neutral-200 text-secondary-light fw-semibold radius-8 border-0 d-flex align-items-center justify-content-center h-32-px w-32-px"
                               href="@Url.Action("Index", new { page = Model.CurrentPage + 1, pageSize = Model.PageSize, searchTerm = Model.SearchTerm, status = Model.Status, universityId = Model.UniversityId, startDate = Model.StartDate?.ToString("yyyy-MM-dd"), endDate = Model.EndDate?.ToString("yyyy-MM-dd") })">
                                <iconify-icon icon="ep:d-arrow-right" class=""></iconify-icon>
                            </a>
                        </li>
                    }
                </ul>
            </div>
        }
    </div>
</div>

@using System.Text.Json
@using Uni_Selector.ViewModels.AdminApplication

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // Select all checkbox
        document.getElementById('selectAll')?.addEventListener('change', function() {
            const checkboxes = document.querySelectorAll('input[name="checkbox"]');
            checkboxes.forEach(checkbox => checkbox.checked = this.checked);
        });

        // Show messages
        const successMsg = @Html.Raw(JsonSerializer.Serialize(TempData["Success"]?.ToString()));
        if (successMsg) {
            Swal.fire({
                icon: 'success',
                title: 'Success!',
                text: successMsg,
                confirmButtonColor: '#198754',
                timer: 3000,
                timerProgressBar: true
            });
        }

        const errorMsg = @Html.Raw(JsonSerializer.Serialize(TempData["Error"]?.ToString()));
        if (errorMsg) {
            Swal.fire({
                icon: 'error',
                title: 'Error!',
                text: errorMsg,
                confirmButtonColor: '#dc3545'
            });
        }
    </script>
}
