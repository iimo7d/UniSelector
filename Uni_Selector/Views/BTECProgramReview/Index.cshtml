@using Uni_Selector.Models.Enums
@model Uni_Selector.ViewModels.BTECAuthority.BtecProgramListViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "BTEC Programs Review";
}

<div class="dashboard-main-body">
    <!-- Breadcrumb -->
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-24">
        <h6 class="fw-semibold mb-0">BTEC Programs Review</h6>
        <ul class="d-flex align-items-center gap-2">
            <li class="fw-medium">
                <a asp-controller="BTECAuthority" asp-action="Dashboard" class="d-flex align-items-center gap-1 hover-text-primary">
                    <iconify-icon icon="solar:home-smile-angle-outline" class="icon text-lg"></iconify-icon>
                    Dashboard
                </a>
            </li>
            <li>-</li>
            <li class="fw-medium">BTEC Programs</li>
        </ul>
    </div>

    <!-- Filters Card -->
    <div class="card mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get" id="filterForm">
                <div class="row g-3">
                    <!-- Search -->
                    <div class="col-md-3">
                        <label class="form-label">Search</label>
                        <input type="text" name="search" class="form-control"
                               placeholder="Program, University, Field..."
                               value="@Model.Search">
                    </div>

                    <!-- Level Filter -->
                    <div class="col-md-2">
                        <label class="form-label">BTEC Level</label>
                        <select name="level" class="form-select">
                            <option value="">All Levels</option>
                            <option value="2" selected="@(Model.LevelFilter == BtecLevel.Level2)">Level 2</option>
                            <option value="3" selected="@(Model.LevelFilter == BtecLevel.Level3)">Level 3</option>
                            <option value="4" selected="@(Model.LevelFilter == BtecLevel.Level4)">Level 4</option>
                            <option value="5" selected="@(Model.LevelFilter == BtecLevel.Level5)">Level 5</option>
                            <option value="6" selected="@(Model.LevelFilter == BtecLevel.Level6)">Level 6</option>
                            <option value="7" selected="@(Model.LevelFilter == BtecLevel.Level7)">Level 7</option>
                            <option value="8" selected="@(Model.LevelFilter == BtecLevel.Level8)">Level 8</option>
                        </select>
                    </div>

                    <!-- Technical Field Filter -->
                    <div class="col-md-2">
                        <label class="form-label">Technical Field</label>
                        <select name="technicalField" class="form-select">
                            <option value="">All Fields</option>
                            @foreach (var field in Model.TechnicalFields)
                            {
                                <option value="@field" selected="@(Model.TechnicalFieldFilter == field)">@field</option>
                            }
                        </select>
                    </div>

                    <!-- Approval Status Filter -->
                    <div class="col-md-2">
                        <label class="form-label">Approval Status</label>
                        <select name="approvalStatus" class="form-select">
                            <option value="">All</option>
                            <option value="true" selected="@(Model.ApprovalStatusFilter == true)">Approved</option>
                            <option value="false" selected="@(Model.ApprovalStatusFilter == false)">Pending</option>
                        </select>
                    </div>

                    <!-- University Filter -->
                    <div class="col-md-3">
                        <label class="form-label">University</label>
                        <select name="universityId" class="form-select">
                            <option value="">All Universities</option>
                            @foreach (var uni in Model.Universities)
                            {
                                <option value="@uni.Id" selected="@(Model.UniversityIdFilter == uni.Id)">
                                    @uni.NameEnglish (@uni.ProgramCount)
                                </option>
                            }
                        </select>
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary">
                            <iconify-icon icon="solar:filter-outline"></iconify-icon> Apply Filters
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <iconify-icon icon="solar:refresh-outline"></iconify-icon> Clear
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Programs Table -->
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0">
                BTEC Programs (@Model.TotalCount total)
            </h5>
            <div class="d-flex gap-2">
                <select class="form-select form-select-sm" style="width: auto;" onchange="changePageSize(this.value)">
                    <option value="10" selected="@(Model.PageSize == 10)">10 per page</option>
                    <option value="25" selected="@(Model.PageSize == 25)">25 per page</option>
                    <option value="50" selected="@(Model.PageSize == 50)">50 per page</option>
                    <option value="100" selected="@(Model.PageSize == 100)">100 per page</option>
                </select>
            </div>
        </div>
        <div class="card-body">
            @if (Model.Programs.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover bordered-table mb-0">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Program Name</th>
                                <th>University</th>
                                <th>Level</th>
                                <th>Field</th>
                                <th>Language</th>
                                <th>Duration</th>
                                <th>Capacity</th>
                                <th>Status</th>
                                <th>Created</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var program in Model.Programs)
                            {
                                <tr>
                                    <td class="fw-medium">#@program.Id</td>
                                    <td>
                                        <div class="fw-semibold text-primary-light">@program.NameEnglish</div>
                                        <div class="text-sm text-secondary-light">@program.NameArabic</div>
                                    </td>
                                    <td>
                                        <div class="fw-medium">@program.UniversityNameEnglish</div>
                                        <div class="text-sm text-secondary-light">
                                            <iconify-icon icon="solar:map-point-outline"></iconify-icon> @program.UniversityCity
                                        </div>
                                    </td>
                                    <td><span class="badge bg-info-focus text-info-main">Level @((int)program.Level)</span></td>
                                    <td><span class="badge bg-purple-focus text-purple">@program.TechnicalField</span></td>
                                    <td>
                                        @switch (program.Language)
                                        {
                                            case LanguageCode.English:
                                                <span class="badge bg-primary-focus text-primary-600">English</span>
                                                break;
                                            case LanguageCode.Arabic:
                                                <span class="badge bg-warning-focus text-warning-main">Arabic</span>
                                                break;
                                            case LanguageCode.Both:
                                                <span class="badge bg-success-focus text-success-main">Both</span>
                                                break;
                                        }
                                    </td>
                                    <td>@program.DurationInYears years</td>
                                    <td>@program.Capacity students</td>
                                    <td>
                                        @if (program.IsApprovedByBtecAuthority)
                                        {
                                            <span class="badge bg-success-focus text-success-main px-3 py-2">
                                                <iconify-icon icon="solar:check-circle-outline" class="icon"></iconify-icon>
                                                Approved
                                            </span>
                                            @if (program.ApprovalDate.HasValue)
                                            {
                                                <div class="text-xs text-secondary-light mt-1">@program.ApprovalDate.Value.ToString("MMM dd, yyyy")</div>
                                            }
                                        }
                                        else if (program.IsActive)
                                        {
                                            <span class="badge bg-warning-focus text-warning-main px-3 py-2">
                                                <iconify-icon icon="solar:clock-circle-outline" class="icon"></iconify-icon>
                                                Pending
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-focus text-danger-main px-3 py-2">
                                                <iconify-icon icon="solar:close-circle-outline" class="icon"></iconify-icon>
                                                Rejected
                                            </span>
                                        }
                                    </td>
                                    <td>@program.CreatedAt.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        <a asp-action="Details" asp-route-id="@program.Id"
                                           class="btn btn-sm btn-outline-primary px-3">
                                            <iconify-icon icon="solar:eye-outline"></iconify-icon> View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                @if (Model.TotalPages > 1)
                {
                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <div class="text-sm text-secondary-light">
                            Showing @((Model.CurrentPage - 1) * Model.PageSize + 1) to @Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount) of @Model.TotalCount programs
                        </div>
                        <nav>
                            <ul class="pagination mb-0">
                                <!-- Previous Button -->
                                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" href="@GetPageUrl(Model.CurrentPage - 1)">Previous</a>
                                </li>

                                <!-- Page Numbers -->
                                @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                                {
                                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                        <a class="page-link" href="@GetPageUrl(i)">@i</a>
                                    </li>
                                }

                                <!-- Next Button -->
                                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                    <a class="page-link" href="@GetPageUrl(Model.CurrentPage + 1)">Next</a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5">
                    <iconify-icon icon="solar:document-text-outline" class="text-secondary-light" style="font-size: 64px;"></iconify-icon>
                    <h5 class="mt-3 text-secondary-light">No BTEC Programs Found</h5>
                    <p class="text-secondary-light">Try adjusting your filters or search criteria.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function changePageSize(pageSize) {
            const url = new URL(window.location.href);
            url.searchParams.set('pageSize', pageSize);
            url.searchParams.set('page', '1'); // Reset to first page
            window.location.href = url.toString();
        }
    </script>
}

@functions {
    string GetPageUrl(int page)
    {
        var queryParams = new Dictionary<string, string>();

        if (!string.IsNullOrEmpty(Model.Search))
            queryParams.Add("search", Model.Search);

        if (Model.LevelFilter.HasValue)
            queryParams.Add("level", ((int)Model.LevelFilter.Value).ToString());

        if (!string.IsNullOrEmpty(Model.TechnicalFieldFilter))
            queryParams.Add("technicalField", Model.TechnicalFieldFilter);

        if (Model.ApprovalStatusFilter.HasValue)
            queryParams.Add("approvalStatus", Model.ApprovalStatusFilter.Value.ToString().ToLower());

        if (Model.UniversityIdFilter.HasValue)
            queryParams.Add("universityId", Model.UniversityIdFilter.Value.ToString());

        queryParams.Add("page", page.ToString());
        queryParams.Add("pageSize", Model.PageSize.ToString());

        var queryString = string.Join("&", queryParams.Select(kvp => $"{kvp.Key}={Uri.EscapeDataString(kvp.Value)}"));
        return $"?{queryString}";
    }
}
