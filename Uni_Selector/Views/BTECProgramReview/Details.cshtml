@using Uni_Selector.Models.Enums
@model Uni_Selector.ViewModels.BTECAuthority.BtecProgramDetailsViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Program Details - " + Model.NameEnglish;
}

<div class="dashboard-main-body">
    <!-- Breadcrumb -->
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-24">
        <h6 class="fw-semibold mb-0">BTEC Program Details</h6>
        <ul class="d-flex align-items-center gap-2">
            <li class="fw-medium">
                <a asp-controller="BTECAuthority" asp-action="Dashboard" class="d-flex align-items-center gap-1 hover-text-primary">
                    <iconify-icon icon="solar:home-smile-angle-outline" class="icon text-lg"></iconify-icon>
                    Dashboard
                </a>
            </li>
            <li>-</li>
            <li class="fw-medium">
                <a asp-controller="BTECProgramReview" asp-action="Index" class="hover-text-primary">BTEC Programs</a>
            </li>
            <li>-</li>
            <li class="fw-medium">@Model.NameEnglish</li>
        </ul>
    </div>

    <!-- Status & Action Buttons -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h5 class="mb-2">@Model.NameEnglish</h5>
                    <div class="d-flex gap-2 align-items-center">
                        @if (Model.IsApprovedByBtecAuthority)
                        {
                            <span class="badge bg-success-main px-3 py-2 fs-6">
                                <iconify-icon icon="solar:check-circle-outline" class="icon"></iconify-icon>
                                Approved by BTEC Authority
                            </span>
                            @if (Model.ApprovalDate.HasValue)
                            {
                                <span class="text-sm text-secondary-light">
                                    on @Model.ApprovalDate.Value.ToString("MMMM dd, yyyy")
                                </span>
                            }
                        }
                        else if (Model.IsActive)
                        {
                            <span class="badge bg-warning-main px-3 py-2 fs-6">
                                <iconify-icon icon="solar:clock-circle-outline" class="icon"></iconify-icon>
                                Pending BTEC Authority Approval
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger-main px-3 py-2 fs-6">
                                <iconify-icon icon="solar:close-circle-outline" class="icon"></iconify-icon>
                                Rejected
                            </span>
                        }
                    </div>
                </div>
                <div>
                    @if (!Model.IsApprovedByBtecAuthority && Model.IsActive)
                    {
                        <button type="button" class="btn btn-success me-2" onclick="showApproveModal()">
                            <iconify-icon icon="solar:check-circle-outline" class="icon"></iconify-icon>
                            Approve Program
                        </button>
                        <button type="button" class="btn btn-danger" onclick="showRejectModal()">
                            <iconify-icon icon="solar:close-circle-outline" class="icon"></iconify-icon>
                            Reject Program
                        </button>
                    }
                    <a asp-action="Index" class="btn btn-secondary">
                        <iconify-icon icon="solar:arrow-left-outline"></iconify-icon>
                        Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row gy-4">
        <!-- Left Column - Program Information -->
        <div class="col-lg-8">
            <!-- Program Details Card -->
            <div class="card mb-4">
                <div class="card-header">
                    <h6 class="mb-0">Program Information</h6>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Program Name (English)</label>
                            <p class="form-control-plaintext">@Model.NameEnglish</p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Program Name (Arabic)</label>
                            <p class="form-control-plaintext">@Model.NameArabic</p>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Description</label>
                            <p class="form-control-plaintext">@(Model.Description ?? "No description provided")</p>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">BTEC Level</label>
                            <p class="form-control-plaintext">
                                <span class="badge bg-info-main fs-6">Level @((int)Model.Level)</span>
                            </p>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Technical Field</label>
                            <p class="form-control-plaintext">
                                <span class="badge bg-purple fs-6">@Model.TechnicalField</span>
                            </p>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Language</label>
                            <p class="form-control-plaintext">
                                @switch (Model.Language)
                                {
                                    case LanguageCode.English:
                                        <span class="badge bg-primary-600 fs-6">English</span>
                                        break;
                                    case LanguageCode.Arabic:
                                        <span class="badge bg-warning-main fs-6">Arabic</span>
                                        break;
                                    case LanguageCode.Both:
                                        <span class="badge bg-success-main fs-6">Both</span>
                                        break;
                                }
                            </p>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Duration</label>
                            <p class="form-control-plaintext">@Model.DurationInYears years</p>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Total Credit Hours</label>
                            <p class="form-control-plaintext">@Model.TotalCreditHours hours</p>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Student Capacity</label>
                            <p class="form-control-plaintext">@Model.Capacity students</p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Semester Start Date</label>
                            <p class="form-control-plaintext">@Model.SemesterStartDate.ToString("MMMM dd, yyyy")</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Fees & Costs Card -->
            <div class="card mb-4">
                <div class="card-header">
                    <h6 class="mb-0">Fees & Costs</h6>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Hour Price (Base)</label>
                            <p class="form-control-plaintext text-primary-600 fs-5">@Model.HourPriceBase.ToString("N2") JOD</p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Estimated Total Cost</label>
                            <p class="form-control-plaintext text-success-main fs-5 fw-bold">@Model.EstimatedTotalCost.ToString("N2") JOD</p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Registration Fee (First Semester)</label>
                            <p class="form-control-plaintext">@Model.RegistrationFeeFirstSemester.ToString("N2") JOD</p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Registration Fee (Regular)</label>
                            <p class="form-control-plaintext">@Model.RegistrationFeeRegularSemester.ToString("N2") JOD</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Entry Requirements Card -->
            <div class="card mb-4">
                <div class="card-header">
                    <h6 class="mb-0">Entry Requirements</h6>
                </div>
                <div class="card-body">
                    @if (Model.EntryRequirements.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Minimum GPA</th>
                                        <th>Requires BTEC L2</th>
                                        <th>Requires BTEC L3</th>
                                        <th>Notes</th>
                                        <th>Effective Period</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var req in Model.EntryRequirements)
                                    {
                                        <tr>
                                            <td><span class="badge bg-info-focus text-info-main">@req.MinGPA%</span></td>
                                            <td>
                                                @if (req.RequiresBtecL2)
                                                {
                                                    <iconify-icon icon="solar:check-circle-outline" class="text-success-main"></iconify-icon>
                                                }
                                                else
                                                {
                                                    <iconify-icon icon="solar:close-circle-outline" class="text-danger-main"></iconify-icon>
                                                }
                                            </td>
                                            <td>
                                                @if (req.RequiresBtecL3)
                                                {
                                                    <iconify-icon icon="solar:check-circle-outline" class="text-success-main"></iconify-icon>
                                                }
                                                else
                                                {
                                                    <iconify-icon icon="solar:close-circle-outline" class="text-danger-main"></iconify-icon>
                                                }
                                            </td>
                                            <td>@(req.Notes ?? "N/A")</td>
                                            <td>
                                                @if (req.EffectiveFrom.HasValue)
                                                {
                                                    <text>@req.EffectiveFrom.Value.ToString("MMM yyyy")</text>
                                                    if (req.EffectiveTo.HasValue)
                                                    {
                                                        <text> - @req.EffectiveTo.Value.ToString("MMM yyyy")</text>
                                                    }
                                                }
                                                else
                                                {
                                                    <text>Always</text>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-secondary-light">No entry requirements specified.</p>
                    }
                </div>
            </div>

            <!-- Approval Notes Card -->
            @if (Model.IsApprovedByBtecAuthority && !string.IsNullOrEmpty(Model.ApprovalNotes))
            {
                <div class="card mb-4">
                    <div class="card-header">
                        <h6 class="mb-0">
                            <iconify-icon icon="solar:check-circle-outline" class="text-success-main"></iconify-icon>
                            Approval Notes
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-success mb-0">
                            <p class="mb-0">@Model.ApprovalNotes</p>
                        </div>
                    </div>
                </div>
            }

            <!-- Rejection Reason Card -->
            @if (!Model.IsApprovedByBtecAuthority && !string.IsNullOrEmpty(Model.RejectionReason))
            {
                <div class="card mb-4">
                    <div class="card-header">
                        <h6 class="mb-0">
                            <iconify-icon icon="solar:close-circle-outline" class="text-danger-main"></iconify-icon>
                            Rejection Reason
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-danger mb-0">
                            <p class="mb-0">@Model.RejectionReason</p>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Right Column - University & Statistics -->
        <div class="col-lg-4">
            <!-- University Information Card -->
            <div class="card mb-4">
                <div class="card-header">
                    <h6 class="mb-0">University Information</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-sm">University Name (EN)</label>
                        <p class="mb-1 fs-6 fw-medium">@Model.UniversityNameEnglish</p>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-sm">University Name (AR)</label>
                        <p class="mb-1">@Model.UniversityNameArabic</p>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-sm">Location</label>
                        <p class="mb-1">
                            <iconify-icon icon="solar:map-point-outline" class="text-primary-600"></iconify-icon>
                            @Model.UniversityCity, @Model.UniversityProvince
                        </p>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-sm">Contact</label>
                        <p class="mb-1">
                            <iconify-icon icon="solar:phone-outline" class="text-primary-600"></iconify-icon>
                            @Model.UniversityPhone
                        </p>
                        <p class="mb-1">
                            <iconify-icon icon="solar:letter-outline" class="text-primary-600"></iconify-icon>
                            @Model.UniversityEmail
                        </p>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.UniversityWebsite))
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold text-sm">Website</label>
                            <p class="mb-1">
                                <a href="@Model.UniversityWebsite" target="_blank" class="text-primary-600">
                                    <iconify-icon icon="solar:link-outline"></iconify-icon>
                                    Visit Website
                                </a>
                            </p>
                        </div>
                    }
                </div>
            </div>

            <!-- Statistics Card -->
            <div class="card mb-4">
                <div class="card-header">
                    <h6 class="mb-0">Program Statistics</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3 pb-3 border-bottom">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-secondary-light">Total Applications</span>
                            <span class="fs-5 fw-bold text-primary-600">@Model.TotalApplications</span>
                        </div>
                    </div>
                    <div class="mb-3 pb-3 border-bottom">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-secondary-light">Approved Applications</span>
                            <span class="fs-5 fw-bold text-success-main">@Model.ApprovedApplications</span>
                        </div>
                    </div>
                    <div class="mb-0">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-secondary-light">Enrolled Students</span>
                            <span class="fs-5 fw-bold text-info-main">@Model.EnrolledStudents</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Timeline Card -->
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">Timeline</h6>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-3">
                            <div class="d-flex gap-2">
                                <iconify-icon icon="solar:calendar-add-outline" class="text-primary-600 mt-1"></iconify-icon>
                                <div>
                                    <div class="text-sm fw-semibold">Created</div>
                                    <div class="text-xs text-secondary-light">@Model.CreatedAt.ToString("MMMM dd, yyyy HH:mm")</div>
                                </div>
                            </div>
                        </li>
                        @if (Model.UpdatedAt.HasValue)
                        {
                            <li class="mb-3">
                                <div class="d-flex gap-2">
                                    <iconify-icon icon="solar:pen-outline" class="text-warning-main mt-1"></iconify-icon>
                                    <div>
                                        <div class="text-sm fw-semibold">Last Updated</div>
                                        <div class="text-xs text-secondary-light">@Model.UpdatedAt.Value.ToString("MMMM dd, yyyy HH:mm")</div>
                                    </div>
                                </div>
                            </li>
                        }
                        @if (Model.ApprovalDate.HasValue)
                        {
                            <li>
                                <div class="d-flex gap-2">
                                    <iconify-icon icon="solar:check-circle-outline" class="text-success-main mt-1"></iconify-icon>
                                    <div>
                                        <div class="text-sm fw-semibold">@(Model.IsApprovedByBtecAuthority ? "Approved" : "Rejected")</div>
                                        <div class="text-xs text-secondary-light">@Model.ApprovalDate.Value.ToString("MMMM dd, yyyy HH:mm")</div>
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Approve Modal -->
<div class="modal fade" id="approveModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="approveForm">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">
                        <iconify-icon icon="solar:check-circle-outline" class="text-success-main"></iconify-icon>
                        Approve BTEC Program
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-success">
                        <h6 class="mb-2">You are about to approve:</h6>
                        <p class="mb-0 fw-semibold">@Model.NameEnglish</p>
                        <p class="mb-0 text-sm">@Model.UniversityNameEnglish</p>
                    </div>
                    <div class="mb-3">
                        <label for="approvalNotes" class="form-label">Approval Notes <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="approvalNotes" name="approvalNotes" rows="4"
                                  placeholder="Enter approval notes and any additional comments..." required></textarea>
                        <div class="form-text">These notes will be sent to the university representatives.</div>
                    </div>
                    <div class="alert alert-info mb-0">
                        <small>
                            <iconify-icon icon="solar:info-circle-outline"></iconify-icon>
                            University representatives will be notified via email and in-app notification.
                        </small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">
                        <iconify-icon icon="solar:check-circle-outline"></iconify-icon>
                        Approve Program
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Reject Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="rejectForm">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">
                        <iconify-icon icon="solar:close-circle-outline" class="text-danger-main"></iconify-icon>
                        Reject BTEC Program
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-danger">
                        <h6 class="mb-2">You are about to reject:</h6>
                        <p class="mb-0 fw-semibold">@Model.NameEnglish</p>
                        <p class="mb-0 text-sm">@Model.UniversityNameEnglish</p>
                    </div>
                    <div class="mb-3">
                        <label for="rejectionReason" class="form-label">Rejection Reason <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="rejectionReason" name="rejectionReason" rows="4"
                                  placeholder="Enter detailed reason for rejection..." required></textarea>
                        <div class="form-text">Provide specific reasons why the program does not meet BTEC standards.</div>
                    </div>
                    <div class="alert alert-warning mb-0">
                        <small>
                            <iconify-icon icon="solar:danger-triangle-outline"></iconify-icon>
                            University will be notified with the rejection reason and can resubmit after addressing the issues.
                        </small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">
                        <iconify-icon icon="solar:close-circle-outline"></iconify-icon>
                        Reject Program
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        function showApproveModal() {
            const modal = new bootstrap.Modal(document.getElementById('approveModal'));
            modal.show();
        }

        function showRejectModal() {
            const modal = new bootstrap.Modal(document.getElementById('rejectModal'));
            modal.show();
        }

        // Handle Approve Form Submission
        document.getElementById('approveForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const approvalNotes = document.getElementById('approvalNotes').value.trim();

            if (!approvalNotes) {
                Swal.fire({
                    icon: 'error',
                    title: 'Approval Notes Required',
                    text: 'Please enter approval notes before approving the program.'
                });
                return;
            }

            const formData = new FormData();
            formData.append('approvalNotes', approvalNotes);
            formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

            try {
                const response = await fetch('@Url.Action("Approve", "BTECProgramReview", new { id = Model.Id })', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Program Approved!',
                        text: 'The BTEC program has been approved successfully. University representatives have been notified.',
                        confirmButtonText: 'OK'
                    }).then(() => {
                        window.location.reload();
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Approval Failed',
                        text: result.message || 'An error occurred while approving the program.'
                    });
                }
            } catch (error) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'An unexpected error occurred. Please try again.'
                });
            }
        });

        // Handle Reject Form Submission
        document.getElementById('rejectForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const rejectionReason = document.getElementById('rejectionReason').value.trim();

            if (!rejectionReason) {
                Swal.fire({
                    icon: 'error',
                    title: 'Rejection Reason Required',
                    text: 'Please enter a detailed rejection reason before rejecting the program.'
                });
                return;
            }

            // Confirm rejection
            const confirmResult = await Swal.fire({
                icon: 'warning',
                title: 'Confirm Rejection',
                text: 'Are you sure you want to reject this BTEC program? The university will be notified.',
                showCancelButton: true,
                confirmButtonText: 'Yes, Reject',
                cancelButtonText: 'Cancel',
                confirmButtonColor: '#dc3545'
            });

            if (!confirmResult.isConfirmed) {
                return;
            }

            const formData = new FormData();
            formData.append('rejectionReason', rejectionReason);
            formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

            try {
                const response = await fetch('@Url.Action("Reject", "BTECProgramReview", new { id = Model.Id })', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Program Rejected',
                        text: 'The BTEC program has been rejected. University representatives have been notified.',
                        confirmButtonText: 'OK'
                    }).then(() => {
                        window.location.reload();
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Rejection Failed',
                        text: result.message || 'An error occurred while rejecting the program.'
                    });
                }
            } catch (error) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'An unexpected error occurred. Please try again.'
                });
            }
        });
    </script>
}
