@using Uni_Selector.ViewModels.Recommendations
@model RecommendationsListViewModel

@{
    ViewData["Title"] = "My Recommendations";
}

<!-- Breadcrumb -->
<section class="bg-whiteColor dark:bg-whiteColor-dark py-30px">
    <div class="container 3xl:container-secondary-lg 4xl:container mx-auto">
        <div class="flex justify-between items-center">
            <h2 class="text-2xl font-bold text-blackColor dark:text-blackColor-dark">
                University Recommendations
            </h2>
            <ul class="flex gap-1 text-sm text-contentColor dark:text-contentColor-dark">
                <li><a asp-controller="Account" asp-action="Me" class="hover:text-primaryColor">Profile</a></li>
                <li>/</li>
                <li>Recommendations</li>
            </ul>
        </div>
    </div>
</section>

<!-- Main Content -->
<section class="py-50px">
    <div class="container 3xl:container-secondary-lg 4xl:container mx-auto">

        <!-- Action Buttons -->
        <div class="flex flex-wrap justify-between items-center mb-8 gap-4">
            <div class="flex gap-3">
                <a asp-action="Generate" asp-controller="Recommendations" class="px-6 py-3 bg-primaryColor text-white rounded-md hover:bg-opacity-90 transition">
                    <i class="icofont-refresh"></i> Generate New Recommendations
                </a>
                @if (Model.Recommendations.Any())
                {
                    <a asp-action="Export" class="px-6 py-3 bg-secondaryColor text-white rounded-md hover:bg-opacity-90 transition">
                        <i class="icofont-file-pdf"></i> Export to PDF
                    </a>
                }
            </div>
            <div class="text-sm text-contentColor dark:text-contentColor-dark">
                <span class="font-semibold">@Model.TotalCount</span> recommendations found
            </div>
        </div>

        @if (!Model.Recommendations.Any())
        {
            <!-- No Recommendations Message -->
            <div class="text-center py-20">
                <div class="bg-whiteColor dark:bg-whiteColor-dark shadow-md rounded-lg p-10">
                    <i class="icofont-search-document text-6xl text-primaryColor mb-4"></i>
                    <h3 class="text-2xl font-bold text-blackColor dark:text-blackColor-dark mb-3">No Recommendations Yet</h3>
                    <p class="text-contentColor dark:text-contentColor-dark mb-6">
                        Click the button above to generate personalized university recommendations based on your profile.
                    </p>
                    <a asp-action="Generate" class="px-8 py-3 bg-primaryColor text-white rounded-md hover:bg-opacity-90 inline-block">
                        <i class="icofont-plus"></i> Generate Recommendations Now
                    </a>
                </div>
            </div>
        }
        else
        {
            <!-- Filters -->
            <form method="get" asp-action="Index" class="bg-whiteColor dark:bg-whiteColor-dark shadow-md rounded-lg p-6 mb-8">
                <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                    <div>
                        <label class="block mb-2 font-medium text-sm">Search</label>
                        <input type="text" name="searchTerm" value="@Model.SearchTerm" placeholder="Search programs..."
                               class="w-full py-2 px-4 border border-borderColor dark:border-borderColor-dark rounded-md focus:outline-none focus:ring-2 focus:ring-primaryColor" />
                    </div>
                    <div>
                        <label class="block mb-2 font-medium text-sm">University</label>
                        <input type="text" name="universityFilter" value="@Model.UniversityFilter" placeholder="University name..."
                               class="w-full py-2 px-4 border border-borderColor dark:border-borderColor-dark rounded-md focus:outline-none focus:ring-2 focus:ring-primaryColor" />
                    </div>
                    <div>
                        <label class="block mb-2 font-medium text-sm">Language</label>
                        <select name="languageFilter" class="w-full py-2 px-4 border border-borderColor dark:border-borderColor-dark rounded-md focus:outline-none focus:ring-2 focus:ring-primaryColor">
                            <option value="">All Languages</option>
                            <option value="English" selected="@(Model.LanguageFilter == "English")">English</option>
                            <option value="Arabic" selected="@(Model.LanguageFilter == "Arabic")">Arabic</option>
                            <option value="Both" selected="@(Model.LanguageFilter == "Both")">Both</option>
                        </select>
                    </div>
                    <div>
                        <label class="block mb-2 font-medium text-sm">Sort By</label>
                        <select name="sortBy" class="w-full py-2 px-4 border border-borderColor dark:border-borderColor-dark rounded-md focus:outline-none focus:ring-2 focus:ring-primaryColor">
                            <option value="score" selected="@(Model.SortBy == "score")">Best Match</option>
                            <option value="cost" selected="@(Model.SortBy == "cost")">Lowest Cost</option>
                            <option value="distance" selected="@(Model.SortBy == "distance")">Nearest</option>
                            <option value="newest" selected="@(Model.SortBy == "newest")">Newest</option>
                        </select>
                    </div>
                </div>
                <div class="flex justify-end gap-2 mt-4">
                    <a asp-action="Index" class="px-6 py-2 bg-gray-300 text-gray-700 rounded-md hover:bg-gray-400">Clear</a>
                    <button type="submit" class="px-6 py-2 bg-primaryColor text-white rounded-md hover:bg-opacity-90">
                        <i class="icofont-search"></i> Apply Filters
                    </button>
                </div>
            </form>

            <!-- Recommendations Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var recommendation in Model.Recommendations)
                {
                    <div class="bg-whiteColor dark:bg-whiteColor-dark shadow-md rounded-lg overflow-hidden hover:shadow-xl transition group">
                        <!-- Score Badge -->
                        <div class="relative">
                            <div class="absolute top-3 right-3 z-10">
                                <span class="px-3 py-1 @recommendation.ScoreClass text-white text-sm font-bold rounded-full shadow-lg">
                                    @recommendation.Score.ToString("F1")%
                                </span>
                            </div>
                            @if (!recommendation.IsViewed)
                            {
                                <div class="absolute top-3 left-3 z-10">
                                    <span class="px-3 py-1 bg-red-500 text-white text-xs font-bold rounded-full">New</span>
                                </div>
                            }
                            @if (recommendation.HasApplication)
                            {
                                <div class="absolute bottom-3 left-3 z-10">
                                    <span class="px-3 py-1 bg-purple-600 text-white text-xs font-bold rounded-full">
                                        <i class="icofont-check-circled"></i> Applied
                                    </span>
                                </div>
                            }

                            <!-- University Logo/Image -->
                            <div class="h-48 bg-gradient-to-br from-blue-100 to-purple-100 flex items-center justify-center p-4">
                                @if (!string.IsNullOrEmpty(recommendation.UniversityLogo))
                                {
                                    <img src="@recommendation.UniversityLogo" alt="@recommendation.UniversityName" class="max-h-full max-w-full object-contain" />
                                }
                                else
                                {
                                    <div class="text-4xl text-primaryColor">
                                        <i class="icofont-university"></i>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Content -->
                        <div class="p-5">
                            <!-- Program Type Badge -->
                            <div class="flex items-center gap-2 mb-3">
                                @if (recommendation.IsBtec)
                                {
                                    <span class="px-2 py-1 bg-orange-100 text-orange-800 text-xs font-semibold rounded">BTEC</span>
                                }
                                else
                                {
                                    <span class="px-2 py-1 bg-blue-100 text-blue-800 text-xs font-semibold rounded">Regular</span>
                                }
                                <span class="px-2 py-1 bg-gray-100 text-gray-800 text-xs font-semibold rounded">@recommendation.Language</span>
                            </div>

                            <!-- Program Name -->
                            <h3 class="text-lg font-bold text-blackColor dark:text-blackColor-dark mb-2 line-clamp-2 group-hover:text-primaryColor transition">
                                @recommendation.ProgramName
                            </h3>

                            <!-- University Name -->
                            <p class="text-sm text-contentColor dark:text-contentColor-dark mb-3 flex items-center">
                                <i class="icofont-building-alt mr-2 text-primaryColor"></i>
                                @recommendation.UniversityName
                            </p>

                            <!-- Stats -->
                            <div class="grid grid-cols-2 gap-3 mb-4 pt-3 border-t border-borderColor dark:border-borderColor-dark">
                                <div class="flex items-center text-sm">
                                    <i class="icofont-wallet mr-2 text-secondaryColor"></i>
                                    <span class="font-semibold">@recommendation.EstimatedCost.ToString("F0") JOD</span>
                                </div>
                                @if (recommendation.DistanceKm.HasValue)
                                {
                                    <div class="flex items-center text-sm">
                                        <i class="icofont-location-pin mr-2 text-primaryColor"></i>
                                        <span>@recommendation.DistanceKm.Value.ToString("F0") km</span>
                                    </div>
                                }
                            </div>

                            <!-- Match Label -->
                            <div class="mb-4">
                                <span class="text-xs font-medium @recommendation.ScoreClass">
                                    <i class="icofont-star"></i> @recommendation.ScoreLabel
                                </span>
                            </div>

                            <!-- Action Buttons -->
                            <div class="flex gap-2">
                                <a asp-action="Details" asp-route-id="@recommendation.Id"
                                   class="flex-1 text-center px-4 py-2 bg-primaryColor text-white rounded-md hover:bg-opacity-90 transition text-sm">
                                    <i class="icofont-eye"></i> View Details
                                </a>
                                @if (!recommendation.HasApplication)
                                {
                                    <button onclick="applyToProgram(@recommendation.Id)"
                                            class="px-4 py-2 bg-secondaryColor text-white rounded-md hover:bg-opacity-90 transition text-sm">
                                        <i class="icofont-plus"></i> Apply
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <div class="flex justify-center items-center gap-2 mt-10">
                    @if (Model.HasPreviousPage)
                    {
                        <a asp-action="Index"
                           asp-route-pageNumber="@(Model.PageNumber - 1)"
                           asp-route-searchTerm="@Model.SearchTerm"
                           asp-route-universityFilter="@Model.UniversityFilter"
                           asp-route-languageFilter="@Model.LanguageFilter"
                           asp-route-sortBy="@Model.SortBy"
                           class="px-4 py-2 bg-whiteColor dark:bg-whiteColor-dark border border-borderColor dark:border-borderColor-dark rounded-md hover:bg-primaryColor hover:text-white transition">
                            <i class="icofont-rounded-left"></i> Previous
                        </a>
                    }

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <a asp-action="Index"
                           asp-route-pageNumber="@i"
                           asp-route-searchTerm="@Model.SearchTerm"
                           asp-route-universityFilter="@Model.UniversityFilter"
                           asp-route-languageFilter="@Model.LanguageFilter"
                           asp-route-sortBy="@Model.SortBy"
                           class="px-4 py-2 @(i == Model.PageNumber ? "bg-primaryColor text-white" : "bg-whiteColor dark:bg-whiteColor-dark border border-borderColor dark:border-borderColor-dark") rounded-md hover:bg-primaryColor hover:text-white transition">
                            @i
                        </a>
                    }

                    @if (Model.HasNextPage)
                    {
                        <a asp-action="Index"
                           asp-route-pageNumber="@(Model.PageNumber + 1)"
                           asp-route-searchTerm="@Model.SearchTerm"
                           asp-route-universityFilter="@Model.UniversityFilter"
                           asp-route-languageFilter="@Model.LanguageFilter"
                           asp-route-sortBy="@Model.SortBy"
                           class="px-4 py-2 bg-whiteColor dark:bg-whiteColor-dark border border-borderColor dark:border-borderColor-dark rounded-md hover:bg-primaryColor hover:text-white transition">
                            Next <i class="icofont-rounded-right"></i>
                        </a>
                    }
                </div>
            }
        }
    </div>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function applyToProgram(recommendationId) {
            Swal.fire({
                title: 'Apply to this Program?',
                text: "You will be redirected to the application form.",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#3b82f6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, apply!',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    // Redirect to application form
                    window.location.href = '/Applications/Create?recommendationId=' + recommendationId;
                }
            });
        }
    </script>
}
