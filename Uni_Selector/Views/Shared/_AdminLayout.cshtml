<!DOCTYPE html>
<html lang="en" data-theme="light">


<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Uni Selector</title>
    <link rel="icon" type="image/png" href="~/assets/images/favicon.ico" sizes="16x16">
    <!-- remix icon font css  -->
    <link rel="stylesheet" href="~/adminAssets/css/remixicon.css">
    <!-- BootStrap css -->
    <link rel="stylesheet" href="~/adminAssets/css/lib/bootstrap.min.css">
    <!-- Apex Chart css -->
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
    <!-- Data Table css -->
    <link rel="stylesheet" href="~/adminAssets/css/lib/dataTables.min.css">
    <!-- Text Editor css -->
    <link rel="stylesheet" href="~/adminAssets/css/lib/editor-katex.min.css">
    <link rel="stylesheet" href="~/adminAssets/css/lib/editor.atom-one-dark.min.css">
    <link rel="stylesheet" href="~/adminAssets/css/lib/editor.quill.snow.css">
    <!-- Date picker css -->
    <link rel="stylesheet" href="~/adminAssets/css/lib/flatpickr.min.css">
    <!-- Calendar css -->
    <link rel="stylesheet" href="~/adminAssets/css/lib/full-calendar.css">
    <!-- Vector Map css -->
    <link rel="stylesheet" href="~/adminAssets/css/lib/jquery-jvectormap-2.0.5.css">
    <!-- Popup css -->
    <link rel="stylesheet" href="~/adminAssets/css/lib/magnific-popup.css">
    <!-- Slick Slider css -->
    <link rel="stylesheet" href="~/adminAssets/css/lib/slick.css">
    <!-- prism css -->
    <link rel="stylesheet" href="~/adminAssets/css/lib/prism.css">
    <!-- file upload css -->
    <link rel="stylesheet" href="~/adminAssets/css/lib/file-upload.css">

    <link rel="stylesheet" href="~/adminAssets/css/lib/audioplayer.css">
    <!-- main css -->
    <link rel="stylesheet" href="~/adminAssets/css/style.css">

    @RenderSection("Styles", required: false)
</head>

<body>
    <partial name="~/Views/Shared/Partials/_Sidebar.cshtml" />

    <main class="dashboard-main">
        <partial name="~/Views/Shared/Partials/_Navbar.cshtml" />

        <div class="dashboard-main-body">
            @{
                string BreadcrumbTitle = ViewData.ContainsKey("title") ? ViewData["title"] as string ?? "" : "";
                string BreadcrumbSubTitle = ViewData.ContainsKey("subTitle") ? ViewData["subTitle"] as string ?? "" : "";
            }
@*             <partial name="~/Views/Shared/Partials/_Breadcrumb.cshtml" view-data='new ViewDataDictionary(ViewData) { { "BreadcrumbTitle", BreadcrumbTitle }, { "BreadcrumbSubTitle", BreadcrumbSubTitle } }' />
 *@            @RenderBody()
        </div>

        <partial name="~/Views/Shared/Partials/_Footer.cshtml" />
    </main>
    <partial name="~/Views/Shared/Partials/_Scripts.cshtml" />

    @* Render the script if it exists in ViewData *@
    @if (ViewData.ContainsKey("script"))
    {
        @Html.Raw(ViewData["script"] as string)
    }

    @RenderSection("Scripts", required: false)

</body>

</html>


