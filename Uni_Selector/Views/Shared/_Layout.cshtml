                                                0
                                            </span>
                                        </a>

                                        <!-- dropdown menu -->
                                        <div class="dropdown absolute top-full right-0 lg:right-8 z-medium hidden opacity-0"
                                             id="notificationDropdown"
                                             style="transition: 0.3s">
