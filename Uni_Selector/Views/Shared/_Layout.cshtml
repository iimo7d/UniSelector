                            Find Your Perfect <span class="text-primaryColor">University</span>
                        </h4>
                        <p class="text-whiteColor text-opacity-65">
                            Smart recommendations for Jordanian students to choose the right private university.
                        </p>
                    </div>
                    <div data-aos="fade-up">
                        @if (!SignInManager.IsSignedIn(User))
                        {
                            <div class="ml-auto max-w-form-xl md:max-w-form-md lg:max-w-form-lg xl:max-w-form-xl">
                                <a asp-controller="Account" asp-action="Login" asp-route-tab="register" class="inline-block px-30px py-15px bg-primaryColor hover:bg-secondaryColor text-whiteColor font-semibold rounded text-lg transition-all duration-300">
                                    <i class="icofont-user-alt-7 mr-2" aria-hidden="true"></i> Get Started Now
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </section>

            <!-- Footer main -->
            <section>
                <div class="grid grid-cols-12 gap-30px md:gap-y-5 lg:gap-y-0 pt-60px pb-50px md:pt-30px md:pb-30px lg:pt-110px lg:pb-20">
                    <!-- Left -->
                    <div class="col-start-1 col-span-12 md:col-span-6 lg:col-span-4 mr-30px" data-aos="fade-up">
                        <h4 class="text-size-22 font-bold text-whiteColor mb-3">About Uni Selector</h4>
                        <p class="text-base lg:text-sm 2xl:text-base text-darkgray mb-30px leading-1.8 2xl:leading-1.8">
                            Smart University Platform helps Jordanian students make informed decisions about their higher education by matching them with the most suitable private universities based on their academic profile and preferences.
                        </p>
                        <div class="flex items-center">
                            <div>
                                <i class="icofont-support text-3xl text-whiteColor h-78px w-78px bg-primaryColor leading-78px mr-22px block text-center rounded" aria-hidden="true"></i>
                            </div>
                            <div>
                                <h6 class="text-lg text-whiteColor font-medium leading-29px">SUPPORT HOURS</h6>
                                <p class="text-sm text-whiteColor text-opacity-60 mb-1">Sun - Thu (9.00 AM - 5.00 PM)</p>
                                <p class="text-sm text-whiteColor text-opacity-60">Friday & Saturday - Closed</p>
                            </div>
                        </div>
                    </div>

                    <!-- Middle 1 -->
                    <div class="col-start-1 col-span-12 md:col-start-7 lg:col-start-5 md:col-span-6 lg:col-span-2" data-aos="fade-up">
                        <h4 class="text-size-22 font-bold text-whiteColor mb-3">Quick Links</h4>
                        <ul class="flex flex-col gap-y-3">
                            <li><a asp-controller="Home" asp-action="Index" class="text-darkgray relative hover:text-primaryColor"><i class="icofont-simple-right mr-1" aria-hidden="true"></i> Home</a></li>
                            <li><a asp-controller="Home" asp-action="Universities" class="text-darkgray relative hover:text-primaryColor"><i class="icofont-simple-right mr-1" aria-hidden="true"></i> Universities</a></li>
                            <li><a asp-controller="Home" asp-action="About" class="text-darkgray relative hover:text-primaryColor"><i class="icofont-simple-right mr-1" aria-hidden="true"></i> About Us</a></li>
                            <li><a asp-controller="Home" asp-action="FAQ" class="text-darkgray relative hover:text-primaryColor"><i class="icofont-simple-right mr-1" aria-hidden="true"></i> FAQ</a></li>
                        </ul>
                    </div>
                    <!-- Right -->
                    <div class="col-start-1 col-span-12 md:col-start-7 lg:col-start-10 md:col-span-6 lg:col-span-3 pl-0 2xl:pl-50px" data-aos="fade-up">
                        <h4 class="text-size-22 font-bold text-whiteColor mb-3">Contact Info</h4>
                        <ul class="flex flex-col gap-y-4">
                            <li class="flex items-start gap-3">
                                <i class="icofont-location-pin text-primaryColor text-xl mt-1" aria-hidden="true"></i>
                                <div>
                                    <h6 class="text-size-15 text-whiteColor font-semibold">Address</h6>
                                    <p class="text-sm text-darkgray">Amman, Jordan</p>
                                </div>
                            </li>
                            <li class="flex items-start gap-3">
                                <i class="icofont-phone text-primaryColor text-xl mt-1" aria-hidden="true"></i>
                                <div>
                                    <h6 class="text-size-15 text-whiteColor font-semibold">Phone</h6>
                                    <p class="text-sm text-darkgray">+962 6 123 4567</p>
                                </div>
                            </li>
                            <li class="flex items-start gap-3">
                                <i class="icofont-email text-primaryColor text-xl mt-1" aria-hidden="true"></i>
                                <div>
                                    <h6 class="text-size-15 text-whiteColor font-semibold">Email</h6>
                                    <p class="text-sm text-darkgray">support@@uniselector.jo</p>
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>
            </section>

            <!-- Footer copyright -->
            <div>
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-5 lg:gap-30px pt-10 items-center border-t border-darkcolor">
                    <div class="lg:col-start-1 lg:col-span-3">
                        <a asp-controller="Home" asp-action="Index"><img src="~/assets/images/logo/logo_2.png" alt="Uni Selector"></a>
                    </div>
                    <div class="lg:col-start-4 lg:col-span-6 text-center">
                        <p class="text-whiteColor text-sm">
                            Copyright © <span class="text-primaryColor">@DateTime.Now.Year</span> Smart University Platform. All Rights Reserved.
                        </p>
                    </div>
                    <div class="lg:col-start-10 lg:col-span-3">
                        <ul class="flex gap-3 lg:gap-2 2xl:gap-3 lg:justify-end">
                            <li><a href="#" class="w-40.19px lg:w-35px 2xl:w-40.19px h-37px lg:h-35px 2xl:h-37px leading-37px lg:leading-35px 2xl:leading-37px text-whiteColor bg-whiteColor bg-opacity-10 hover:bg-primaryColor text-center rounded transition-all duration-300" aria-label="Facebook"><i class="icofont-facebook"></i></a></li>
                            <li><a href="#" class="w-40.19px lg:w-35px 2xl:w-40.19px h-37px lg:h-35px 2xl:h-37px leading-37px lg:leading-35px 2xl:leading-37px text-whiteColor bg-whiteColor bg-opacity-10 hover:bg-primaryColor text-center rounded transition-all duration-300" aria-label="Twitter"><i class="icofont-twitter"></i></a></li>
                            <li><a href="#" class="w-40.19px lg:w-35px 2xl:w-40.19px h-37px lg:h-35px 2xl:h-37px leading-37px lg:leading-35px 2xl:leading-37px text-whiteColor bg-whiteColor bg-opacity-10 hover:bg-primaryColor text-center rounded transition-all duration-300" aria-label="Instagram"><i class="icofont-instagram"></i></a></li>
                            <li><a href="#" class="w-40.19px lg:w-35px 2xl:w-40.19px h-37px lg:h-35px 2xl:h-37px leading-37px lg:leading-35px 2xl:leading-37px text-whiteColor bg-whiteColor bg-opacity-10 hover:bg-primaryColor text-center rounded transition-all duration-300" aria-label="LinkedIn"><i class="icofont-linkedin"></i></a></li>
                        </ul>
                    </div>
                </div>
            </div>
