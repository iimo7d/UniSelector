@model Uni_Selector.ViewModels.ProgramManagement.BtecEntryRequirementsViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "BTEC Entry Requirements";
}

<div class="dashboard-main-body">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-24">
        <h6 class="fw-semibold mb-0">BTEC Entry Requirements</h6>
        <ul class="d-flex align-items-center gap-2">
            <li class="fw-medium">
                <a asp-controller="UniversityRep" asp-action="Index" class="d-flex align-items-center gap-1 hover-text-primary">
                    <iconify-icon icon="solar:home-smile-angle-outline" class="icon text-lg"></iconify-icon>
                    Dashboard
                </a>
            </li>
            <li>-</li>
            <li class="fw-medium">
                <a asp-action="Index">BTEC Programs</a>
            </li>
            <li>-</li>
            <li class="fw-medium">Entry Requirements</li>
        </ul>
    </div>

    <div class="card h-100 p-0 radius-12">
        <div class="card-header border-bottom bg-base py-16 px-24 d-flex align-items-center justify-content-between">
            <div>
                <h6 class="text-lg fw-semibold mb-2">@Model.ProgramNameEnglish</h6>
                <p class="text-sm text-secondary-light mb-0">@Model.ProgramNameArabic</p>
            </div>
            @if (Model.CanManagePrograms)
            {
                <button type="button" class="btn btn-primary text-sm btn-sm px-12 py-12 radius-8 d-flex align-items-center gap-2"
                        data-bs-toggle="modal" data-bs-target="#addRequirementModal">
                    <iconify-icon icon="ic:baseline-plus" class="icon text-xl line-height-1"></iconify-icon>
                    Add Requirement
                </button>
            }
        </div>

        <div class="card-body p-24">
            @if (Model.EntryRequirements.Any())
            {
                <div class="table-responsive">
                    <table class="table bordered-table mb-0">
                        <thead>
                            <tr>
                                <th>Min GPA (%)</th>
                                <th>BTEC Level 2</th>
                                <th>BTEC Level 3</th>
                                <th>Effective From</th>
                                <th>Effective To</th>
                                <th>Notes</th>
                                @if (Model.CanManagePrograms)
                                {
                                    <th class="text-center">Actions</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var req in Model.EntryRequirements)
                            {
                                <tr>
                                    <td>
                                        <span class="fw-bold text-primary-600">@req.MinGPA%</span>
                                    </td>
                                    <td>
                                        @if (req.RequiresBtecL2)
                                        {
                                            <span class="text-success-main">
                                                <iconify-icon icon="mdi:check-circle"></iconify-icon> Required
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-secondary-light">
                                                <iconify-icon icon="mdi:close-circle"></iconify-icon> Not Required
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        @if (req.RequiresBtecL3)
                                        {
                                            <span class="text-success-main">
                                                <iconify-icon icon="mdi:check-circle"></iconify-icon> Required
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-secondary-light">
                                                <iconify-icon icon="mdi:close-circle"></iconify-icon> Not Required
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        @if (req.EffectiveFrom.HasValue)
                                        {
                                            @req.EffectiveFrom.Value.ToString("MMM dd, yyyy")
                                        }
                                        else
                                        {
                                            <span class="text-secondary-light">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (req.EffectiveTo.HasValue)
                                        {
                                            @req.EffectiveTo.Value.ToString("MMM dd, yyyy")
                                        }
                                        else
                                        {
                                            <span class="text-secondary-light">Active</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(req.Notes))
                                        {
                                            <span class="text-sm">@req.Notes</span>
                                        }
                                        else
                                        {
                                            <span class="text-secondary-light">-</span>
                                        }
                                    </td>
                                    @if (Model.CanManagePrograms)
                                    {
                                        <td class="text-center">
                                            <button type="button" onclick="deleteRequirement(@req.Id)"
                                                    class="w-32-px h-32-px bg-danger-focus text-danger-main rounded-circle d-inline-flex align-items-center justify-content-center border-0"
                                                    title="Delete">
                                                <iconify-icon icon="mingcute:delete-2-line"></iconify-icon>
                                            </button>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-40">
                    <iconify-icon icon="mdi:file-document-alert-outline" class="text-xxl text-secondary-light mb-12"></iconify-icon>
                    <p class="text-secondary-light mb-16">No entry requirements added yet.</p>
                    @if (Model.CanManagePrograms)
                    {
                        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addRequirementModal">
                            <iconify-icon icon="ic:baseline-plus" class="icon"></iconify-icon> Add First Requirement
                        </button>
                    }
                </div>
            }
        </div>
    </div>
</div>

<!-- Add BTEC Entry Requirement Modal -->
<div class="modal fade" id="addRequirementModal" tabindex="-1" aria-labelledby="addRequirementModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addRequirementModalLabel">Add BTEC Entry Requirement</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="addRequirementForm">
                <div class="modal-body">
                    <div class="alert alert-danger d-none" id="validationErrors"></div>

                    <div class="mb-20">
                        <label class="form-label fw-semibold text-primary-light text-sm mb-8">
                            Minimum GPA (%) <span class="text-danger-600">*</span>
                        </label>
                        <input type="number" step="0.01" min="0" max="100" name="MinGPA" class="form-control radius-8" required placeholder="e.g., 60">
                        <small class="text-secondary-light">Enter the minimum GPA percentage required (0-100)</small>
                    </div>

                    <div class="mb-20">
                        <label class="form-label fw-semibold text-primary-light text-sm mb-8">
                            BTEC Prerequisites
                        </label>
                        <div class="card border">
                            <div class="card-body p-16">
                                <div class="form-check mb-12">
                                    <input type="checkbox" name="RequiresBtecL2" value="true" class="form-check-input" id="requiresBtecL2" checked>
                                    <label class="form-check-label" for="requiresBtecL2">
                                        <strong>Requires BTEC Level 2</strong>
                                        <p class="text-sm text-secondary-light mb-0">Student must have completed BTEC Level 2</p>
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input type="checkbox" name="RequiresBtecL3" value="true" class="form-check-input" id="requiresBtecL3" checked>
                                    <label class="form-check-label" for="requiresBtecL3">
                                        <strong>Requires BTEC Level 3</strong>
                                        <p class="text-sm text-secondary-light mb-0">Student must have completed BTEC Level 3</p>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-20">
                        <label class="form-label fw-semibold text-primary-light text-sm mb-8">
                            Effective From
                        </label>
                        <input type="date" name="EffectiveFrom" class="form-control radius-8">
                        <small class="text-secondary-light">Leave empty to make effective immediately</small>
                    </div>

                    <div class="mb-20">
                        <label class="form-label fw-semibold text-primary-light text-sm mb-8">
                            Notes
                        </label>
                        <textarea name="Notes" class="form-control radius-8" rows="3" maxlength="500" placeholder="Optional notes about this requirement (e.g., 'Accepts Tawjihi graduates with minimum 60%')"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" id="submitBtn">
                        <span class="spinner-border spinner-border-sm d-none" id="submitSpinner"></span>
                        Add Requirement
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Handle form submission
        $('#addRequirementForm').on('submit', function(e) {
            e.preventDefault();

            const formData = $(this).serialize();
            const submitBtn = $('#submitBtn');
            const spinner = $('#submitSpinner');

            // Disable button and show spinner
            submitBtn.prop('disabled', true);
            spinner.removeClass('d-none');
            $('#validationErrors').addClass('d-none');

            $.ajax({
                url: '@Url.Action("AddEntryRequirement", new { id = Model.ProgramId })',
                type: 'POST',
                data: formData,
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Success!',
                            text: response.message,
                            timer: 2000,
                            showConfirmButton: false
                        }).then(() => {
                            location.reload();
                        });
                    } else {
                        $('#validationErrors').text(response.message).removeClass('d-none');
                        submitBtn.prop('disabled', false);
                        spinner.addClass('d-none');
                    }
                },
                error: function() {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error!',
                        text: 'Failed to add entry requirement. Please try again.'
                    });
                    submitBtn.prop('disabled', false);
                    spinner.addClass('d-none');
                }
            });
        });

        // Delete requirement function
        function deleteRequirement(reqId) {
            Swal.fire({
                title: 'Are you sure?',
                text: "Do you want to delete this entry requirement?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/UniversityRep/BTECPrograms/@Model.ProgramId/EntryRequirements/' + reqId + '/Delete',
                        type: 'POST',
                        headers: {
                            'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Deleted!',
                                    text: response.message,
                                    timer: 2000,
                                    showConfirmButton: false
                                }).then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Error!',
                                    text: response.message
                                });
                            }
                        },
                        error: function() {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error!',
                                text: 'Failed to delete entry requirement.'
                            });
                        }
                    });
                }
            });
        }

        @if (TempData["SuccessMessage"] != null)
        {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: 'Success!',
                    text: '@TempData["SuccessMessage"]',
                    timer: 3000,
                    showConfirmButton: false
                });
                </text>
        }

        @if (TempData["ErrorMessage"] != null)
        {
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Error!',
                    text: '@TempData["ErrorMessage"]',
                    timer: 3000,
                    showConfirmButton: false
                });
                </text>
        }
    </script>
}

<!-- Hidden CSRF Token -->
@Html.AntiForgeryToken()
