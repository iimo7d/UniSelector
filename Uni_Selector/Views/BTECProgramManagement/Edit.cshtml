@using Uni_Selector.Models.Enums
@model Uni_Selector.ViewModels.ProgramManagement.EditBtecProgramViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Edit BTEC Program";
}

<div class="dashboard-main-body">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-24">
        <h6 class="fw-semibold mb-0">Edit BTEC Program</h6>
        <ul class="d-flex align-items-center gap-2">
            <li class="fw-medium">
                <a asp-controller="UniversityRep" asp-action="Index" class="d-flex align-items-center gap-1 hover-text-primary">
                    <iconify-icon icon="solar:home-smile-angle-outline" class="icon text-lg"></iconify-icon>
                    Dashboard
                </a>
            </li>
            <li>-</li>
            <li class="fw-medium">
                <a asp-action="Index">BTEC Programs</a>
            </li>
            <li>-</li>
            <li class="fw-medium">Edit</li>
        </ul>
    </div>

    <div class="card h-100 p-0 radius-12">
        <div class="card-body p-24">
            <div class="row justify-content-center">
                <div class="col-xxl-10 col-xl-10 col-lg-12">
                    <div class="card border">
                        <div class="card-body">
                            @if (!Model.IsApprovedByBtecAuthority)
                            {
                                <div class="alert alert-warning mb-20">
                                    <strong>Pending Approval:</strong> This program is awaiting BTEC Authority approval.
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-success mb-20">
                                    <strong>Approved:</strong> This program has been approved by BTEC Authority.
                                </div>
                            }

                            <form asp-action="Edit" method="post" id="editBtecForm">
                                <input asp-for="Id" type="hidden" />
                                <input asp-for="IsApprovedByBtecAuthority" type="hidden" />
                                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                                <!-- Program Names -->
                                <div class="row">
                                    <div class="col-md-6 mb-20">
                                        <label asp-for="NameEnglish" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                            Program Name (English) <span class="text-danger-600">*</span>
                                        </label>
                                        <input asp-for="NameEnglish" class="form-control radius-8">
                                        <span asp-validation-for="NameEnglish" class="text-danger"></span>
                                    </div>

                                    <div class="col-md-6 mb-20">
                                        <label asp-for="NameArabic" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                            Program Name (Arabic) <span class="text-danger-600">*</span>
                                        </label>
                                        <input asp-for="NameArabic" class="form-control radius-8">
                                        <span asp-validation-for="NameArabic" class="text-danger"></span>
                                    </div>
                                </div>

                                <!-- Description -->
                                <div class="mb-20">
                                    <label asp-for="Description" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                        Description
                                    </label>
                                    <textarea asp-for="Description" class="form-control radius-8" rows="3"></textarea>
                                    <span asp-validation-for="Description" class="text-danger"></span>
                                </div>

                                <!-- Level and Technical Field -->
                                <div class="row">
                                    <div class="col-md-6 mb-20">
                                        <label asp-for="Level" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                            BTEC Level <span class="text-danger-600">*</span>
                                        </label>
                                        <select asp-for="Level" class="form-control radius-8 form-select" asp-items="Html.GetEnumSelectList<BtecLevel>()">
                                        </select>
                                        <span asp-validation-for="Level" class="text-danger"></span>
                                    </div>

                                    <div class="col-md-6 mb-20">
                                        <label asp-for="TechnicalField" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                            Technical Field <span class="text-danger-600">*</span>
                                        </label>
                                        <input asp-for="TechnicalField" class="form-control radius-8">
                                        <span asp-validation-for="TechnicalField" class="text-danger"></span>
                                    </div>
                                </div>

                                <!-- Language and Duration -->
                                <div class="row">
                                    <div class="col-md-4 mb-20">
                                        <label asp-for="Language" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                            Language of Instruction <span class="text-danger-600">*</span>
                                        </label>
                                        <select asp-for="Language" class="form-control radius-8 form-select" asp-items="Html.GetEnumSelectList<LanguageCode>()">
                                        </select>
                                        <span asp-validation-for="Language" class="text-danger"></span>
                                    </div>

                                    <div class="col-md-4 mb-20">
                                        <label asp-for="DurationInYears" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                            Duration (Years) <span class="text-danger-600">*</span>
                                        </label>
                                        <input asp-for="DurationInYears" type="number" class="form-control radius-8" min="1" max="10">
                                        <span asp-validation-for="DurationInYears" class="text-danger"></span>
                                    </div>

                                    <div class="col-md-4 mb-20">
                                        <label asp-for="TotalCreditHours" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                            Total Credit Hours <span class="text-danger-600">*</span>
                                        </label>
                                        <input asp-for="TotalCreditHours" type="number" class="form-control radius-8" min="30" max="300">
                                        <span asp-validation-for="TotalCreditHours" class="text-danger"></span>
                                    </div>
                                </div>

                                <!-- Semester Start Date -->
                                <div class="mb-20">
                                    <label asp-for="SemesterStartDate" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                        Semester Start Date <span class="text-danger-600">*</span>
                                    </label>
                                    <input asp-for="SemesterStartDate" type="date" class="form-control radius-8">
                                    <span asp-validation-for="SemesterStartDate" class="text-danger"></span>
                                </div>

                                <!-- Financial Information -->
                                <hr class="my-20">
                                <h6 class="mb-16 fw-semibold">Financial Information</h6>
                                <div class="row">
                                    <div class="col-md-4 mb-20">
                                        <label asp-for="HourPriceBase" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                            Hour Price (JOD) <span class="text-danger-600">*</span>
                                        </label>
                                        <input asp-for="HourPriceBase" type="number" step="0.01" class="form-control radius-8">
                                        <span asp-validation-for="HourPriceBase" class="text-danger"></span>
                                    </div>

                                    <div class="col-md-4 mb-20">
                                        <label asp-for="RegistrationFeeFirstSemester" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                            First Semester Fee (JOD) <span class="text-danger-600">*</span>
                                        </label>
                                        <input asp-for="RegistrationFeeFirstSemester" type="number" step="0.01" class="form-control radius-8">
                                        <span asp-validation-for="RegistrationFeeFirstSemester" class="text-danger"></span>
                                    </div>

                                    <div class="col-md-4 mb-20">
                                        <label asp-for="RegistrationFeeRegularSemester" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                            Regular Semester Fee (JOD) <span class="text-danger-600">*</span>
                                        </label>
                                        <input asp-for="RegistrationFeeRegularSemester" type="number" step="0.01" class="form-control radius-8">
                                        <span asp-validation-for="RegistrationFeeRegularSemester" class="text-danger"></span>
                                    </div>
                                </div>

                                <!-- Capacity -->
                                <div class="mb-20">
                                    <label asp-for="Capacity" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                        Student Capacity <span class="text-danger-600">*</span>
                                    </label>
                                    <input asp-for="Capacity" type="number" class="form-control radius-8" min="0" max="1000">
                                    <span asp-validation-for="Capacity" class="text-danger"></span>
                                </div>

                                <div class="d-flex align-items-center justify-content-center gap-3 mt-24">
                                    <a asp-action="Details" asp-route-id="@Model.Id" class="border border-danger-600 bg-hover-danger-200 text-danger-600 text-md px-56 py-11 radius-8 text-decoration-none">
                                        Cancel
                                    </a>
                                    <button type="button" id="submitBtn" class="btn btn-primary border border-primary-600 text-md px-56 py-12 radius-8">
                                        Update Program
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function() {
            $('#submitBtn').on('click', function(e) {
                e.preventDefault();
                var form = document.getElementById('editBtecForm');

                if (!form.checkValidity()) {
                    form.reportValidity();
                    return;
                }

                Swal.fire({
                    title: 'Update BTEC Program?',
                    text: "Are you sure you want to update this program?",
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'Yes, update it!'
                }).then((result) => {
                    if (result.isConfirmed) {
                        Swal.fire({
                            title: 'Updating...',
                            text: 'Please wait',
                            allowOutsideClick: false,
                            showConfirmButton: false,
                            willOpen: () => {
                                Swal.showLoading();
                            }
                        });
                        setTimeout(() => form.submit(), 300);
                    }
                });
            });
        });
    </script>
}
