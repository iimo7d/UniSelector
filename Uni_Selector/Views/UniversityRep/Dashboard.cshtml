@model Uni_Selector.ViewModels.UniversityReps.UniversityRepDashboardViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "University Representative Dashboard";
}

<div class="dashboard-main-body">
    <!-- Page Header -->
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-24">
        <h6 class="fw-semibold mb-0">@Model.UniversityName - Dashboard</h6>
        <ul class="d-flex align-items-center gap-2">
            <li class="fw-medium">
                <a asp-action="Dashboard" class="d-flex align-items-center gap-1 hover-text-primary">
                    <iconify-icon icon="solar:home-smile-angle-outline" class="icon text-lg"></iconify-icon>
                    Dashboard
                </a>
            </li>
            <li>-</li>
            <li class="fw-medium">@Model.RepresentativeName</li>
        </ul>
    </div>

    <!-- KPI Cards Row 1 -->
    <div class="row gy-4">
        <!-- Total Applications -->
        <div class="col-xxl-3 col-sm-6">
            <div class="card shadow-none border bg-gradient-start-1 h-100">
                <div class="card-body p-20">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                        <div>
                            <p class="fw-medium text-primary-light mb-1">Total Applications</p>
                            <h6 class="mb-0">@Model.TotalApplications</h6>
                        </div>
                        <div class="w-50-px h-50-px bg-primary-600 rounded-circle d-flex justify-content-center align-items-center">
                            <iconify-icon icon="solar:document-text-bold" class="text-white text-2xl mb-0"></iconify-icon>
                        </div>
                    </div>
                    <p class="fw-medium text-sm text-primary-light mt-12 mb-0 d-flex align-items-center gap-2">
                        <span class="d-inline-flex align-items-center gap-1 text-success-main">
                            <iconify-icon icon="bxs:up-arrow" class="text-xs"></iconify-icon> @Model.ApplicationsThisMonth
                        </span>
                        This Month
                    </p>
                </div>
            </div>
        </div>

        <!-- Pending Applications -->
        <div class="col-xxl-3 col-sm-6">
            <div class="card shadow-none border bg-gradient-start-2 h-100">
                <div class="card-body p-20">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                        <div>
                            <p class="fw-medium text-primary-light mb-1">Pending Review</p>
                            <h6 class="mb-0">@Model.PendingApplications</h6>
                        </div>
                        <div class="w-50-px h-50-px bg-warning-main rounded-circle d-flex justify-content-center align-items-center">
                            <iconify-icon icon="solar:clock-circle-bold" class="text-white text-2xl mb-0"></iconify-icon>
                        </div>
                    </div>
                    <p class="fw-medium text-sm text-primary-light mt-12 mb-0">
                        <span class="text-warning-main">Needs Attention</span>
                    </p>
                </div>
            </div>
        </div>

        <!-- Approved Applications -->
        <div class="col-xxl-3 col-sm-6">
            <div class="card shadow-none border bg-gradient-start-3 h-100">
                <div class="card-body p-20">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                        <div>
                            <p class="fw-medium text-primary-light mb-1">Approved</p>
                            <h6 class="mb-0">@Model.ApprovedApplications</h6>
                        </div>
                        <div class="w-50-px h-50-px bg-success-main rounded-circle d-flex justify-content-center align-items-center">
                            <iconify-icon icon="solar:check-circle-bold" class="text-white text-2xl mb-0"></iconify-icon>
                        </div>
                    </div>
                    <p class="fw-medium text-sm text-primary-light mt-12 mb-0">
                        @{
                            var successRate = Model.TotalApplications > 0 ? (Model.ApprovedApplications * 100.0 / Model.TotalApplications).ToString("F1") : "0";
                        }
                        <span class="text-success-main">Success Rate: @successRate%</span>
                    </p>
                </div>
            </div>
        </div>

        <!-- Active Programs -->
        <div class="col-xxl-3 col-sm-6">
            <div class="card shadow-none border bg-gradient-start-5 h-100">
                <div class="card-body p-20">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                        <div>
                            <p class="fw-medium text-primary-light mb-1">Active Programs</p>
                            <h6 class="mb-0">@(Model.ActivePrograms + Model.ActiveBtecPrograms)</h6>
                        </div>
                        <div class="w-50-px h-50-px bg-cyan rounded-circle d-flex justify-content-center align-items-center">
                            <iconify-icon icon="solar:book-2-bold" class="text-white text-2xl mb-0"></iconify-icon>
                        </div>
                    </div>
                    <p class="fw-medium text-sm text-primary-light mt-12 mb-0">
                        <span class="text-cyan">@Model.ActivePrograms Uni + @Model.ActiveBtecPrograms BTEC</span>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- KPI Cards Row 2 -->
    <div class="row gy-4 mt-1">
        <!-- Total Commission -->
        <div class="col-xxl-3 col-sm-6">
            <div class="card shadow-none border bg-gradient-start-4 h-100">
                <div class="card-body p-20">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                        <div>
                            <p class="fw-medium text-primary-light mb-1">Total Commission</p>
                            <h6 class="mb-0">JOD @Model.TotalCommissionEarned.ToString("N2")</h6>
                        </div>
                        <div class="w-50-px h-50-px bg-success-main rounded-circle d-flex justify-content-center align-items-center">
                            <iconify-icon icon="solar:wallet-money-bold" class="text-white text-2xl mb-0"></iconify-icon>
                        </div>
                    </div>
                    <p class="fw-medium text-sm text-primary-light mt-12 mb-0">
                        <span class="text-success-main">Total Earned</span>
                    </p>
                </div>
            </div>
        </div>

        <!-- Pending Settlement -->
        <div class="col-xxl-3 col-sm-6">
            <div class="card shadow-none border bg-gradient-start-1 h-100">
                <div class="card-body p-20">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                        <div>
                            <p class="fw-medium text-primary-light mb-1">Pending Settlement</p>
                            <h6 class="mb-0">JOD @Model.PendingSettlement.ToString("N2")</h6>
                        </div>
                        <div class="w-50-px h-50-px bg-orange rounded-circle d-flex justify-content-center align-items-center">
                            <iconify-icon icon="solar:dollar-minimalistic-bold" class="text-white text-2xl mb-0"></iconify-icon>
                        </div>
                    </div>
                    <p class="fw-medium text-sm text-primary-light mt-12 mb-0">
                        <span class="text-warning-main">Awaiting Payment</span>
                    </p>
                </div>
            </div>
        </div>

        <!-- Rejected -->
        <div class="col-xxl-3 col-sm-6">
            <div class="card shadow-none border bg-gradient-start-3 h-100">
                <div class="card-body p-20">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                        <div>
                            <p class="fw-medium text-primary-light mb-1">Rejected</p>
                            <h6 class="mb-0">@Model.RejectedApplications</h6>
                        </div>
                        <div class="w-50-px h-50-px bg-red rounded-circle d-flex justify-content-center align-items-center">
                            <iconify-icon icon="solar:close-circle-bold" class="text-white text-2xl mb-0"></iconify-icon>
                        </div>
                    </div>
                    <p class="fw-medium text-sm text-primary-light mt-12 mb-0">
                        <span class="text-danger-main">Not Accepted</span>
                    </p>
                </div>
            </div>
        </div>

        <!-- Last Month -->
        <div class="col-xxl-3 col-sm-6">
            <div class="card shadow-none border bg-gradient-start-2 h-100">
                <div class="card-body p-20">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                        <div>
                            <p class="fw-medium text-primary-light mb-1">Last Month</p>
                            <h6 class="mb-0">@Model.ApplicationsLastMonth</h6>
                        </div>
                        <div class="w-50-px h-50-px bg-purple rounded-circle d-flex justify-content-center align-items-center">
                            <iconify-icon icon="solar:calendar-bold" class="text-white text-2xl mb-0"></iconify-icon>
                        </div>
                    </div>
                    @{
                        var change = Model.ApplicationsLastMonth > 0 ? ((Model.ApplicationsThisMonth - Model.ApplicationsLastMonth) * 100.0 / Model.ApplicationsLastMonth).ToString("F1") : "0";
                        var isPositive = Model.ApplicationsThisMonth >= Model.ApplicationsLastMonth;
                    }
                    <p class="fw-medium text-sm text-primary-light mt-12 mb-0">
                        <span class="@(isPositive ? "text-success-main" : "text-danger-main")">
                            @(isPositive ? "+" : "")@change%
                        </span>
                        vs Last Month
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Section -->
    <div class="row gy-4 mt-1">
        <!-- Monthly Trend Line Chart -->
        <div class="col-xxl-8 col-xl-12">
            <div class="card h-100 p-0">
                <div class="card-header border-bottom bg-base py-16 px-24 d-flex align-items-center flex-wrap gap-3 justify-content-between">
                    <h6 class="text-lg fw-semibold mb-0">Application Trend (Last 6 Months)</h6>
                    <a asp-action="ApplicationAnalytics" asp-controller="UniversityRep" class="text-primary-600 hover-text-primary d-flex align-items-center gap-1">
                        View Details
                        <iconify-icon icon="solar:alt-arrow-right-linear" class="icon"></iconify-icon>
                    </a>
                </div>
                <div class="card-body p-24">
                    <div id="monthlyTrendChart" class="apexcharts-tooltip-style-1"></div>
                </div>
            </div>
        </div>

        <!-- Status Distribution Pie Chart -->
        <div class="col-xxl-4 col-xl-6">
            <div class="card h-100 p-0">
                <div class="card-header border-bottom bg-base py-16 px-24">
                    <h6 class="text-lg fw-semibold mb-0">Application Status</h6>
                </div>
                <div class="card-body p-24 text-center">
                    <div id="statusPieChart" class="apexcharts-tooltip-z-none"></div>
                    <ul class="d-flex flex-wrap align-items-center justify-content-center mt-3 gap-3">
                        @{
                            var colors = new[] { "primary-600", "success-600", "danger-600", "warning-600", "info-600", "purple" };
                            var index = 0;
                        }
                        @foreach (var status in Model.ApplicationStatusBreakdown)
                        {
                            <li class="d-flex align-items-center gap-2">
                                <span class="w-12-px h-12-px radius-2 bg-@colors[index % colors.Length]"></span>
                                <span class="text-secondary-light text-sm fw-normal">
                                    @status.Key:
                                    <span class="text-primary-light fw-semibold">@status.Value</span>
                                </span>
                            </li>
                            index++;
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Applications Table -->
    <div class="row gy-4 mt-1">
        <div class="col-12">
            <div class="card h-100 p-0">
                <div class="card-header border-bottom bg-base py-16 px-24 d-flex align-items-center flex-wrap gap-3 justify-content-between">
                    <h6 class="text-lg fw-semibold mb-0">Recent Applications</h6>
                    <a asp-action="Index" asp-controller="Applications" class="text-primary-600 hover-text-primary d-flex align-items-center gap-1">
                        View All
                        <iconify-icon icon="solar:alt-arrow-right-linear" class="icon"></iconify-icon>
                    </a>
                </div>
                <div class="card-body p-24">
                    <div class="table-responsive scroll-sm">
                        <table class="table bordered-table mb-0">
                            <thead>
                                <tr>
                                    <th scope="col">Application #</th>
                                    <th scope="col">Student</th>
                                    <th scope="col">Program</th>
                                    <th scope="col">Type</th>
                                    <th scope="col">Status</th>
                                    <th scope="col">Date</th>
                                    <th scope="col" class="text-center">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var app in Model.RecentApplications)
                                {
                                    <tr>
                                        <td><span class="text-sm fw-semibold">@app.ApplicationNumber</span></td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="flex-grow-1">
                                                    <h6 class="text-md mb-0 fw-medium">@app.StudentName</h6>
                                                    <span class="text-sm text-secondary-light fw-medium">@app.StudentEmail</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td><span class="text-sm">@app.ProgramName</span></td>
                                        <td>
                                            @if (app.ProgramType == "BTEC Program")
                                            {
                                                <span class="bg-info-focus text-info-main px-16 py-4 rounded-pill fw-medium text-sm">BTEC</span>
                                            }
                                            else
                                            {
                                                <span class="bg-primary-focus text-primary-600 px-16 py-4 rounded-pill fw-medium text-sm">University</span>
                                            }
                                        </td>
                                        <td>
                                            @switch (app.Status.ToString())
                                            {
                                                case "Pending":
                                                    <span class="bg-warning-focus text-warning-main px-24 py-4 rounded-pill fw-medium text-sm">Pending</span>
                                                    break;
                                                case "Approved":
                                                    <span class="bg-success-focus text-success-main px-24 py-4 rounded-pill fw-medium text-sm">Approved</span>
                                                    break;
                                                case "Rejected":
                                                    <span class="bg-danger-focus text-danger-main px-24 py-4 rounded-pill fw-medium text-sm">Rejected</span>
                                                    break;
                                                case "UnderReview":
                                                    <span class="bg-info-focus text-info-main px-24 py-4 rounded-pill fw-medium text-sm">Under Review</span>
                                                    break;
                                                default:
                                                    <span class="bg-neutral-200 text-neutral-600 px-24 py-4 rounded-pill fw-medium text-sm">@app.Status</span>
                                                    break;
                                            }
                                        </td>
                                        <td><span class="text-sm">@app.ApplicationDate.ToString("MMM dd, yyyy")</span></td>
                                        <td class="text-center">
                                            <a asp-controller="Applications" asp-action="Details" asp-route-id="@app.Id" class="w-32-px h-32-px bg-primary-light text-primary-600 rounded-circle d-inline-flex align-items-center justify-content-center">
                                                <iconify-icon icon="iconamoon:eye-light"></iconify-icon>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row gy-4 mt-1">
        <div class="col-12">
            <div class="card h-100 p-0">
                <div class="card-header border-bottom bg-base py-16 px-24">
                    <h6 class="text-lg fw-semibold mb-0">Quick Actions</h6>
                </div>
                <div class="card-body p-24">
                    <div class="d-flex flex-wrap gap-3">
                        <a asp-action="ApplicationAnalytics" asp-controller="UniversityRep" class="btn btn-primary-600 radius-8 px-20 py-11">
                            <iconify-icon icon="solar:chart-2-bold" class="icon text-xl line-height-1"></iconify-icon>
                            Application Analytics
                        </a>
                        <a asp-action="ProgramAnalytics" asp-controller="UniversityRep" class="btn btn-success-600 radius-8 px-20 py-11">
                            <iconify-icon icon="solar:pie-chart-bold" class="icon text-xl line-height-1"></iconify-icon>
                            Program Analytics
                        </a>
                        <a asp-action="Demographics" asp-controller="UniversityRep" class="btn btn-info-600 radius-8 px-20 py-11">
                            <iconify-icon icon="solar:users-group-rounded-bold" class="icon text-xl line-height-1"></iconify-icon>
                            Demographics
                        </a>
                        <a asp-action="ExportAnalytics" asp-route-reportType="comprehensive" class="btn btn-warning-600 radius-8 px-20 py-11">
                            <iconify-icon icon="solar:download-minimalistic-bold" class="icon text-xl line-height-1"></iconify-icon>
                            Export Reports
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/assets/js/lib/apexcharts.min.js"></script>
    <script>
        // Monthly Trend Line Chart
        var monthlyTrendOptions = {
            series: [{
                name: 'Applications',
                data: [@string.Join(",", Model.MonthlyApplicationsTrend.Select(m => m.Count))]
            }],
            chart: {
                height: 350,
                type: 'area',
                toolbar: {
                    show: true
                },
                zoom: {
                    enabled: true
                }
            },
            colors: ['#487FFF'],
            dataLabels: {
                enabled: false
            },
            stroke: {
                curve: 'smooth',
                width: 2
            },
            xaxis: {
                categories: [@Html.Raw(string.Join(",", Model.MonthlyApplicationsTrend.Select(m => $"'{m.Month}'")))]
            },
            yaxis: {
                title: {
                    text: 'Number of Applications'
                }
            },
            fill: {
                type: 'gradient',
                gradient: {
                    shadeIntensity: 1,
                    opacityFrom: 0.4,
                    opacityTo: 0.1,
                    stops: [0, 90, 100]
                }
            },
            tooltip: {
                x: {
                    format: 'MMM yyyy'
                }
            }
        };

        var monthlyTrendChart = new ApexCharts(document.querySelector("#monthlyTrendChart"), monthlyTrendOptions);
        monthlyTrendChart.render();

        // Status Pie Chart
        var statusPieOptions = {
            series: [@string.Join(",", Model.ApplicationStatusBreakdown.Values)],
            chart: {
                type: 'donut',
                height: 280
            },
            labels: [@Html.Raw(string.Join(",", Model.ApplicationStatusBreakdown.Keys.Select(k => $"'{k}'")))],
            colors: ['#487FFF', '#45B369', '#EA5455', '#FF9F43', '#00CFE8', '#7367F0'],
            legend: {
                show: false
            },
            plotOptions: {
                pie: {
                    donut: {
                        size: '70%',
                        labels: {
                            show: true,
                            total: {
                                show: true,
                                label: 'Total',
                                fontSize: '16px',
                                fontWeight: 600,
                                formatter: function (w) {
                                    return w.globals.seriesTotals.reduce((a, b) => {
                                        return a + b
                                    }, 0)
                                }
                            }
                        }
                    }
                }
            },
            responsive: [{
                breakpoint: 480,
                options: {
                    chart: {
                        width: 200
                    },
                    legend: {
                        position: 'bottom'
                    }
                }
            }]
        };

        var statusPieChart = new ApexCharts(document.querySelector("#statusPieChart"), statusPieOptions);
        statusPieChart.render();
    </script>
}
