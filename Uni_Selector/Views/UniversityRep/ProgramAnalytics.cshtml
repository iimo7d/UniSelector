@model Uni_Selector.ViewModels.UniversityReps.ProgramAnalyticsViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Program Analytics";
}

<div class="dashboard-main-body">
    <!-- Page Header -->
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-24">
        <h6 class="fw-semibold mb-0">Program Analytics</h6>
        <ul class="d-flex align-items-center gap-2">
            <li class="fw-medium">
                <a asp-action="Dashboard" class="d-flex align-items-center gap-1 hover-text-primary">
                    <iconify-icon icon="solar:home-smile-angle-outline" class="icon text-lg"></iconify-icon>
                    Dashboard
                </a>
            </li>
            <li>-</li>
            <li class="fw-medium">Analytics / Programs</li>
        </ul>
    </div>

    <!-- Summary Cards -->
    <div class="row gy-4">
        <div class="col-xxl-3 col-sm-6">
            <div class="card shadow-none border bg-gradient-start-1 h-100">
                <div class="card-body p-20">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                        <div>
                            <p class="fw-medium text-primary-light mb-1">Total Programs</p>
                            <h6 class="mb-0">@Model.TotalPrograms</h6>
                        </div>
                        <div class="w-50-px h-50-px bg-primary-600 rounded-circle d-flex justify-content-center align-items-center">
                            <iconify-icon icon="solar:book-2-bold" class="text-white text-2xl mb-0"></iconify-icon>
                        </div>
                    </div>
                    <p class="fw-medium text-sm text-primary-light mt-12 mb-0">
                        <span class="text-primary-600">University + BTEC</span>
                    </p>
                </div>
            </div>
        </div>

        <div class="col-xxl-3 col-sm-6">
            <div class="card shadow-none border bg-gradient-start-3 h-100">
                <div class="card-body p-20">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                        <div>
                            <p class="fw-medium text-primary-light mb-1">Active Programs</p>
                            <h6 class="mb-0">@Model.ActivePrograms</h6>
                        </div>
                        <div class="w-50-px h-50-px bg-success-main rounded-circle d-flex justify-content-center align-items-center">
                            <iconify-icon icon="solar:check-circle-bold" class="text-white text-2xl mb-0"></iconify-icon>
                        </div>
                    </div>
                    <p class="fw-medium text-sm text-primary-light mt-12 mb-0">
                        <span class="text-success-main">Currently Accepting</span>
                    </p>
                </div>
            </div>
        </div>

        <div class="col-xxl-3 col-sm-6">
            <div class="card shadow-none border bg-gradient-start-2 h-100">
                <div class="card-body p-20">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                        <div>
                            <p class="fw-medium text-primary-light mb-1">Total Applications</p>
                            <h6 class="mb-0">@Model.TotalApplications</h6>
                        </div>
                        <div class="w-50-px h-50-px bg-warning-main rounded-circle d-flex justify-content-center align-items-center">
                            <iconify-icon icon="solar:document-text-bold" class="text-white text-2xl mb-0"></iconify-icon>
                        </div>
                    </div>
                    <p class="fw-medium text-sm text-primary-light mt-12 mb-0">
                        <span class="text-warning-main">All Programs Combined</span>
                    </p>
                </div>
            </div>
        </div>

        <div class="col-xxl-3 col-sm-6">
            <div class="card shadow-none border bg-gradient-start-5 h-100">
                <div class="card-body p-20">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                        <div>
                            <p class="fw-medium text-primary-light mb-1">Avg Conversion Rate</p>
                            <h6 class="mb-0">@Model.AverageConversionRate.ToString("F1")%</h6>
                        </div>
                        <div class="w-50-px h-50-px bg-info-main rounded-circle d-flex justify-content-center align-items-center">
                            <iconify-icon icon="solar:chart-2-bold" class="text-white text-2xl mb-0"></iconify-icon>
                        </div>
                    </div>
                    <p class="fw-medium text-sm text-primary-light mt-12 mb-0">
                        <span class="text-info-main">Recommendation → Application</span>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Distribution Charts -->
    <div class="row gy-4 mt-1">
        <!-- Degree Distribution -->
        <div class="col-md-6">
            <div class="card h-100 p-0">
                <div class="card-header border-bottom bg-base py-16 px-24">
                    <h6 class="text-lg fw-semibold mb-0">Degree Distribution</h6>
                </div>
                <div class="card-body p-24 text-center">
                    <div id="degreeDistributionChart" class="apexcharts-tooltip-z-none"></div>
                    <ul class="d-flex flex-wrap align-items-center justify-content-center mt-3 gap-3">
                        @{
                            var degreeColors = new[] { "primary-600", "success-600", "warning-600", "danger-600", "info-600" };
                            var degreeIndex = 0;
                        }
                        @foreach (var degree in Model.DegreeDistribution)
                        {
                            <li class="d-flex align-items-center gap-2">
                                <span class="w-12-px h-12-px radius-2 bg-@degreeColors[degreeIndex % degreeColors.Length]"></span>
                                <span class="text-secondary-light text-sm fw-normal">
                                    @degree.Key:
                                    <span class="text-primary-light fw-semibold">@degree.Value</span>
                                </span>
                            </li>
                            degreeIndex++;
                        }
                    </ul>
                </div>
            </div>
        </div>

        <!-- Language Distribution -->
        <div class="col-md-6">
            <div class="card h-100 p-0">
                <div class="card-header border-bottom bg-base py-16 px-24">
                    <h6 class="text-lg fw-semibold mb-0">Language Distribution</h6>
                </div>
                <div class="card-body p-24">
                    <div id="languageDistributionChart"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Program Performance Table -->
    <div class="row gy-4 mt-1">
        <div class="col-12">
            <div class="card h-100 p-0">
                <div class="card-header border-bottom bg-base py-16 px-24">
                    <h6 class="text-lg fw-semibold mb-0">Program Performance Details</h6>
                </div>
                <div class="card-body p-24">
                    <div class="table-responsive scroll-sm">
                        <table class="table bordered-table mb-0">
                            <thead>
                                <tr>
                                    <th scope="col">Program Name</th>
                                    <th scope="col">Type</th>
                                    <th scope="col">Degree</th>
                                    <th scope="col" class="text-center">Applications</th>
                                    <th scope="col" class="text-center">Approved</th>
                                    <th scope="col" class="text-center">Recommendations</th>
                                    <th scope="col" class="text-center">Conversion</th>
                                    <th scope="col" class="text-center">Capacity Used</th>
                                    <th scope="col" class="text-center">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var program in Model.Programs)
                                {
                                    <tr>
                                        <td>
                                            <div>
                                                <h6 class="text-md mb-0 fw-semibold">@program.ProgramName</h6>
                                                <span class="text-sm text-secondary-light">@program.Language</span>
                                            </div>
                                        </td>
                                        <td>
                                            @if (program.ProgramType == "BTEC Program")
                                            {
                                                <span class="bg-info-focus text-info-main px-16 py-4 rounded-pill fw-medium text-sm">BTEC</span>
                                            }
                                            else
                                            {
                                                <span class="bg-primary-focus text-primary-600 px-16 py-4 rounded-pill fw-medium text-sm">University</span>
                                            }
                                        </td>
                                        <td><span class="text-sm fw-medium">@program.Degree</span></td>
                                        <td class="text-center">
                                            <span class="text-primary-light fw-semibold">@program.TotalApplications</span>
                                        </td>
                                        <td class="text-center">
                                            <span class="bg-success-focus text-success-main px-16 py-4 rounded-pill fw-medium text-sm">@program.ApprovedApplications</span>
                                        </td>
                                        <td class="text-center">
                                            <span class="text-secondary-light fw-medium">@program.RecommendationCount</span>
                                        </td>
                                        <td class="text-center">
                                            <div class="progress w-100 bg-primary-50 rounded-pill h-8-px" role="progressbar">
                                                <div class="progress-bar bg-primary-600 rounded-pill" style="width: @(program.ConversionRate > 100 ? 100 : program.ConversionRate)%"></div>
                                            </div>
                                            <span class="text-sm text-secondary-light fw-medium mt-4">@program.ConversionRate.ToString("F1")%</span>
                                        </td>
                                        <td class="text-center">
                                            <div class="progress w-100 bg-warning-50 rounded-pill h-8-px" role="progressbar">
                                                <div class="progress-bar bg-warning-600 rounded-pill" style="width: @(program.CapacityUtilization > 100 ? 100 : program.CapacityUtilization)%"></div>
                                            </div>
                                            <span class="text-sm text-secondary-light fw-medium mt-4">@program.CapacityUtilization.ToString("F1")%</span>
                                            <div class="text-xs text-secondary-light mt-4">@program.Capacity capacity</div>
                                        </td>
                                        <td class="text-center">
                                            @if (program.IsActive)
                                            {
                                                <span class="bg-success-focus text-success-main px-16 py-4 rounded-pill fw-medium text-sm">Active</span>
                                            }
                                            else
                                            {
                                                <span class="bg-danger-focus text-danger-main px-16 py-4 rounded-pill fw-medium text-sm">Inactive</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Export Button -->
    <div class="row gy-4 mt-1">
        <div class="col-12">
            <div class="card h-100 p-0">
                <div class="card-body p-24">
                    <a asp-action="ExportAnalytics" asp-route-reportType="programs" class="btn btn-success-600 radius-8 px-20 py-11">
                        <iconify-icon icon="solar:download-minimalistic-bold" class="icon text-xl line-height-1"></iconify-icon>
                        Export Programs Report
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/assets/js/lib/apexcharts.min.js"></script>
    <script>
        // Degree Distribution Donut Chart
        var degreeDistributionOptions = {
            series: [@string.Join(",", Model.DegreeDistribution.Values)],
            chart: {
                type: 'donut',
                height: 280
            },
            labels: [@Html.Raw(string.Join(",", Model.DegreeDistribution.Keys.Select(k => $"'{k}'")))],
            colors: ['#487FFF', '#45B369', '#FF9F43', '#EA5455', '#00CFE8'],
            legend: {
                show: false
            },
            plotOptions: {
                pie: {
                    donut: {
                        size: '70%',
                        labels: {
                            show: true,
                            total: {
                                show: true,
                                label: 'Total',
                                fontSize: '16px',
                                fontWeight: 600,
                                formatter: function (w) {
                                    return w.globals.seriesTotals.reduce((a, b) => a + b, 0)
                                }
                            }
                        }
                    }
                }
            },
            dataLabels: {
                enabled: true,
                formatter: function(val) {
                    return val.toFixed(0) + '%'
                }
            }
        };

        var degreeDistributionChart = new ApexCharts(document.querySelector("#degreeDistributionChart"), degreeDistributionOptions);
        degreeDistributionChart.render();

        // Language Distribution Column Chart
        var languageDistributionOptions = {
            series: [{
                name: 'Programs',
                data: [@string.Join(",", Model.LanguageDistribution.Values)]
            }],
            chart: {
                type: 'bar',
                height: 280,
                toolbar: {
                    show: false
                }
            },
            colors: ['#487FFF'],
            plotOptions: {
                bar: {
                    horizontal: false,
                    columnWidth: '55%',
                    borderRadius: 8
                }
            },
            dataLabels: {
                enabled: false
            },
            stroke: {
                show: true,
                width: 2,
                colors: ['transparent']
            },
            xaxis: {
                categories: [@Html.Raw(string.Join(",", Model.LanguageDistribution.Keys.Select(k => $"'{k}'")))],
            },
            yaxis: {
                title: {
                    text: 'Number of Programs'
                }
            },
            fill: {
                opacity: 1
            },
            tooltip: {
                y: {
                    formatter: function (val) {
                        return val + " programs"
                    }
                }
            }
        };

        var languageDistributionChart = new ApexCharts(document.querySelector("#languageDistributionChart"), languageDistributionOptions);
        languageDistributionChart.render();
    </script>
}
