@model Uni_Selector.ViewModels.UniversityAdmin.UniversityListViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Universities Management";
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-24">
    <h6 class="fw-semibold mb-0">Universities Management</h6>
    <ul class="d-flex align-items-center gap-2">
        <li class="fw-medium">
            <a href="@Url.Action("Index", "Admin")" class="d-flex align-items-center gap-1 hover-text-primary">
                <iconify-icon icon="solar:home-smile-angle-outline" class="icon text-lg"></iconify-icon>
                Dashboard
            </a>
        </li>
        <li>-</li>
        <li class="fw-medium">Universities</li>
    </ul>
</div>

<div class="card h-100 p-0 radius-12">
    <div class="card-header border-bottom bg-base py-16 px-24 d-flex align-items-center flex-wrap gap-3 justify-content-between">
        <div class="d-flex align-items-center flex-wrap gap-3">
            <form asp-action="Index" method="get" class="d-flex align-items-center gap-3">
                <span class="text-md fw-medium text-secondary-light mb-0">Show</span>
                <select name="pageSize" class="form-select form-select-sm w-auto ps-12 py-6 radius-12 h-40-px" onchange="this.form.submit()">
                    <option value="10" selected="@(Model.PageSize == 10 ? "selected" : null)">10</option>
                    <option value="20" selected="@(Model.PageSize == 20 ? "selected" : null)">20</option>
                    <option value="50" selected="@(Model.PageSize == 50 ? "selected" : null)">50</option>
                    <option value="100" selected="@(Model.PageSize == 100 ? "selected" : null)">100</option>
                </select>

                <div class="navbar-search">
                    <input type="text" name="searchTerm" value="@Model.SearchTerm" class="bg-base h-40-px w-auto" placeholder="Search universities...">
                    <iconify-icon icon="ion:search-outline" class="icon"></iconify-icon>
                </div>

                <select name="province" class="form-select form-select-sm w-auto ps-12 py-6 radius-12 h-40-px" onchange="this.form.submit()">
                    <option value="">All Provinces</option>
                    @foreach (var province in Model.Provinces)
                    {
                        <option value="@province" selected="@(Model.Province == province ? "selected" : null)">@province</option>
                    }
                </select>

                <select name="isActive" class="form-select form-select-sm w-auto ps-12 py-6 radius-12 h-40-px" onchange="this.form.submit()">
                    <option value="">All Status</option>
                    <option value="true" selected="@(Model.IsActive == true ? "selected" : null)">Active</option>
                    <option value="false" selected="@(Model.IsActive == false ? "selected" : null)">Inactive</option>
                </select>

                <input type="hidden" name="page" value="@Model.CurrentPage" />
            </form>
        </div>
        <a asp-action="Create" class="btn btn-primary text-sm btn-sm px-12 py-12 radius-8 d-flex align-items-center gap-2">
            <iconify-icon icon="ic:baseline-plus" class="icon text-xl line-height-1"></iconify-icon>
            Add New University
        </a>
    </div>

    <div class="card-body p-24">
        <div class="table-responsive scroll-sm">
            <table class="table bordered-table sm-table mb-0">
                <thead>
                    <tr>
                        <th scope="col">
                            <div class="d-flex align-items-center gap-10">
                                <div class="form-check style-check d-flex align-items-center">
                                    <input class="form-check-input radius-4 border border-neutral-400" type="checkbox" id="selectAll">
                                </div>
                                ID
                            </div>
                        </th>
                        <th scope="col">Created</th>
                        <th scope="col">University</th>
                        <th scope="col">Location</th>
                        <th scope="col">Contact</th>
                        <th scope="col">Type</th>
                        <th scope="col">Representatives</th>
                        <th scope="col" class="text-center">Status</th>
                        <th scope="col" class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Universities.Any())
                    {
                        foreach (var university in Model.Universities)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-10">
                                        <div class="form-check style-check d-flex align-items-center">
                                            <input class="form-check-input radius-4 border border-neutral-400" type="checkbox" name="checkbox">
                                        </div>
                                        #@university.Id
                                    </div>
                                </td>
                                <td>@university.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        @if (!string.IsNullOrEmpty(university.LogoPath))
                                        {
                                            <img src="@university.LogoPath" alt="@university.NameEnglish" class="w-40-px h-40-px rounded-circle flex-shrink-0 me-12 overflow-hidden">
                                        }
                                        else
                                        {
                                            <div class="w-40-px h-40-px rounded-circle flex-shrink-0 me-12 bg-primary-50 d-flex align-items-center justify-content-center">
                                                <span class="text-primary-600 fw-bold">@university.NameEnglish[0]</span>
                                            </div>
                                        }
                                        <div class="flex-grow-1">
                                            <h6 class="text-md mb-0 fw-medium text-secondary-light">@university.NameEnglish</h6>
                                            <span class="text-sm text-secondary-light">@university.NameArabic</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="text-md mb-0 fw-normal text-secondary-light">@university.City, @university.Province</span>
                                </td>
                                <td>
                                    <div>
                                        <span class="text-sm text-secondary-light d-block">@university.Email</span>
                                        <span class="text-sm text-secondary-light">@university.PhoneNumber</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-info-focus text-info-600 px-24 py-4 radius-4 fw-medium text-sm">@university.Type</span>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-neutral-200 text-neutral-600 px-16 py-4 radius-4 fw-medium">
                                        @university.RepresentativesCount
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="@university.StatusBadgeClass px-24 py-4 radius-4 fw-medium text-sm">@university.StatusText</span>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex align-items-center gap-10 justify-content-center">
                                        <a asp-action="Details" asp-route-id="@university.Id"
                                           class="bg-info-focus bg-hover-info-200 text-info-600 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle"
                                           title="View Details">
                                            <iconify-icon icon="majesticons:eye-line" class="icon text-xl"></iconify-icon>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@university.Id"
                                           class="bg-success-focus text-success-600 bg-hover-success-200 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle"
                                           title="Edit">
                                            <iconify-icon icon="lucide:edit" class="menu-icon"></iconify-icon>
                                        </a>
                                        <a asp-action="Representatives" asp-route-id="@university.Id"
                                           class="bg-warning-focus text-warning-600 bg-hover-warning-200 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle"
                                           title="Manage Representatives">
                                            <iconify-icon icon="heroicons:users" class="menu-icon"></iconify-icon>
                                        </a>
                                        @if (university.IsActive)
                                        {
                                            <form asp-action="Suspend" asp-route-id="@university.Id" method="post" class="d-inline suspend-form">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="universityName" value="@university.NameEnglish" />
                                                <button type="submit" class="bg-danger-focus bg-hover-danger-200 text-danger-600 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle border-0"
                                                        title="Suspend">
                                                    <iconify-icon icon="mdi:cancel" class="menu-icon"></iconify-icon>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="Approve" asp-route-id="@university.Id" method="post" class="d-inline approve-form">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="universityName" value="@university.NameEnglish" />
                                                <button type="submit" class="bg-success-focus bg-hover-success-200 text-success-600 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle border-0"
                                                        title="Approve">
                                                    <iconify-icon icon="mdi:check-circle" class="menu-icon"></iconify-icon>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center py-32">
                                <iconify-icon icon="mdi:database-off" class="icon text-64 text-secondary-light mb-12"></iconify-icon>
                                <p class="text-secondary-light">No universities found</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mt-24">
                <span class="text-sm fw-medium text-secondary-light">
                    Showing @((Model.CurrentPage - 1) * Model.PageSize + 1) to
                    @Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalUniversities) of @Model.TotalUniversities
                </span>
                <ul class="pagination d-flex flex-wrap align-items-center gap-2 justify-content-center">
                    @if (Model.CurrentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link bg-neutral-200 text-secondary-light fw-semibold radius-8 border-0 d-flex align-items-center justify-content-center h-32-px w-32-px"
                               href="@Url.Action("Index", new { page = Model.CurrentPage - 1, pageSize = Model.PageSize, searchTerm = Model.SearchTerm, province = Model.Province, isActive = Model.IsActive })">
                                <iconify-icon icon="ep:d-arrow-left" class=""></iconify-icon>
                            </a>
                        </li>
                    }

                    @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                    {
                        <li class="page-item">
                            <a class="page-link @(i == Model.CurrentPage ? "bg-primary-600 text-white" : "bg-neutral-200 text-secondary-light") fw-semibold radius-8 border-0 d-flex align-items-center justify-content-center h-32-px w-32-px"
                               href="@Url.Action("Index", new { page = i, pageSize = Model.PageSize, searchTerm = Model.SearchTerm, province = Model.Province, isActive = Model.IsActive })">
                                @i
                            </a>
                        </li>
                    }

                    @if (Model.CurrentPage < Model.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link bg-neutral-200 text-secondary-light fw-semibold radius-8 border-0 d-flex align-items-center justify-content-center h-32-px w-32-px"
                               href="@Url.Action("Index", new { page = Model.CurrentPage + 1, pageSize = Model.PageSize, searchTerm = Model.SearchTerm, province = Model.Province, isActive = Model.IsActive })">
                                <iconify-icon icon="ep:d-arrow-right" class=""></iconify-icon>
                            </a>
                        </li>
                    }
                </ul>
            </div>
        }
    </div>
</div>

@using System.Text.Json

@section Scripts {
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // Select all checkbox functionality
        document.getElementById('selectAll')?.addEventListener('change', function() {
            const checkboxes = document.querySelectorAll('input[name="checkbox"]');
            checkboxes.forEach(checkbox => checkbox.checked = this.checked);
        });

        // Handle Suspend Form Submissions
        document.querySelectorAll('.suspend-form').forEach(form => {
            form.addEventListener('submit', function(e) {
                e.preventDefault();

                const universityName = this.querySelector('input[name="universityName"]').value;
                const submitForm = this;

                Swal.fire({
                    title: 'Suspend University?',
                    html: `Are you sure you want to suspend<br><strong>${universityName}</strong>?<br><br><small class="text-danger">This will deactivate the university and prevent new applications.</small>`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Yes, Suspend',
                    cancelButtonText: 'Cancel'
                }).then((result) => {
                    if (result.isConfirmed) {
                        submitForm.submit();
                    }
                });
            });
        });

        // Handle Approve Form Submissions
        document.querySelectorAll('.approve-form').forEach(form => {
            form.addEventListener('submit', function(e) {
                e.preventDefault();

                const universityName = this.querySelector('input[name="universityName"]').value;
                const submitForm = this;

                Swal.fire({
                    title: 'Approve University?',
                    html: `Are you sure you want to approve<br><strong>${universityName}</strong>?<br><br><small class="text-success">This will activate the university and allow new applications.</small>`,
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#198754',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Yes, Approve',
                    cancelButtonText: 'Cancel'
                }).then((result) => {
                    if (result.isConfirmed) {
                        submitForm.submit();
                    }
                });
            });
        });

        // ✅ Show success/error messages from TempData (FIXED ENCODING)
        const successMsg = @Html.Raw(JsonSerializer.Serialize(TempData["Success"]?.ToString()));
        if (successMsg) {
            Swal.fire({
                icon: 'success',
                title: 'Success!',
                text: successMsg,
                confirmButtonColor: '#198754',
                timer: 3000,
                timerProgressBar: true
            });
        }

        const errorMsg = @Html.Raw(JsonSerializer.Serialize(TempData["Error"]?.ToString()));
        if (errorMsg) {
            Swal.fire({
                icon: 'error',
                title: 'Error!',
                text: errorMsg,
                confirmButtonColor: '#dc3545'
            });
        }
    </script>
}
