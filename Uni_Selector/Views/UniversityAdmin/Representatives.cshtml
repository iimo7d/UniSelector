@model Uni_Selector.ViewModels.UniversityAdmin.UniversityRepresentativesViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = $"{Model.University.NameEnglish} - Representatives";
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-24">
    <h6 class="fw-semibold mb-0">Manage Representatives</h6>
    <ul class="d-flex align-items-center gap-2">
        <li class="fw-medium">
            <a href="@Url.Action("Index", "Admin")" class="d-flex align-items-center gap-1 hover-text-primary">
                <iconify-icon icon="solar:home-smile-angle-outline" class="icon text-lg"></iconify-icon>
                Dashboard
            </a>
        </li>
        <li>-</li>
        <li class="fw-medium">
            <a asp-action="Index" class="hover-text-primary">Universities</a>
        </li>
        <li>-</li>
        <li class="fw-medium">@Model.University.NameEnglish</li>
        <li>-</li>
        <li class="fw-medium">Representatives</li>
    </ul>
</div>

<!-- University Info Card -->
<div class="card mb-24">
    <div class="card-body p-24">
        <div class="d-flex align-items-center gap-3">
            @if (!string.IsNullOrEmpty(Model.University.LogoPath))
            {
                <img src="@Model.University.LogoPath" alt="@Model.University.NameEnglish" class="w-64-px h-64-px rounded-circle object-fit-cover">
            }
            else
            {
                <div class="w-64-px h-64-px rounded-circle bg-primary-50 d-flex align-items-center justify-content-center">
                    <span class="text-primary-600 fw-bold text-2xl">@Model.University.NameEnglish[0]</span>
                </div>
            }
            <div class="flex-grow-1">
                <h5 class="mb-1">@Model.University.NameEnglish</h5>
                <p class="text-secondary-light mb-1">@Model.University.NameArabic</p>
                <span class="badge @(Model.University.IsActive ? "bg-success-focus text-success-600" : "bg-neutral-200 text-neutral-600")">
                    @(Model.University.IsActive ? "Active" : "Inactive")
                </span>
            </div>
            <div>
                <a asp-action="Details" asp-route-id="@Model.University.Id" class="btn btn-outline-primary btn-sm">
                    <iconify-icon icon="majesticons:eye-line" class="icon me-1"></iconify-icon>
                    View Details
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Representatives Management Card -->
<div class="card h-100 p-0 radius-12">
    <div class="card-header border-bottom bg-base py-16 px-24 d-flex align-items-center flex-wrap gap-3 justify-content-between">
        <h6 class="mb-0">University Representatives (@Model.Representatives.Count)</h6>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-success text-sm btn-sm px-12 py-12 radius-8 d-flex align-items-center gap-2"
                    data-bs-toggle="modal" data-bs-target="#createRepresentativeModal">
                <iconify-icon icon="ic:baseline-plus" class="icon text-xl line-height-1"></iconify-icon>
                Create New Representative
            </button>
            @if (Model.AvailableUsers.Any())
            {
                <button type="button" class="btn btn-primary text-sm btn-sm px-12 py-12 radius-8 d-flex align-items-center gap-2"
                        data-bs-toggle="modal" data-bs-target="#addRepresentativeModal">
                    <iconify-icon icon="mdi:account-plus" class="icon text-xl line-height-1"></iconify-icon>
                    Assign Existing User
                </button>
            }
        </div>
    </div>

    <div class="card-body p-24">
        @if (Model.Representatives.Any())
        {
            <div class="table-responsive scroll-sm">
                <table class="table bordered-table sm-table mb-0">
                    <thead>
                        <tr>
                            <th scope="col">
                                <div class="d-flex align-items-center gap-10">
                                    <div class="form-check style-check d-flex align-items-center">
                                        <input class="form-check-input radius-4 border border-neutral-400" type="checkbox" id="selectAll">
                                    </div>
                                    ID
                                </div>
                            </th>
                            <th scope="col">Assigned Date</th>
                            <th scope="col">Representative</th>
                            <th scope="col">Email</th>
                            <th scope="col">Position</th>
                            <th scope="col" class="text-center">Permissions</th>
                            <th scope="col" class="text-center">Status</th>
                            <th scope="col" class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var rep in Model.Representatives)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-10">
                                        <div class="form-check style-check d-flex align-items-center">
                                            <input class="form-check-input radius-4 border border-neutral-400" type="checkbox" name="checkbox">
                                        </div>
                                        #@rep.Id
                                    </div>
                                </td>
                                <td>@rep.AssignedAt.ToString("dd MMM yyyy")</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="w-40-px h-40-px rounded-circle flex-shrink-0 me-12 bg-primary-50 d-flex align-items-center justify-content-center">
                                            <span class="text-primary-600 fw-bold">@rep.UserFullName[0]</span>
                                        </div>
                                        <div class="flex-grow-1">
                                            <span class="text-md mb-0 fw-normal text-secondary-light">@rep.UserFullName</span>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="text-md mb-0 fw-normal text-secondary-light">@rep.UserEmail</span></td>
                                <td>
                                    @if (!string.IsNullOrEmpty(rep.Position))
                                    {
                                        <span class="badge bg-info-focus text-info-600">@rep.Position</span>
                                    }
                                    else
                                    {
                                        <span class="text-secondary-light">N/A</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="d-flex gap-1 justify-content-center flex-wrap">
                                        @if (rep.CanManagePrograms)
                                        {
                                            <span class="badge bg-info-focus text-info-600 px-8 py-4 radius-4 text-xs" title="Can Manage Programs">
                                                <iconify-icon icon="mdi:book-education"></iconify-icon> Programs
                                            </span>
                                        }
                                        @if (rep.CanManageFees)
                                        {
                                            <span class="badge bg-warning-focus text-warning-600 px-8 py-4 radius-4 text-xs" title="Can Manage Fees">
                                                <iconify-icon icon="mdi:cash"></iconify-icon> Fees
                                            </span>
                                        }
                                        @if (rep.CanViewApplications)
                                        {
                                            <span class="badge bg-success-focus text-success-600 px-8 py-4 radius-4 text-xs" title="Can View Applications">
                                                <iconify-icon icon="mdi:file-document"></iconify-icon> Apps
                                            </span>
                                        }
                                    </div>
                                </td>
                                <td class="text-center">
                                    @if (rep.IsActive)
                                    {
                                        <span class="bg-success-focus text-success-600 border border-success-main px-24 py-4 radius-4 fw-medium text-sm">Active</span>
                                    }
                                    else
                                    {
                                        <span class="bg-neutral-200 text-neutral-600 border border-neutral-400 px-24 py-4 radius-4 fw-medium text-sm">Inactive</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="d-flex align-items-center gap-10 justify-content-center">
                                        <button type="button"
                                                class="bg-success-focus text-success-600 bg-hover-success-200 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle border-0"
                                                title="Edit Representative"
                                                onclick="loadEditModal(@rep.Id, @Model.University.Id)">
                                            <iconify-icon icon="lucide:edit" class="menu-icon"></iconify-icon>
                                        </button>
                                        <button type="button"
                                                class="bg-danger-focus bg-hover-danger-200 text-danger-600 fw-medium w-40-px h-40-px d-flex justify-content-center align-items-center rounded-circle border-0"
                                                title="Remove Representative"
                                                onclick="showRemoveModal(@rep.Id, '@rep.UserFullName', '@Model.University.Id')">
                                            <iconify-icon icon="fluent:delete-24-regular" class="menu-icon"></iconify-icon>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-64">
                <iconify-icon icon="mdi:account-off" class="icon text-64 text-secondary-light mb-12"></iconify-icon>
                <p class="text-secondary-light mb-0">No representatives assigned yet.</p>
                <div class="d-flex gap-2 justify-content-center mt-16">
                    <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createRepresentativeModal">
                        <iconify-icon icon="ic:baseline-plus" class="icon me-1"></iconify-icon>
                        Create First Representative
                    </button>
                    @if (Model.AvailableUsers.Any())
                    {
                        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addRepresentativeModal">
                            <iconify-icon icon="mdi:account-plus" class="icon me-1"></iconify-icon>
                            Assign Existing User
                        </button>
                    }
                </div>
            </div>
        }
    </div>
</div>

<!-- Create Representative Modal -->
<div class="modal fade" id="createRepresentativeModal" tabindex="-1" aria-labelledby="createRepresentativeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-success-focus">
                <h5 class="modal-title d-flex align-items-center gap-2" id="createRepresentativeModalLabel">
                    <iconify-icon icon="mdi:account-plus-outline" class="icon text-xl text-success-600"></iconify-icon>
                    Create New Representative
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="createRepForm" asp-action="CreateRepresentative" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="UniversityId" value="@Model.University.Id" />
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 mb-20">
                            <label for="createFullName" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                Full Name <span class="text-danger-600">*</span>
                            </label>
                            <input type="text" name="FullName" id="createFullName" class="form-control radius-8" required placeholder="Enter full name">
                        </div>
                        <div class="col-md-6 mb-20">
                            <label for="createEmail" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                Email <span class="text-danger-600">*</span>
                            </label>
                            <input type="email" name="Email" id="createEmail" class="form-control radius-8" required placeholder="Enter email">
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-20">
                            <label for="createPhoneNumber" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                Phone Number <span class="text-danger-600">*</span>
                            </label>
                            <input type="tel" name="PhoneNumber" id="createPhoneNumber" class="form-control radius-8" required placeholder="Enter phone number">
                        </div>
                        <div class="col-md-6 mb-20">
                            <label for="createPosition" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                Position
                            </label>
                            <input type="text" name="Position" id="createPosition" class="form-control radius-8" placeholder="e.g., Senior Representative">
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-20">
                            <label for="createPassword" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                Password <span class="text-danger-600">*</span>
                            </label>
                            <input type="password" name="Password" id="createPassword" class="form-control radius-8" required minlength="6" placeholder="Min. 6 characters">
                        </div>
                        <div class="col-md-6 mb-20">
                            <label for="createConfirmPassword" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                Confirm Password <span class="text-danger-600">*</span>
                            </label>
                            <input type="password" name="ConfirmPassword" id="createConfirmPassword" class="form-control radius-8" required placeholder="Confirm password">
                        </div>
                    </div>

                    <h6 class="text-md text-primary-light mb-12 mt-3">Permissions</h6>
                    <div class="row">
                        <div class="col-md-4 mb-12">
                            <div class="form-check style-check d-flex align-items-center">
                                <input class="form-check-input" type="checkbox" name="CanManagePrograms" id="createCanManagePrograms" value="true" checked>
                                <input type="hidden" name="CanManagePrograms" value="false">
                                <label class="form-check-label" for="createCanManagePrograms">
                                    Can Manage Programs
                                </label>
                            </div>
                        </div>
                        <div class="col-md-4 mb-12">
                            <div class="form-check style-check d-flex align-items-center">
                                <input class="form-check-input" type="checkbox" name="CanManageFees" id="createCanManageFees" value="true" checked>
                                <input type="hidden" name="CanManageFees" value="false">
                                <label class="form-check-label" for="createCanManageFees">
                                    Can Manage Fees
                                </label>
                            </div>
                        </div>
                        <div class="col-md-4 mb-12">
                            <div class="form-check style-check d-flex align-items-center">
                                <input class="form-check-input" type="checkbox" name="CanViewApplications" id="createCanViewApplications" value="true" checked>
                                <input type="hidden" name="CanViewApplications" value="false">
                                <label class="form-check-label" for="createCanViewApplications">
                                    Can View Applications
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-info d-flex align-items-start gap-2 mt-3 mb-0" role="alert">
                        <iconify-icon icon="mdi:information" class="icon text-lg flex-shrink-0 mt-4"></iconify-icon>
                        <div>
                            <small>A new user account will be created with UniversityRep role and assigned to this university.</small>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">
                        <iconify-icon icon="mdi:account-plus" class="icon me-1"></iconify-icon>
                        Create Representative
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Add Representative Modal (Assign Existing User) -->
<div class="modal fade" id="addRepresentativeModal" tabindex="-1" aria-labelledby="addRepresentativeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary-50">
                <h5 class="modal-title d-flex align-items-center gap-2" id="addRepresentativeModalLabel">
                    <iconify-icon icon="mdi:account-plus" class="icon text-xl text-primary-600"></iconify-icon>
                    Assign Existing User
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="addRepForm" asp-action="AddRepresentative" asp-route-id="@Model.University.Id" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    @if (Model.AvailableUsers.Any())
                    {
                        <div class="mb-20">
                            <label for="userId" class="form-label fw-semibold text-primary-light text-sm mb-8">
                                Select User <span class="text-danger-600">*</span>
                            </label>
                            <select name="userId" id="userId" class="form-control radius-8 form-select" required>
                                <option value="">-- Select a user --</option>
                                @foreach (var item in Model.AvailableUsers)
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            </select>
                            <small class="text-secondary-light mt-1 d-block">
                                <iconify-icon icon="mdi:information" class="icon"></iconify-icon>
                                Only students and normal users are shown
                            </small>
                        </div>
                        <div class="alert alert-info d-flex align-items-start gap-2 mb-0" role="alert">
                            <iconify-icon icon="mdi:information" class="icon text-lg flex-shrink-0 mt-4"></iconify-icon>
                            <div>
                                <strong class="d-block mb-2">Default Permissions:</strong>
                                <ul class="mb-0 ps-3">
                                    <li><small>Can Manage Programs ✓</small></li>
                                    <li><small>Can Manage Fees ✓</small></li>
                                    <li><small>Can View Applications ✓</small></li>
                                </ul>
                                <small class="d-block mt-2 text-muted">The user will be assigned the UniversityRep role automatically.</small>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning mb-0" role="alert">
                            <iconify-icon icon="mdi:alert" class="icon me-2"></iconify-icon>
                            No available users found. All eligible users are already assigned.
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    @if (Model.AvailableUsers.Any())
                    {
                        <button type="submit" class="btn btn-primary">
                            <iconify-icon icon="mdi:account-plus" class="icon me-1"></iconify-icon>
                            Assign User
                        </button>
                    }
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Representative Modal -->
<div class="modal fade" id="editRepresentativeModal" tabindex="-1" aria-labelledby="editRepresentativeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-warning-focus">
                <h5 class="modal-title d-flex align-items-center gap-2" id="editRepresentativeModalLabel">
                    <iconify-icon icon="lucide:edit" class="icon text-xl text-warning-600"></iconify-icon>
                    Edit Representative
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="editRepForm" asp-action="EditRepresentative" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editId" name="Id" />
                <input type="hidden" id="editUniversityId" name="UniversityId" />
                <input type="hidden" id="editUserId" name="UserId" />
                <div class="modal-body">
                    <div class="mb-20">
                        <label class="form-label fw-semibold text-primary-light text-sm mb-8">Representative</label>
                        <div class="d-flex align-items-center gap-2 p-3 bg-neutral-50 radius-8">
                            <div class="w-40-px h-40-px rounded-circle bg-primary-50 d-flex align-items-center justify-content-center">
                                <iconify-icon icon="mdi:account" class="icon text-xl text-primary-600"></iconify-icon>
                            </div>
                            <div>
                                <div class="fw-semibold" id="editUserFullName"></div>
                                <small class="text-secondary-light" id="editUserEmail"></small>
                            </div>
                        </div>
                    </div>

                    <div class="mb-20">
                        <label for="editPosition" class="form-label fw-semibold text-primary-light text-sm mb-8">
                            Position
                        </label>
                        <input type="text" name="Position" id="editPosition" class="form-control radius-8" placeholder="e.g., Senior Representative">
                    </div>

                    <h6 class="text-md text-primary-light mb-12">Permissions</h6>
                    <div class="mb-12">
                        <div class="form-check style-check d-flex align-items-center">
                            <input class="form-check-input" type="checkbox" name="CanManagePrograms" id="editCanManagePrograms" value="true">
                            <input type="hidden" name="CanManagePrograms" value="false">
                            <label class="form-check-label" for="editCanManagePrograms">
                                Can Manage Programs
                            </label>
                        </div>
                    </div>
                    <div class="mb-12">
                        <div class="form-check style-check d-flex align-items-center">
                            <input class="form-check-input" type="checkbox" name="CanManageFees" id="editCanManageFees" value="true">
                            <input type="hidden" name="CanManageFees" value="false">
                            <label class="form-check-label" for="editCanManageFees">
                                Can Manage Fees
                            </label>
                        </div>
                    </div>
                    <div class="mb-12">
                        <div class="form-check style-check d-flex align-items-center">
                            <input class="form-check-input" type="checkbox" name="CanViewApplications" id="editCanViewApplications" value="true">
                            <input type="hidden" name="CanViewApplications" value="false">
                            <label class="form-check-label" for="editCanViewApplications">
                                Can View Applications
                            </label>
                        </div>
                    </div>

                    <div class="mb-0 mt-3">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" name="IsActive" id="editIsActive" value="true">
                            <input type="hidden" name="IsActive" value="false">
                            <label class="form-check-label" for="editIsActive">
                                Active Status
                            </label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning">
                        <iconify-icon icon="mdi:content-save" class="icon me-1"></iconify-icon>
                        Update Representative
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Remove Representative Modal -->
<div class="modal fade" id="removeRepresentativeModal" tabindex="-1" aria-labelledby="removeRepresentativeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger-focus">
                <h5 class="modal-title d-flex align-items-center gap-2" id="removeRepresentativeModalLabel">
                    <iconify-icon icon="mdi:account-remove" class="icon text-xl text-danger-600"></iconify-icon>
                    Remove Representative
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="removeRepForm" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="alert alert-danger d-flex align-items-start gap-2" role="alert">
                        <iconify-icon icon="mdi:alert-circle" class="icon text-2xl flex-shrink-0"></iconify-icon>
                        <div>
                            <strong class="d-block mb-1">Are you sure?</strong>
                            <p class="mb-0">You are about to remove <strong id="removeRepName"></strong> as a representative for this university.</p>
                        </div>
                    </div>
                    <div class="bg-light p-3 radius-8">
                        <p class="mb-2 fw-semibold text-sm">This action will:</p>
                        <ul class="mb-0 text-sm">
                            <li>Remove all representative permissions</li>
                            <li>Revoke access to university management</li>
                            <li>Send a notification to the user</li>
                        </ul>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">
                        <iconify-icon icon="mdi:account-remove" class="icon me-1"></iconify-icon>
                        Remove Representative
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@using System.Text.Json

@section Scripts {
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // Select all checkbox functionality
        document.getElementById('selectAll')?.addEventListener('change', function() {
            const checkboxes = document.querySelectorAll('input[name="checkbox"]');
            checkboxes.forEach(checkbox => checkbox.checked = this.checked);
        });

        // Show Remove Representative Modal
        function showRemoveModal(repId, repName, universityId) {
            document.getElementById('removeRepName').textContent = repName;
            const form = document.getElementById('removeRepForm');
            form.action = `/UniversityAdmin/RemoveRepresentative/${universityId}?repId=${repId}`;

            const modal = new bootstrap.Modal(document.getElementById('removeRepresentativeModal'));
            modal.show();
        }

        // Load Edit Representative Modal
        async function loadEditModal(repId, universityId) {
            try {
                const response = await fetch(`/UniversityAdmin/EditRepresentative/${universityId}?repId=${repId}`);
                const data = await response.json();

                if (data.error) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: data.error
                    });
                    return;
                }

                // Populate form
                document.getElementById('editId').value = data.id;
                document.getElementById('editUniversityId').value = data.universityId;
                document.getElementById('editUserId').value = data.userId;
                document.getElementById('editUserFullName').textContent = data.userFullName;
                document.getElementById('editUserEmail').textContent = data.userEmail;
                document.getElementById('editPosition').value = data.position || '';
                document.getElementById('editCanManagePrograms').checked = data.canManagePrograms;
                document.getElementById('editCanManageFees').checked = data.canManageFees;
                document.getElementById('editCanViewApplications').checked = data.canViewApplications;
                document.getElementById('editIsActive').checked = data.isActive;

                const modal = new bootstrap.Modal(document.getElementById('editRepresentativeModal'));
                modal.show();
            } catch (error) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Failed to load representative data'
                });
            }
        }

        // Handle Create Representative Form Submission
        document.getElementById('createRepForm')?.addEventListener('submit', function(e) {
            e.preventDefault();

            const form = this;
            const password = document.getElementById('createPassword').value;
            const confirmPassword = document.getElementById('createConfirmPassword').value;

            if (password !== confirmPassword) {
                Swal.fire({
                    icon: 'error',
                    title: 'Password Mismatch',
                    text: 'Password and Confirm Password do not match.',
                    confirmButtonColor: '#dc3545'
                });
                return;
            }

            Swal.fire({
                title: 'Create Representative?',
                text: 'A new user account will be created and assigned as a representative.',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#198754',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, Create',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
        });

        // Handle Add Representative Form Submission
        document.getElementById('addRepForm')?.addEventListener('submit', function(e) {
            e.preventDefault();

            const form = this;
            const userId = document.getElementById('userId').value;

            if (!userId) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Please Select a User',
                    text: 'You must select a user before submitting.',
                    confirmButtonColor: '#3085d6'
                });
                return;
            }

            Swal.fire({
                title: 'Assign Representative?',
                text: 'Are you sure you want to assign this user as a representative?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, Assign',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
        });

        // Handle Edit Representative Form Submission
        document.getElementById('editRepForm')?.addEventListener('submit', function(e) {
            e.preventDefault();

            const form = this;
            const repName = document.getElementById('editUserFullName').textContent;

            Swal.fire({
                title: 'Update Representative?',
                html: `Are you sure you want to update <strong>${repName}</strong>'s permissions and details?`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#ffc107',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, Update',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
        });

        // Handle Remove Representative Form Submission
        document.getElementById('removeRepForm')?.addEventListener('submit', function(e) {
            e.preventDefault();

            const form = this;
            const repName = document.getElementById('removeRepName').textContent;

            Swal.fire({
                title: 'Remove Representative?',
                html: `Are you sure you want to remove <strong>${repName}</strong> as a representative?<br><br><small class="text-danger">This action will revoke all their access and permissions.</small>`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, Remove',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
        });

        // ✅ Show success/error messages from TempData (FIXED ENCODING)
        const successMsg = @Html.Raw(JsonSerializer.Serialize(TempData["Success"]?.ToString()));
        if (successMsg) {
            Swal.fire({
                icon: 'success',
                title: 'Success!',
                text: successMsg,
                confirmButtonColor: '#198754',
                timer: 3000,
                timerProgressBar: true
            });
        }

        const errorMsg = @Html.Raw(JsonSerializer.Serialize(TempData["Error"]?.ToString()));
        if (errorMsg) {
            Swal.fire({
                icon: 'error',
                title: 'Error!',
                text: errorMsg,
                confirmButtonColor: '#dc3545'
            });
        }
    </script>
}
